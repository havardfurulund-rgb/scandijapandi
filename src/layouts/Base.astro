---
// Shared brand shell for every page (storefront, admin, status pages) so the
// whole site — including the admin and the forms — carries the same identity:
// the ScandiJapandi palette (paper / ink / stone / oat / clay) and the
// Fraunces + Jost type pairing. Tailwind is compiled at build time via the
// @astrojs/tailwind integration (colors live in tailwind.config.mjs). Utility
// classes on markup injected at runtime (the dynamic product grid and the admin
// table) still work because those classes also appear in the scanned source.
import CookieBanner from '../components/CookieBanner.astro';
interface Props {
  title?: string;
  description?: string;
}
const {
  title = "ScandiJapandi — Skandinavisk håndverk, ren nordisk ro",
  description = "A curated collection of timeless Scandinavian objects for the Japanese and Asian market. Nordic craft, uncompromising quality.",
} = Astro.props;
---

<!doctype html>
<html lang="no" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- SEO -->
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={`https://scandijapandi.no${Astro.url.pathname}`} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="ScandiJapandi Collection" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={`https://scandijapandi.no${Astro.url.pathname}`} />
    <meta property="og:image" content="https://scandijapandi.no/images/og-image.svg" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:locale:alternate" content="ja_JP" />
    <meta property="og:locale:alternate" content="nb_NO" />

    <!-- Twitter/X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://scandijapandi.no/images/og-image.svg" />

    <!-- Language alternates -->
    <link rel="alternate" hreflang="no" href={`https://scandijapandi.no${Astro.url.pathname}`} />
    <link rel="alternate" hreflang="en" href={`https://scandijapandi.no${Astro.url.pathname}`} />
    <link rel="alternate" hreflang="ja" href={`https://scandijapandi.no${Astro.url.pathname}`} />
    <link rel="alternate" hreflang="x-default" href={`https://scandijapandi.no${Astro.url.pathname}`} />

    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,400;9..144,500&family=Jost:wght@300;400;500&display=swap"
    />
    <style>
      body { font-family: 'Jost', sans-serif; background-color: #FBFBFA; color: #1A1A1A; }
      .font-serif { font-family: 'Fraunces', serif; }
      .reveal { opacity: 0; transform: translateY(20px); transition: opacity 1s ease, transform 1s ease; }
      .reveal.is-visible { opacity: 1; transform: translateY(0); }
      .lang-btn { opacity: 0.45; transition: opacity .2s ease; }
      .lang-btn[aria-current="true"] { opacity: 1; }
      .lang-btn:hover { opacity: 0.85; }
    </style>
  </head>
  <body class="overflow-x-hidden bg-paper text-ink antialiased">
    <slot />
    <CookieBanner />
  </body>
</html>
