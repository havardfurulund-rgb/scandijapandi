---
import Base from '../layouts/Base.astro';
---

<Base title="Takk — ScandiJapandi">
  <main class="min-h-screen flex items-center justify-center px-6 py-32 bg-[#E2DFD9]">
    <div class="max-w-lg text-center">
      <span class="text-[10px] font-medium uppercase tracking-widest text-stone block mb-4">ScandiJapandi</span>
      <h1 class="font-serif text-4xl sm:text-5xl text-ink leading-tight">Takk for at du tok kontakt</h1>
      <p class="mt-6 text-base text-stone font-light leading-relaxed">
        Vi har mottatt informasjonen din og tar vare på den. Du hører fra oss når vi har noe
        som er relevant for nettopp dine interesser.
      </p>
      <a href="/" class="mt-10 inline-block bg-ink text-paper px-8 py-4 text-[10px] font-medium uppercase tracking-widest transition-colors hover:bg-clay">
        Tilbake til forsiden
      </a>
    </div>
  </main>
</Base>
