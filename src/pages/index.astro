---
import { sanityClient } from 'sanity:client';
import imageUrlBuilder from '@sanity/image-url';

// Henter alle produktdetaljer + SLUG (Viktig for API-et)
const QUERY = `*[_type == "product" && defined(title)] | order(_createdAt asc){
  _id,
  title,
  price,
  subtitle,
  "slug": slug.current,
  "excerpt": pt::text(body),
  mainImage{ ..., asset->{ url, metadata{ lqip } } }
}`;

let docs = [];
try {
  docs = (await sanityClient.fetch(QUERY)) ?? [];
} catch {
  docs = [];
}

const builder = imageUrlBuilder(sanityClient);
const buildImage = (img) => {
  const base = builder.image(img).auto('format').fit('crop').quality(78);
  return {
    src: base.width(800).height(1000).url(),
    srcset: [400, 800, 1200]
      .map((w) => `${base.width(w).height(Math.round(w * 1.25)).url()} ${w}w`)
      .join(', '),
    lqip: img?.asset?.metadata?.lqip ?? null,
  };
};

const sanityItems = docs.map((d) => ({
  title: d.title,
  maker: d.subtitle || 'ScandiJapandi Collection',
  price: d.price,
  slug: d.slug || '',
  excerpt: d.excerpt ? d.excerpt.slice(0, 150) : '',
  alt: d.mainImage?.alt ?? d.title,
  ...(d.mainImage?.asset ? buildImage(d.mainImage) : { src: null, srcset: null, lqip: null }),
}));

const fallback = [
  { title: 'Curved Birch Tray', maker: 'Studio Bjørk · Bergen', price: 895, slug: 'curved-birch-tray', alt: 'Curved birch serving tray', src: '/images/products/wood-tray.jpg', excerpt: 'A single sweep of steam-bent Nordic birch, oiled by hand and left to show its grain.' },
  { title: 'Matte Stoneware Vase', maker: 'Sōen Keramikk · Kyoto', price: 1450, slug: 'matte-stoneware-vase', alt: 'Matte stoneware vase', src: '/images/products/ceramic-vase.jpg', excerpt: 'Thrown in a chalk-grey clay and fired low, so the surface stays soft to the touch.' },
];

const products = sanityItems.length > 0 ? sanityItems : fallback;

const nok = new Intl.NumberFormat('nb-NO', {
  style: 'currency',
  currency: 'NOK',
  maximumFractionDigits: 0,
});
---

<!doctype html>
<html lang="no" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ScandiJapandi — Nordisk ro, japansk håndverk</title>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,400;9..144,500&family=Jost:wght@300;400;500&display=swap" />
    
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              paper: '#FBFBFA',
              ink: '#1A1A1A',
              stone: '#706E6B',
              oat: '#F1EFEA',
              clay: '#A37B65',
            }
          }
        }
      }
    </script>
    
    <style>
      body { font-family: 'Jost', sans-serif; background-color: #FBFBFA; color: #1A1A1A; }
      .font-serif { font-family: 'Fraunces', serif; }
    </style>
  </head>

  <body class="overflow-x-hidden bg-paper text-ink antialiased">
    
    <header class="fixed inset-x-0 top-0 z-50 border-b border-ink/5 bg-paper/80 backdrop-blur-md">
      <div class="mx-auto flex h-20 max-w-6xl items-center justify-between px-6 sm:px-12">
        <a href="#top" class="font-serif text-xl tracking-tight">ScandiJapandi</a>
        <nav class="flex items-center gap-10 text-[10px] font-medium uppercase tracking-widest text-stone">
          <a href="#collection" class="hover:text-ink">Kolleksjon</a>
          <a href="#about" class="hover:text-ink">Om oss</a>
          <a href="#partner" class="hover:text-ink">Bli Partner</a>
        </nav>
      </div>
    </header>

    <section id="top" class="relative flex min-h-screen items-center overflow-hidden bg-[#E2DFD9] pt-20">
      <div class="relative z-10 mx-auto w-full max-w-6xl px-6 sm:px-12 py-20">
        <div class="max-w-2xl">
          <span class="text-[10px] font-medium uppercase tracking-widest text-stone block mb-4">Etablert 2026</span>
          <h1 class="font-serif text-5xl sm:text-7xl leading-[1.1] tracking-tight text-ink">
            Der nordisk ro møter japansk håndverk
          </h1>
          <p class="mt-8 text-base sm:text-lg text-stone font-light leading-relaxed max-w-lg">
            En kuratert samling av tidløse objekter for det moderne hjem. Rene linjer fra den skandinaviske designtradisjonen forent med kompromissløs japansk estetikk og kvalitet.
          </p>
          <div class="mt-10">
            <a href="#collection" class="inline-block bg-ink text-paper px-8 py-4 text-[10px] font-medium uppercase tracking-widest hover:bg-clay transition-colors">
              Utforsk kolleksjonen
            </a>
          </div>
        </div>
      </div>
    </section>

    <section id="about" class="px-6 sm:px-12 py-32 bg-paper border-b border-ink/5">
      <div class="mx-auto max-w-3xl text-center">
        <span class="text-[10px] font-medium uppercase tracking-widest text-stone block mb-4">Vår Filosofi</span>
        <h2 class="font-serif text-3xl sm:text-4xl text-ink leading-snug">«Wabi-sabi» og skandinavisk funksjonalitet. Vi feirer det uperfekte, det naturlige og det som er skapt for å vare i generasjoner.</h2>
      </div>
    </section>

    <section id="collection" class="px-6 sm:px-12 py-32 mx-auto max-w-6xl">
      <div class="flex flex-col md:flex-row md:items-baseline justify-between mb-20">
        <div>
          <span class="text-[10px] font-medium uppercase tracking-widest text-stone block mb-2">Kuratert utvalg</span>
          <h2 class="font-serif text-3xl sm:text-4xl text-ink">ScandiJapandi Collection</h2>
        </div>
        <p class="text-sm text-stone font-light max-w-xs mt-4 md:mt-0 leading-relaxed">
          Alle våre objekter er håndplukket eller utviklet i samarbeid med uavhengige kunstnere og håndverkere.
        </p>
      </div>

      <div class="grid grid-cols-1 gap-x-12 gap-y-24 sm:grid-cols-2 lg:grid-cols-3">
        {products.map((item) => (
          <article class="flex flex-col justify-between group">
            <div>
              <div class="relative aspect-[4/5] bg-oat overflow-hidden">
                {item.src ? (
                  <img src={item.src} srcset={item.srcset} alt={item.alt} class="h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-105" />
                ) : (
                  <div class="h-full w-full bg-stone/5 flex items-center justify-center text-stone/40 text-xs">Ingen bilde</div>
                )}
              </div>
              <div class="mt-8 flex justify-between items-baseline border-b border-ink/5 pb-2">
                <div>
                  <h3 class="font-serif text-2xl text-ink transition-colors">{item.title}</h3>
                  <p class="text-[10px] text-stone uppercase tracking-wider mt-1">{item.maker}</p>
                </div>
                <span class="text-base font-light text-ink">{typeof item.price === 'number' ? nok.format(item.price) : item.price}</span>
              </div>
              <p class="mt-4 text-sm text-stone/90 font-light leading-relaxed">{item.excerpt}</p>
            </div>
            
            {/* ENDRET FRA EN LENKE TIL EN LIVE-KNAPP SOM SNAKKER MED API-ET DITT */}
            <button 
              data-slug={item.slug}
              class="checkout-button mt-8 block w-full bg-ink text-paper py-4 text-[10px] font-medium uppercase tracking-widest text-center hover:bg-clay transition-colors disabled:opacity-50"
            >
              Kjøp nå →
            </button>
          </article>
        ))}
      </div>
    </section>

    <section id="partner" class="bg-oat px-6 sm:px-12 py-32 border-t border-ink/5">
      <div class="max-w-md mx-auto text-center">
        <span class="text-[10px] font-medium uppercase tracking-widest text-stone block mb-4">Samarbeid</span>
        <h2 class="font-serif text-3xl text-ink">Bli en del av ScandiJapandi</h2>
        <form name="collection-partner" method="POST" data-netlify="true" class="mt-12 text-left space-y-6">
          <input type="hidden" name="form-name" value="collection-partner" />
          <div>
            <label class="block text-[9px] font-medium uppercase tracking-widest text-stone mb-2">Ditt fulle navn</label>
            <input type="text" name="name" required class="w-full p-4 bg-white border border-ink/10 outline-none text-sm font-light" />
          </div>
          <div>
            <label class="block text-[9px] font-medium uppercase tracking-widest text-stone mb-2">E-postadresse</label>
            <input type="email" name="email" required class="w-full p-4 bg-white border border-ink/10 outline-none text-sm font-light" />
          </div>
          <button type="submit" class="w-full bg-ink text-paper py-4 uppercase text-[10px] font-medium tracking-widest hover:bg-clay transition-colors mt-4">
            Send søknad
          </button>
        </form>
      </div>
    </section>

    <footer class="bg-ink text-paper/60 px-6 sm:px-12 py-12 text-center text-[10px] uppercase tracking-widest">
      <p class="text-paper/40">&copy; 2026 ScandiJapandi. Alle rettigheter reservert.</p>
    </footer>

    <script>
      document.addEventListener('DOMContentLoaded', () => {
        // Henter 'ref' fra URL-en hvis den finnes (f.eks ?ref=kuratorNavn)
        const urlParams = new URLSearchParams(window.location.search);
        const ref = urlParams.get('ref');

        const buttons = document.querySelectorAll('.checkout-button');
        
        buttons.forEach(button => {
          button.addEventListener('click', async (e) => {
            const btn = e.currentTarget;
            const slug = btn.getAttribute('data-slug');
            
            if (!slug) return;
            
            try {
              btn.disabled = true;
              btn.innerText = 'Laster kasse...';

              // Sender forespørsel til det nye JavaScript API-endepunktet ditt
              const response = await fetch('/api/checkout', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ slug, ref })
              });

              const data = await response.json();

              if (data.url) {
                // Sender brukeren rett videre til Stripe Checkout
                window.location.href = data.url;
              } else {
                throw new Error(data.error || 'Kunne ikke opprette Stripe-sesjon');
              }

            } catch (err) {
              console.error('Nettverksfeil mot Stripe API:', err);
              alert('Klarte ikke å koble til betalingen. Vennligst sjekk Sanity for gyldig Stripe Price ID.');
              btn.disabled = false;
              btn.innerText = 'Kjøp nå →';
            }
          });
        });
      });
    </script>

  </body>
</html>
