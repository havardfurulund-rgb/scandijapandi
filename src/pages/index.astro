---
// cache-bust: v=1 — forces a content change so Netlify uploads a fresh artifact
import Base from '../layouts/Base.astro';
import productsData from '../data/products.json';

// Embedded launch collection. Rendered immediately so the page is never empty,
// then replaced at runtime with the live collection from /api/products (which
// reflects whatever is published from the admin).
// Guarantee `products` is ALWAYS an array so `.map` can never throw.
const products = Array.isArray(productsData) ? productsData : [];

const nok = new Intl.NumberFormat('nb-NO', {
  style: 'currency',
  currency: 'NOK',
  maximumFractionDigits: 0,
});

// Prefer a product's own Stripe payment link when present; otherwise fall back
// to the server-side checkout flow that builds a Stripe session from the slug.
// (?ref= for influencer attribution is appended client-side, where the query
// string is available.)
const checkoutHref = (product) =>
  product.stripeLink ? product.stripeLink : `/api/checkout?slug=${product.slug}`;
---

<Base>
  <header class="fixed inset-x-0 top-0 z-50 border-b border-ink/5 bg-paper/80 backdrop-blur-md">
    <div class="mx-auto flex h-20 max-w-6xl items-center justify-between px-6 sm:px-12">
      <a href="#top" class="font-serif text-xl tracking-tight transition-opacity hover:opacity-70">ScandiJapandi</a>
      <nav class="flex items-center gap-6 sm:gap-10 text-[10px] font-medium uppercase tracking-widest text-stone">
        <a href="#collection" class="transition-colors hover:text-ink" data-i18n="nav_collection">Collection</a>
        <a href="/about" class="transition-colors hover:text-ink" data-i18n="nav_about">About</a>
        <div class="flex items-center gap-3 border-l border-ink/10 pl-6">
          <button type="button" class="lang-btn" data-lang="no" aria-current="true">NO</button>
          <button type="button" class="lang-btn" data-lang="en">EN</button>
          <button type="button" class="lang-btn" data-lang="jp">日本語</button>
        </div>
      </nav>
    </div>
  </header>

  <!-- Checkout status banner -->
  <div id="checkout-banner" class="hidden fixed top-20 inset-x-0 z-40 px-6 sm:px-12"></div>

  <!-- Hero -->
  <section id="top" class="relative flex min-h-screen items-center overflow-hidden bg-[#E2DFD9] pt-20">
    <div class="absolute inset-0 z-0 bg-cover bg-center mix-blend-multiply opacity-20" style="background-image: url('/images/hero-bg.jpg');"></div>
    <div class="relative z-10 mx-auto w-full max-w-6xl px-6 sm:px-12 py-20">
      <div class="max-w-2xl reveal">
        <h1 class="font-serif text-5xl sm:text-7xl leading-[1.1] tracking-tight text-ink" data-i18n="hero_title">
          Nordisk ro kuratert for verden
        </h1>
        <p class="mt-8 text-base sm:text-lg text-stone font-light leading-relaxed max-w-lg" data-i18n="hero_body">
          En eksklusiv samling av tidløse skandinaviske objekter. Rene linjer, kompromissløst nordisk håndverk og bærekraftige naturmaterialer.
        </p>
        <div class="mt-10 flex flex-wrap gap-4">
          <a href="#collection" class="inline-block bg-ink text-paper px-8 py-4 text-[10px] font-medium uppercase tracking-widest transition-colors hover:bg-clay" data-i18n="hero_cta">
            Utforsk kolleksjonen
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- About -->
  <section id="about" class="px-6 sm:px-12 py-32 bg-paper border-b border-ink/5">
    <div class="mx-auto max-w-3xl text-center reveal">
      <span class="text-[10px] font-medium uppercase tracking-widest text-stone block mb-4" data-i18n="about_eyebrow">Vår Filosofi</span>
      <h2 class="font-serif text-3xl sm:text-4xl text-ink leading-snug" data-i18n="about_title">
        Skandinavisk funksjonalitet møter global minimalisme.
      </h2>
    </div>
  </section>

  <!-- Collection -->
  <section id="collection" class="px-6 sm:px-12 py-32 mx-auto max-w-6xl">
    <div class="flex flex-col md:flex-row md:items-baseline justify-between mb-20 reveal">
      <div>
        <span class="text-[10px] font-medium uppercase tracking-widest text-stone block mb-2" data-i18n="collection_eyebrow">Kuratert utvalg</span>
        <h2 class="font-serif text-3xl sm:text-4xl text-ink">ScandiJapandi Collection</h2>
      </div>
      <p class="text-sm text-stone font-light max-w-xs mt-4 md:mt-0 leading-relaxed" data-i18n="collection_lead">
        Unike objekter fra uavhengige skandinaviske kunstnere og tradisjonsrike nordiske verksteder.
      </p>
    </div>

    <div id="product-grid" class="grid grid-cols-1 gap-x-12 gap-y-24 sm:grid-cols-2 lg:grid-cols-3">
      {products.map((product) => (
        <article class="reveal flex flex-col justify-between group">
          <div>
            <div class="relative aspect-[4/5] bg-oat overflow-hidden">
              <img src={product.image} alt={product.name} loading="lazy" class="h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-105" />
            </div>
            <div class="mt-8 flex justify-between items-baseline border-b border-ink/5 pb-2">
              <div>
                <a href={`/products/${product.slug}`} class="hover:text-clay transition-colors">
                  <h3 class="font-serif text-2xl text-ink transition-colors group-hover:text-clay">{product.name}</h3>
                </a>
                <p class="text-[10px] text-stone uppercase tracking-wider mt-1">{product.producer}</p>
              </div>
              <span class="text-base font-light text-ink">{nok.format(product.price)}</span>
            </div>
          </div>
          <a href={checkoutHref(product)} class="checkout-btn mt-8 block w-full bg-ink text-paper py-4 text-[10px] font-medium uppercase tracking-widest text-center transition-all duration-300 hover:bg-clay shadow-sm" data-i18n="product_buy">
            Kjøp nå →
          </a>
        </article>
      ))}
    </div>
  </section>

  <!-- Private Circle — progressive, low-friction email capture -->
  <section id="circle" class="bg-ink py-24 px-6">
    <div class="max-w-xl mx-auto text-center">

      <!-- Step 1: Email only -->
      <div id="circle-step-1">
        <p class="text-[10px] uppercase tracking-widest text-paper/40 mb-6" data-i18n="circle_eyebrow">Private Circle</p>
        <h2 class="font-serif text-3xl sm:text-4xl text-paper font-light mb-4" data-i18n="circle_heading">
          First to know. Always.
        </h2>
        <p class="text-sm text-paper/60 font-light mb-10 leading-relaxed" data-i18n="circle_sub">
          New arrivals, maker stories, and exclusive previews — before anyone else.
        </p>
        <form id="circle-email-form" class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
          <input
            type="email"
            id="circle-email"
            required
            placeholder="your@email.com"
            class="flex-1 bg-paper/10 border border-paper/20 text-paper placeholder-paper/30 px-5 py-4 text-sm outline-none focus:border-paper/60 transition-colors"
          />
          <button type="submit" class="bg-paper text-ink px-8 py-4 text-[10px] uppercase tracking-widest font-medium hover:bg-oat transition-colors whitespace-nowrap" data-i18n="circle_join">
            Join
          </button>
        </form>
        <p id="circle-email-error" class="hidden mt-3 text-xs text-clay"></p>
      </div>

      <!-- Step 2: Segment selection (shown after email submit) -->
      <div id="circle-step-2" class="hidden">
        <p class="text-[10px] uppercase tracking-widest text-paper/40 mb-8" data-i18n="circle_thanks_eyebrow">Welcome</p>
        <h2 class="font-serif text-3xl text-paper font-light mb-10" data-i18n="circle_thanks_heading">
          One quick thing —
        </h2>
        <p class="text-sm text-paper/60 mb-10" data-i18n="circle_thanks_sub">What best describes you?</p>
        <div class="grid grid-cols-1 gap-3 max-w-xs mx-auto">
          <button onclick="submitSegment('customer')" class="segment-btn border border-paper/20 text-paper px-6 py-5 text-sm font-light hover:border-paper hover:bg-paper/5 transition-all" data-i18n="segment_customer">
            I collect beautiful objects
          </button>
          <button onclick="submitSegment('maker')" class="segment-btn border border-paper/20 text-paper px-6 py-5 text-sm font-light hover:border-paper hover:bg-paper/5 transition-all" data-i18n="segment_maker">
            I design or make things
          </button>
          <button onclick="submitSegment('curator')" class="segment-btn border border-paper/20 text-paper px-6 py-5 text-sm font-light hover:border-paper hover:bg-paper/5 transition-all" data-i18n="segment_curator">
            I share what inspires me
          </button>
        </div>
      </div>

      <!-- Step 3: Confirmation -->
      <div id="circle-step-3" class="hidden">
        <div class="w-12 h-12 border border-paper/30 rounded-full flex items-center justify-center mx-auto mb-8">
          <svg width="20" height="14" viewBox="0 0 20 14" fill="none"><path d="M1 7L7 13L19 1" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" class="text-paper"/></svg>
        </div>
        <p class="font-serif text-2xl text-paper font-light mb-3" data-i18n="circle_done_heading">You're in.</p>
        <p class="text-sm text-paper/50" data-i18n="circle_done_sub">We'll be in touch when something worthy of your attention arrives.</p>
      </div>

    </div>
  </section>

  <!-- Ordrer — kun synlig når en admin-økt er aktiv. Selve dataene hentes fra
       /api/admin/orders, som krever gyldig admin-autorisering på SERVEREN (samme
       gating som resten av /api/admin/*). Å skjule seksjonen i klienten er kun
       kosmetisk; den ekte beskyttelsen ligger i funksjonen. Storefronten for
       vanlige besøkende er uendret. -->
  <section id="admin-orders" class="hidden bg-oat px-6 sm:px-12 py-20 border-t border-ink/10">
    <div class="mx-auto max-w-6xl">
      <div class="flex items-baseline justify-between mb-8">
        <div>
          <span class="text-[10px] font-medium uppercase tracking-widest text-stone block mb-2">Admin</span>
          <h2 class="font-serif text-2xl sm:text-3xl text-ink">Ordrer</h2>
        </div>
        <button id="admin-orders-refresh" type="button" class="text-[10px] font-medium uppercase tracking-widest text-stone transition-colors hover:text-ink">
          Oppdater
        </button>
      </div>
      <p id="admin-orders-status" class="text-sm text-stone font-light">Laster ordrer …</p>
      <div class="overflow-x-auto">
        <table id="admin-orders-table" class="hidden mt-2 w-full text-left text-sm">
          <thead class="text-[10px] uppercase tracking-widest text-stone">
            <tr class="border-b border-ink/10">
              <th class="py-3 pr-4 font-medium">Dato</th>
              <th class="py-3 pr-4 font-medium">Produkt</th>
              <th class="py-3 pr-4 font-medium">Kunde</th>
              <th class="py-3 pr-4 font-medium">Beløp</th>
              <th class="py-3 pr-4 font-medium">Henvist</th>
              <th class="py-3 font-medium">Status</th>
            </tr>
          </thead>
          <tbody id="admin-orders-body" class="align-top text-ink/90"></tbody>
        </table>
      </div>
    </div>
  </section>

  <footer class="bg-ink text-paper/70 py-12 text-center text-sm">
    <!-- Diskret makers-inngang. Selve søknaden bor nå på den dedikerte
         /makers-siden, slik at forsiden holdes minimal og uten partner-mas. -->
    <a href="/makers" class="mb-8 inline-block text-[10px] uppercase tracking-widest text-stone/40 hover:text-stone transition-colors">For makers</a>
    <p data-i18n="footer_rights">© 2026 ScandiJapandi. Alle rettigheter reservert.</p>
    <!-- Diskret admin-inngang: skjult for vanlige besøkende. Vises kun som en
         liten, nedtonet lenke nederst i footeren når en admin-økt er aktiv
         (midlertidig hardkodet login eller Netlify Identity). -->
    <p id="admin-link" class="hidden mt-2 text-[10px] uppercase tracking-widest text-paper/25">
      <a href="/admin" class="transition-colors hover:text-paper/80" data-i18n="footer_admin">Admin</a>
    </p>
  </footer>

