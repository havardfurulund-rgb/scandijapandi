---
import '../styles/global.css';
import { sanityClient } from 'sanity:client';
import imageUrlBuilder from '@sanity/image-url';

// Henter produktene, inkludert en direkte Stripe-link fra Sanity hvis den finnes
const QUERY = `*[_type == "product" && defined(title)] | order(_createdAt asc){
  _id,
  title,
  price,
  "excerpt": pt::text(body),
  "stripeLink": stripeLink, 
  mainImage{ ..., asset->{ url, metadata{ lqip } } }
}`;

let docs = [];
try {
  docs = (await sanityClient.fetch(QUERY)) ?? [];
} catch {
  docs = [];
}

const builder = imageUrlBuilder(sanityClient);
const buildImage = (img) => {
  const base = builder.image(img).auto('format').fit('crop').quality(78);
  return {
    src: base.width(800).height(1000).url(),
    srcset: [400, 800, 1200]
      .map((w) => `${base.width(w).height(Math.round(w * 1.25)).url()} ${w}w`)
      .join(', '),
    lqip: img?.asset?.metadata?.lqip ?? null,
  };
};

const sanityItems = docs.map((d) => ({
  title: d.title,
  maker: '',
  price: d.price,
  stripeLink: d.stripeLink ?? '#partner', // Fallback til partnerskjema hvis link mangler
  excerpt: d.excerpt ? d.excerpt.slice(0, 150) : '',
  alt: d.mainImage?.alt ?? d.title,
  ...(d.mainImage?.asset ? buildImage(d.mainImage) : { src: null, srcset: null, lqip: null }),
}));

const fallback = [
  { title: 'Curved Birch Tray', maker: 'Studio Bjørk · Bergen', price: 895, stripeLink: '#partner', alt: 'Curved birch serving tray', src: '/images/products/wood-tray.jpg', excerpt: 'A single sweep of steam-bent Nordic birch, oiled by hand and left to show its grain.' },
  { title: 'Matte Stoneware Vase', maker: 'Sōen Keramikk · Kyoto', price: 1450, stripeLink: '#partner', alt: 'Matte stoneware vase', src: '/images/products/ceramic-vase.jpg', excerpt: 'Thrown in a chalk-grey clay and fired low, so the surface stays soft to the touch.' },
];

const products = sanityItems.length > 0 ? sanityItems : fallback;

const nok = new Intl.NumberFormat('nb-NO', {
  style: 'currency',
  currency: 'NOK',
  maximumFractionDigits: 0,
});
---

<!doctype html>
<html lang="no" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ScandiJapandi — Nordisk ro, japansk håndverk</title>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,400;9..144,500&family=Jost:wght@300;400;500&display=swap" />
    <script is:inline>
      document.documentElement.classList.add('js');
      addEventListener('DOMContentLoaded', () => {
        const els = document.querySelectorAll('.reveal');
        if (!('IntersectionObserver' in window)) {
          els.forEach((e) => e.classList.add('is-visible'));
          return;
        }
        const io = new IntersectionObserver((entries) => {
          for (const e of entries) {
            if (e.isIntersecting) { e.target.classList.add('is-visible'); io.unobserve(e.target); }
          }
        }, { rootMargin: '0px 0px -10% 0px', threshold: 0.12 });
        els.forEach((e) => io.observe(e));
      });
    </script>
  </head>

  <body class="overflow-x-hidden bg-paper text-ink">
    <header class="fixed inset-x-0 top-0 z-50 border-b border-ink/5 bg-paper/80 backdrop-blur-md">
      <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-6">
        <a href="#top" class="font-serif text-lg tracking-tight">ScandiJapandi</a>
        <nav class="flex items-center gap-8 text-[11px] font-medium uppercase tracking-widest text-stone">
          <a href="#collection">Kolleksjon</a>
          <a href="#partner">Bli Partner</a>
        </nav>
      </div>
    </header>

    <section id="top" class="relative flex min-h-screen items-end overflow-hidden bg-stone py-20">
      <div class="relative z-10 mx-auto w-full max-w-6xl px-6 text-paper">
        <h1 class="font-serif text-5xl sm:text-7xl max-w-3xl">Der nordisk ro møter japansk håndverk</h1>
      </div>
    </section>

    <section id="collection" class="px-6 py-28 mx-auto max-w-6xl">
      <div class="grid grid-cols-1 gap-x-8 gap-y-16 sm:grid-cols-2 lg:grid-cols-3">
        {products.map((item, i) => (
          <article class="reveal flex flex-col justify-between">
            <div>
              <div class="relative aspect-[4/5] bg-oat overflow-hidden">
                {item.src && <img src={item.src} srcset={item.srcset} alt={item.alt} class="h-full w-full object-cover" />}
              </div>
              <div class="mt-6 flex justify-between items-baseline">
                <h3 class="font-serif text-2xl">{item.title}</h3>
                <span class="text-sm font-light text-stone">{typeof item.price === 'number' ? nok.format(item.price) : item.price}</span>
              </div>
              <p class="mt-3 text-sm text-stone/90 font-light">{item.excerpt}</p>
            </div>
            
            {/* IDIOTSIKKER DIREKTESTRAPPING */}
            <a 
              href={item.stripeLink}
              class="mt-6 block w-full bg-ink text-paper py-3 text-[10px] font-medium uppercase tracking-widest text-center transition-colors hover:bg-clay"
            >
              Kjøp nå →
            </a>
          </article>
        ))}
      </div>
    </section>

    <section id="partner" class="bg-oat px-6 py-28 text-center">
      <h2 class="font-serif text-3xl">Bli Partner</h2>
      <form name="collection-partner" method="POST" data-netlify="true" class="mt-8 max-w-md mx-auto space-y-4">
        <input type="hidden" name="form-name" value="collection-partner" />
        <input type="text" name="name" placeholder="Navn" required class="w-full p-3 bg-transparent border-b border-ink/20 outline-none" />
        <input type="email" name="email" placeholder="E-post" required class="w-full p-3 bg-transparent border-b border-ink/20 outline-none" />
        <button type="submit" class="w-full bg-ink text-paper py-3 uppercase text-[10px] tracking-widest">Send søknad</button>
      </form>
    </section>
  </body>
</html>
