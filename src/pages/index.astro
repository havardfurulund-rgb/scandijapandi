---
import { sanityClient } from 'sanity:client';

// 1. DATA FETCHING (Sanity DB)
// Henter alle aktive produkter med nødvendige felter for både norsk og japansk innhold
const products = await sanityClient.fetch(`*[_type == "product"]{
  title,
  "slug": slug.current,
  price,
  mainImage,
  description_no,
  description_ja,
  curator->{
    title,
    "id": _id
  }
}`);
---

<html lang="no">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Scandi Japandi Collection</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">

    <style>
      /* 2. GLOBAL JAPANDI AESTHETIC (Minimalisme, luft og jordtoner) */
      :root {
        --color-bg: #fcfbfa;       /* Off-white / papirfarge */
        --color-text: #1a1a1a;     /* Dempet sort */
        --color-muted: #706e6b;    /* Jordete gråtone for sekundærtekst */
        --color-border: #e6e4e0;   /* Myk, tynn delelinje */
        --color-accent: #2b2927;   /* Dyp mørkegrå for knapper */
        --font-sans: 'Inter', sans-serif;
      }

      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      body {
        background-color: var(--color-bg);
        color: var(--color-text);
        font-family: var(--font-sans);
        -webkit-font-smoothing: antialiased;
        padding-bottom: 6rem;
      }

      .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 2rem;
      }

      /* Navigation Header */
      header {
        border-bottom: 1px solid var(--color-border);
        padding: 2rem 0;
        margin-bottom: 6rem;
      }

      .header-inner {
        display: flex;
        justify-content: space-between;
        align-items: center;
      }

      .logo {
        font-size: 1.25rem;
        font-weight: 400;
        letter-spacing: 0.1em;
        text-transform: uppercase;
      }

      /* Språkvelger (Premium & diskret) */
      .lang-toggle {
        background: none;
        border: none;
        font-family: var(--font-sans);
        font-size: 0.875rem;
        color: var(--color-muted);
        cursor: pointer;
        letter-spacing: 0.05em;
        font-weight: 500;
        transition: color 0.2s ease;
      }

      .lang-toggle:hover {
        color: var(--color-text);
      }

      /* Intro seksjon */
      .intro-section {
        margin-bottom: 8rem;
        max-width: 600px;
      }

      .intro-text {
        font-size: 1.5rem;
        font-weight: 300;
        line-height: 1.6;
        color: var(--color-text);
        letter-spacing: -0.01em;
      }

      /* Produkt-grid (Lekker, luftig plassering) */
      .product-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
        gap: 6rem 4rem;
        margin-bottom: 10rem;
      }

      .product-card {
        display: flex;
        flex-direction: column;
      }

      .image-wrapper {
        background-color: #f5f3f0;
        aspect-ratio: 4 / 5;
        margin-bottom: 1.5rem;
        overflow: hidden;
        position: relative;
      }

      .product-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.4s ease;
      }

      .product-card:hover .product-image {
        transform: scale(1.02);
      }

      .product-meta {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        margin-bottom: 0.5rem;
      }

      .product-title {
        font-size: 1.125rem;
        font-weight: 500;
        letter-spacing: -0.01em;
      }

      .product-price {
        font-size: 1rem;
        font-weight: 400;
        color: var(--color-muted);
      }

      .product-desc {
        font-size: 0.95rem;
        line-height: 1.5;
        color: var(--color-muted);
        margin-bottom: 1.5rem;
        font-weight: 300;
      }

      /* Kjøp nå-knapp */
      .buy-button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background-color: var(--color-accent);
        color: #ffffff;
        border: none;
        padding: 1rem;
        font-family: var(--font-sans);
        font-size: 0.9rem;
        font-weight: 400;
        letter-spacing: 0.05em;
        cursor: pointer;
        text-transform: uppercase;
        transition: background-color 0.2s ease;
      }

      .buy-button:hover {
        background-color: #000000;
      }

      /* 3. PARTNER SØKNADSSKJEMA (Netlify Forms integrert) */
      .partner-section {
        border-top: 1px solid var(--color-border);
        padding: 8rem 0;
        max-width: 550px;
        margin: 0 auto;
      }

      .partner-section h2 {
        font-size: 1.5rem;
        font-weight: 400;
        margin-bottom: 1rem;
        letter-spacing: -0.01em;
        text-align: center;
      }

      .partner-section p {
        font-size: 0.95rem;
        color: var(--color-muted);
        text-align: center;
        margin-bottom: 3rem;
        font-weight: 300;
        line-height: 1.5;
      }

      .form-group {
        margin-bottom: 1.5rem;
      }

      .form-group label {
        display: block;
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 0.5rem;
        color: var(--color-muted);
      }

      .form-control {
        width: 100%;
        background-color: #f5f3f0;
        border: 1px solid transparent;
        padding: 1rem;
        font-family: var(--font-sans);
        font-size: 0.95rem;
        color: var(--color-text);
        transition: border-color 0.2s ease;
      }

      .form-control:focus {
        outline: none;
        border-color: var(--color-muted);
      }

      textarea.form-control {
        resize: vertical;
        min-height: 120px;
      }

      .submit-button {
        width: 100%;
        background-color: transparent;
        color: var(--color-text);
        border: 1px solid var(--color-text);
        padding: 1rem;
        font-family: var(--font-sans);
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        cursor: pointer;
        transition: all 0.2s ease;
        margin-top: 1rem;
      }

      .submit-button:hover {
        background-color: var(--color-text);
        color: #ffffff;
      }

      /* 4. DISKRET FOOTER (Med gjemt Studio-lenke) */
      footer {
        border-top: 1px solid var(--color-border);
        padding: 4rem 0 2rem 0;
        margin-top: 4rem;
      }

      .footer-inner {
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 0.8rem;
        color: var(--color-muted);
      }

      .studio-link {
        color: var(--color-muted);
        text-decoration: none;
        letter-spacing: 0.05em;
        transition: color 0.2s ease;
      }

      .studio-link:hover {
        color: var(--color-text);
      }

      /* Skjuler elementer basert på aktivt språk */
      [data-lang]:hidden {
        display: none !important;
      }
    </style>
  </head>
  
  <body>
    <header>
      <div class="container header-inner">
        <div class="logo">Scandi Japandi</div>
        <button id="langToggle" class="lang-toggle">EN / NO</button>
      </div>
    </header>

    <main class="container">
      <section class="intro-section">
        <div data-lang="no" class="intro-text">
          Få stykker, valgt med omhu. Hvert objekt er laget i små serier av håndverkere i Norden og Japan.
        </div>
        <div data-lang="en" class="intro-text" hidden>
          Few pieces, carefully selected. Each object is crafted in small batches by artisans in the Nordic region and Japan.
        </div>
      </section>

      <section class="product-grid">
        {products && products.map((product) => (
          <div class="product-card">
            <div class="image-wrapper">
              {product.mainImage && (
                <img class="product-image" src={product.mainImage} alt={product.title} loading="lazy" />
              )}
            </div>
            
            <div class="product-meta">
              <h3 class="product-title">{product.title}</h3>
              <span class="product-price">{product.price.toLocaleString('no-NO')} kr</span>
            </div>

            {/* Lokalisert beskrivelse */}
            <p data-lang="no" class="product-desc">{product.description_no || product.description_en}</p>
            <p data-lang="en" class="product-desc" hidden>{product.description_ja || product.description_no}</p>

            {/* Kjøp-knapp med Stripe-logikk */}
            <button 
              class="buy-button" 
              data-slug={product.slug}
              data-curator={product.curator?.id || ""}
            >
              <span data-lang="no">Kjøp nå →</span>
              <span data-lang="en" hidden>Buy now →</span>
            </button>
          </div>
        ))}
      </section>

      <section class="partner-section">
        <h2 data-lang="no">Bli Collection Partner</h2>
        <h2 data-lang="en" hidden>Become a Collection Partner</h2>
        
        <p data-lang="no">Ønsker du dine objekter vurdert for vår seleksjon? Send oss en henvendelse under.</p>
        <p data-lang="en" hidden>Would you like your objects considered for our selection? Apply below.</p>

        <form name="collection-partner" method="POST" data-netlify="true">
          <input type="hidden" name="form-name" value="collection-partner" />
          
          <div class="form-group">
            <label for="name" data-lang="no">Navn</label>
            <label for="name" data-lang="en" hidden>Name</label>
            <input type="text" id="name" name="name" class="form-control" required />
          </div>

          <div class="form-group">
            <label for="email" data-lang="no">E-post</label>
            <label for="email" data-lang="en" hidden>Email</label>
            <input type="email" id="email" name="email" class="form-control" required />
          </div>

          <div class="form-group">
            <label for="brand" data-lang="no">Firmanavn / Merkevare</label>
            <label for="brand" data-lang="en" hidden>Brand / Company</label>
            <input type="text" id="brand" name="brand" class="form-control" required />
          </div>

          <div class="form-group">
            <label for="message" data-lang="no">Melding / Søknad</label>
            <label for="message" data-lang="en" hidden>Message / Application</label>
            <textarea id="message" name="message" class="form-control" required></textarea>
          </div>

          <button type="submit" class="submit-button">
            <span data-lang="no">Send søknad</span>
            <span data-lang="en" hidden>Submit Application</span>
          </button>
        </form>
      </section>
    </main>

    <footer>
      <div class="container footer-inner">
        <div>© 2026 Scandi Japandi Group.</div>
        <div>
          <a href="/studio" class="studio-link">Studio Portal</a>
        </div>
      </div>
    </footer>

    {/* CLIENT SCRIPT: Låser språksvitsj, sporer kurator (?ref=) og håndterer Stripe-kall */}
    <script>
      // 1. SPRÅKVELGER LOGIKK
      let currentLang = 'no';
      const langToggle = document.getElementById('langToggle');
      const langElements = document.querySelectorAll('[data-lang]');

      function setLanguage(lang) {
        currentLang = lang;
        langElements.forEach(el => {
          if (el.getAttribute('data-lang') === lang) {
            el.removeAttribute('hidden');
          } else {
            el.setAttribute('hidden', 'true');
          }
        });
      }

      langToggle?.addEventListener('click', () => {
        setLanguage(currentLang === 'no' ? 'en' : 'no');
      });

      // 2. SPORING AV KURATOR (localStorage-sjekk for ?ref= URL)
      const urlParams = new URLSearchParams(window.location.search);
      const refParam = urlParams.get('ref');
      if (refParam) {
        localStorage.setItem('curator_ref', refParam);
      }

      // 3. STRIPE CHECKOUT INTEGRASJON VIA /api/checkout
      const buyButtons = document.querySelectorAll('.buy-button');
      buyButtons.forEach(button => {
        button.addEventListener('click', async (e) => {
          const btn = e.currentTarget as HTMLButtonElement;
          const slug = btn.getAttribute('data-slug');
          const inlineCurator = btn.getAttribute('data-curator');
          const storedCurator = localStorage.getItem('curator_ref');
          
          // Prioriterer aktiv ref-link over statisk kobling
          const activeCurator = storedCurator || inlineCurator;

          try {
            const response = await fetch('/api/checkout', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ slug, ref: activeCurator })
            });

            const session = await response.json();
            if (session.url) {
              window.location.href = session.url; // Sender brukeren direkte til Stripe
            } else {
              console.error('Stripe Checkout Session feilet.');
            }
          } catch (error) {
            console.error('Nettverksfeil mot Stripe API-endepunkt:', error);
          }
        });
      });
    </script>
  </body>
</html>
