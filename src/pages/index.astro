---
// src/pages/index.astro
import { sanityClient } from 'sanity:client';

const products = await sanityClient.fetch(`*[_type == "product"]{
  title,
  slug,
  price,
  mainImage{asset->{url}},
  description,
  curator->{name, instagramHandle}
}`);
---

<html lang="no">
<head>
  <meta charset="utf-8" />
  <title>Scandi Japandi</title>
  <style>
    body { font-family: 'Helvetica Neue', Arial, sans-serif; background-color: #fcfbf9; color: #2c2a29; margin: 0; padding: 40px; }
    .header { display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #e6e3df; padding-bottom: 20px; margin-bottom: 40px; }
    .logo { font-size: 24px; font-weight: 300; letter-spacing: 2px; text-transform: uppercase; }
    .lang-switcher { display: flex; gap: 15px; }
    .lang-btn { background: none; border: none; font-size: 14px; cursor: pointer; color: #8c8882; padding: 5px; transition: color 0.2s; }
    .lang-btn.active { color: #2c2a29; font-weight: bold; border-bottom: 1px solid #2c2a29; }
    .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 40px; }
    .product-card { background: #ffffff; padding: 20px; border: 1px solid #f0ede9; border-radius: 4px; }
    .product-image { width: 100%; height: 350px; object-fit: cover; background-color: #f7f5f2; margin-bottom: 15px; }
    .product-title { font-size: 18px; font-weight: 400; margin: 10px 0; }
    .product-price { font-size: 16px; color: #615e5a; margin-bottom: 10px; }
    .product-curator { font-size: 12px; text-transform: uppercase; letter-spacing: 1px; color: #9c968f; margin-bottom: 15px; }
    .buy-btn { width: 100%; background-color: #2c2a29; color: #ffffff; border: none; padding: 12px; font-size: 14px; cursor: pointer; transition: background 0.2s; }
    .buy-btn:hover { background-color: #4a4744; }
  </style>
</head>
<body>

  <header class="header">
    <div class="logo">Scandi Japandi</div>
    <div class="lang-switcher">
      <button class="lang-btn active" onclick="setLanguage('no')">NO</button>
      <button class="lang-btn" onclick="setLanguage('en')">EN</button>
    </div>
  </header>

  <main class="grid">
    {products && products.map((product) => (
      <div class="product-card">
        {product.mainImage?.asset?.url && (
          <img class="product-image" src={product.mainImage.asset.url} alt="Produktbilde" />
        )}
        
        <h2 class="product-title" data-no={product.title?.no} data-en={product.title?.en}>
          {product.title?.no || 'Uten navn'}
        </h2>
        
        <div class="product-price">{product.price} NOK</div>
        
        {product.curator && (
          <div class="product-curator">Curated by: {product.curator.name}</div>
        )}
        
        <p class="product-desc" data-no={product.description?.no} data-en={product.description?.en}>
          {product.description?.no}
        </p>

        <button class="buy-btn" onclick={`checkout('${product.slug?.current}')`}>
          <span class="btn-text" data-no="KJØP NÅ" data-en="BUY NOW">KJØP NÅ</span>
        </button>
      </div>
    ))}
  </main>

  <script is:inline>
    const urlParams = new URLSearchParams(window.location.search);
    const ref = urlParams.get('ref');
    if (ref) {
      localStorage.setItem('curator_ref', ref);
    }

    function setLanguage(lang) {
      document.querySelectorAll('.lang-btn').forEach(btn => btn.classList.remove('active'));
      event.target.classList.add('active');

      document.querySelectorAll('[data-no]').forEach(el => {
        const txt = el.getAttribute('data-' + lang);
        if (txt) {
          el.innerText = txt;
        }
      });
    }

    function checkout(slug) {
      const curator = localStorage.getItem('curator_ref') || '';
      window.location.href = `/api/checkout?slug=${slug}&ref=${curator}`;
    }
  </script>
</body>
</html>
