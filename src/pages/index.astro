---
const title = "Scandi Japandi Collection";
---

<!DOCTYPE html>
<html lang="no">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Scandi Japandi Collection</title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;500&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    body { font-family: 'Inter', system-ui, sans-serif; }
    .serif { font-family: 'Cormorant Garamond', serif; }
    .hero {
      background-image: linear-gradient(rgba(18,18,18,0.38), rgba(18,18,18,0.38)), 
                        url('https://picsum.photos/id/1015/2000/1200');
      background-size: cover;
      background-position: center;
    }
  </style>
</head>
<body class="bg-[#FAF9F6] text-[#1F1F1F]">

  <!-- Nav -->
  <nav class="fixed top-0 w-full bg-white/95 backdrop-blur z-50 border-b">
    <div class="max-w-7xl mx-auto px-8 py-6 flex justify-between items-center">
      <div class="text-2xl tracking-wider serif">SCANDI JAPANDI</div>
      <div class="flex gap-8 text-sm uppercase tracking-widest">
        <a href="#collection" class="hover:text-[#C5A05B]">Kolleksjon</a>
        <a href="#" class="hover:text-[#C5A05B]">Japandi</a>
        <a href="#" class="hover:text-[#C5A05B]">Produsenter</a>
      </div>
      <div class="flex gap-5">
        <a href="/" class="font-medium">NO</a>
        <a href="/en" class="hover:text-[#C5A05B]">EN</a>
        <a href="/ja" class="hover:text-[#C5A05B]">JA</a>
      </div>
    </div>
  </nav>

  <!-- Hero -->
  <section class="hero h-screen flex items-center justify-center text-white">
    <div class="max-w-4xl mx-auto text-center px-6">
      <p class="uppercase tracking-[0.4em] text-sm mb-6">Quiet Luxury • Timeless Craft</p>
      <h1 class="serif text-6xl md:text-7xl font-light leading-tight mb-8">
        Skandinavisk sjel.<br>
        Japansk ro.
      </h1>
      <p class="text-xl max-w-md mx-auto mb-12">Håndplukkede objekter fra de beste småskala produsentene i Norden.</p>
      <a href="#collection" class="inline-block border border-white px-12 py-5 text-sm uppercase tracking-widest hover:bg-white hover:text-[#1F1F1F] transition">Utforsk kolleksjonen</a>
    </div>
  </section>

  <!-- Collection -->
  <section id="collection" class="max-w-7xl mx-auto px-8 py-24">
    <h2 class="serif text-5xl font-light text-center mb-16">Kuratert kolleksjon</h2>
    <div class="grid md:grid-cols-3 gap-10">
      <!-- Legg til produkter her senere -->
      <div class="text-center">
        <div class="aspect-square bg-gray-100 mb-6"></div>
        <h3 class="serif text-xl">Produktnavn</h3>
        <p class="text-sm text-gray-600">Produsent</p>
      </div>
    </div>
  </section>

</body>
</html>
