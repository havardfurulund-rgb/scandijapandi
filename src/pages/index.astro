    const LANGS = ['no', 'en', 'jp'];
    const HTML_LANG = { no: 'no', en: 'en', jp: 'ja' };

    function applyLang(lang) {
      if (!LANGS.includes(lang)) lang = 'no';
      const dict = I18N[lang];

      document.querySelectorAll('[data-i18n]').forEach((el) => {
        const key = el.getAttribute('data-i18n');
        if (dict[key] != null) el.textContent = dict[key];
      });

      document.documentElement.setAttribute('lang', HTML_LANG[lang]);
      document.querySelectorAll('.lang-btn').forEach((b) => {
        b.setAttribute('aria-current', b.getAttribute('data-lang') === lang ? 'true' : 'false');
      });

      window.__sjLang = lang;
      try { localStorage.setItem('sj-lang', lang); } catch (e) {}
    }

    // Eksponert slik at det dynamisk rendrede produktgridet kan re-oversettes.
    window.__sjApplyLang = applyLang;
    // Eksponert slik at dynamiske meldinger (f.eks. designer-søknadsskjemaet)
    // kan slå opp riktig språk uten å duplisere ordlistene.
    window.__SJ_I18N = I18N;
    try { window.__sjLang = localStorage.getItem('sj-lang') || 'no'; } catch (e) { window.__sjLang = 'no'; }

    document.addEventListener('DOMContentLoaded', () => {
      applyLang(window.__sjLang || 'no');
      document.querySelectorAll('.lang-btn').forEach((btn) => {
        btn.addEventListener('click', () => applyLang(btn.getAttribute('data-lang')));
      });
    });
  </script>

  <script>
    const nokFmt = new Intl.NumberFormat('nb-NO', { style: 'currency', currency: 'NOK', maximumFractionDigits: 0 });
    const ref = new URLSearchParams(window.location.search).get('ref');

    function checkoutHref(product) {
      let href = product.stripeLink || `/api/checkout?slug=${encodeURIComponent(product.slug)}`;
      if (ref) href += `${href.includes('?') ? '&' : '?'}ref=${encodeURIComponent(ref)}`;
      if (href.includes('/api/checkout')) {
        // Read locale at call time so it reflects the language the user has
        // actively selected, not the language at page load.
        // window.__sjLang uses internal codes (no/en/jp); map jp → ja for BCP 47.
        const lang = window.__sjLang || 'en';
        const locale = lang === 'jp' ? 'ja' : lang;
        href += `&locale=${encodeURIComponent(locale)}`;
      }
      return href;
    }

    function renderProducts(products) {
      const grid = document.getElementById('product-grid');
      if (!grid || !Array.isArray(products) || !products.length) return;
      grid.innerHTML = products.map((p) => `
        <article class="reveal is-visible flex flex-col justify-between group">
          <div>
            <div class="relative aspect-[4/5] bg-oat overflow-hidden">
              <img src="${p.image || ''}" alt="${(p.name || '').replace(/"/g, '&quot;')}" loading="lazy" class="h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-105" />
            </div>
            <div class="mt-8 flex justify-between items-baseline border-b border-ink/5 pb-2">
              <div>
                <a href="/products/${p.slug}" class="hover:text-clay transition-colors"><h3 class="font-serif text-2xl text-ink transition-colors group-hover:text-clay">${p.name || ''}</h3></a>
                <p class="text-[10px] text-stone uppercase tracking-wider mt-1">${p.producer || ''}</p>
              </div>
              <span class="text-base font-light text-ink">${nokFmt.format(p.price || 0)}</span>
            </div>
          </div>
          <a href="${checkoutHref(p)}" class="checkout-btn mt-8 block w-full bg-ink text-paper py-4 text-[10px] font-medium uppercase tracking-widest text-center transition-all duration-300 hover:bg-clay shadow-sm" data-i18n="product_buy">
            Kjøp nå →
          </a>
        </article>`).join('');

      // Oversett de nyrendrede «Kjøp nå»-knappene til gjeldende språk.
      if (window.__sjApplyLang) window.__sjApplyLang(window.__sjLang || 'no');
    }

    // Carry an influencer ?ref= through the statically rendered fallback links too.
    if (ref) {
      document.querySelectorAll('.checkout-btn').forEach((btn) => {
        const url = new URL(btn.href, window.location.origin);
        if (!url.searchParams.get('ref')) url.searchParams.set('ref', ref);
        btn.href = url.toString();
      });
    }

    // Replace the fallback grid with the live collection from the database.
    fetch('/api/products')
      .then((r) => (r.ok ? r.json() : null))
      .then((data) => { if (Array.isArray(data?.products) && data.products.length) renderProducts(data.products); })
      .catch(() => { /* keep the embedded fallback */ });

    // Checkout status banner driven by the ?checkout= query the function sets.
    const status = new URLSearchParams(window.location.search).get('checkout');
    if (status) {
      const banner = document.getElementById('checkout-banner');
      const messages = {
        success: ['Takk for din bestilling! Vi sender en bekreftelse på e-post.', 'bg-ink text-paper'],
        cancel: ['Betalingen ble avbrutt. Varene venter fortsatt på deg.', 'bg-oat text-ink border border-ink/10'],
        error: ['Noe gikk galt med betalingen. Prøv igjen, eller kontakt oss.', 'bg-clay text-paper'],
      };
      const [msg, cls] = messages[status] || messages.error;
      banner.className = `fixed top-20 inset-x-0 z-40 px-6 sm:px-12`;
      banner.innerHTML = `<div class="mx-auto max-w-6xl"><div class="mt-4 ${cls} px-6 py-4 text-sm shadow-lg flex justify-between items-center"><span>${msg}</span><button type="button" aria-label="Lukk" class="ml-4 opacity-60 hover:opacity-100" onclick="this.closest('#checkout-banner').classList.add('hidden')">✕</button></div></div>`;
      banner.classList.remove('hidden');
    }

    // Reveal-animasjoner.
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) { entry.target.classList.add('is-visible'); observer.unobserve(entry.target); }
      });
    }, { threshold: 0.1 });
    document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
  </script>

  <script>
    // Reveal the discreet Admin link in the footer whenever an admin session is
    // active — either the temporary hardcoded login (a server-set httpOnly
    // cookie, checked via /api/admin/session) or a real Netlify Identity user.
    // The link stays hidden for anonymous visitors; the storefront is untouched.
    //
    // The same admin signal also reveals the minimal "Ordrer" section and loads
    // it once from /api/admin/orders (which enforces admin auth server-side —
    // the client-side hiding is cosmetic only).
    import { getUser, onAuthChange } from '@netlify/identity';

    const adminLink = document.getElementById('admin-link');
    const ordersSection = document.getElementById('admin-orders');
    let identityUser = null;
    let tempAdmin = false;
    let ordersLoaded = false;

    function isAdmin() {
      return !!(identityUser || tempAdmin);
    }

    function esc(s) {
      return String(s == null ? '' : s).replace(/[&<>"']/g, (c) =>
        ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));
    }

    async function loadOrders() {
      const status = document.getElementById('admin-orders-status');
      const table = document.getElementById('admin-orders-table');
      const body = document.getElementById('admin-orders-body');
      if (!body) return;
      if (status) { status.textContent = 'Laster ordrer …'; status.classList.remove('hidden'); }
      if (table) table.classList.add('hidden');
      try {
        const res = await fetch('/api/admin/orders', { headers: { Accept: 'application/json' } });
        if (!res.ok) throw new Error('HTTP ' + res.status);
        const data = await res.json();
        const orders = Array.isArray(data.orders) ? data.orders : [];
        if (!orders.length) {
          if (status) { status.textContent = 'Ingen ordrer ennå.'; status.classList.remove('hidden'); }
          return;
        }
        body.innerHTML = orders.map((o) => {
          let when = '—';
          try { if (o.created_at) when = new Date(o.created_at).toLocaleDateString('nb-NO'); } catch (e) {}
          let amount;
          try {
            amount = new Intl.NumberFormat('nb-NO', { style: 'currency', currency: o.currency || 'NOK', maximumFractionDigits: 0 }).format(Number(o.amount) || 0);
          } catch (e) {
            amount = (o.amount != null ? o.amount : '') + ' ' + (o.currency || '');
          }
          return `<tr class="border-b border-ink/5">
            <td class="py-3 pr-4 whitespace-nowrap">${esc(when)}</td>
            <td class="py-3 pr-4">${esc(o.product || '—')}</td>
            <td class="py-3 pr-4">${esc(o.customer_name || '—')}<br /><span class="text-xs text-stone">${esc(o.customer_email || '')}</span></td>
            <td class="py-3 pr-4 whitespace-nowrap">${esc(amount)}</td>
            <td class="py-3 pr-4">${esc(o.curator || '—')}</td>
            <td class="py-3"><span class="text-[10px] uppercase tracking-widest text-stone">${esc(o.status || '—')}</span></td>
          </tr>`;
        }).join('');
        if (status) status.classList.add('hidden');
        if (table) table.classList.remove('hidden');
      } catch (err) {
        if (status) { status.textContent = 'Kunne ikke laste ordrer.'; status.classList.remove('hidden'); }
      }
    }

    function syncAdminUI() {
      const admin = isAdmin();
      if (adminLink) adminLink.classList.toggle('hidden', !admin);
      if (ordersSection) ordersSection.classList.toggle('hidden', !admin);
      if (admin && !ordersLoaded) { ordersLoaded = true; loadOrders(); }
    }

    document.getElementById('admin-orders-refresh')?.addEventListener('click', loadOrders);

    // Midlertidig hurtig-admin: spør serveren om øktcookien er gyldig.
    async function checkTempAdmin() {
      try {
        const res = await fetch('/api/admin/session');
        if (!res.ok) return false;
        const data = await res.json();
        return !!data.authenticated;
      } catch (e) {
        return false;
      }
    }

    checkTempAdmin().then((ok) => { tempAdmin = ok; syncAdminUI(); });
    getUser().then((u) => { identityUser = u; syncAdminUI(); }).catch(() => { identityUser = null; syncAdminUI(); });
    onAuthChange((_event, user) => { identityUser = user; syncAdminUI(); });
  </script>

  <script>
    // ── Progressive email capture ─────────────────────────────────────────
    const circleEmailForm = document.getElementById('circle-email-form');
    let capturedEmail = '';
    let capturedRef = new URLSearchParams(window.location.search).get('ref') || '';
    let capturedLang = '';

    circleEmailForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = (document.getElementById('circle-email') as HTMLInputElement)?.value?.trim();
      if (!email) return;
      capturedEmail = email;
      capturedLang = window.__sjLang || 'no';

      // Submit to Netlify Forms (interesse form, email only first)
      try {
        const body = new URLSearchParams({
          'form-name': 'interesse',
          email,
          name: '',
          message: '',
          'ref': capturedRef,
          'language': capturedLang,
          'segment': 'pending',
        });
        await fetch('/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: body.toString(),
        });
      } catch { /* non-critical */ }

      // Move to step 2
      document.getElementById('circle-step-1')?.classList.add('hidden');
      document.getElementById('circle-step-2')?.classList.remove('hidden');
    });

    async function submitSegment(segment: string) {
      // Disable buttons
      document.querySelectorAll('.segment-btn').forEach(b => (b as HTMLButtonElement).disabled = true);

      try {
        // Submit segment to Netlify Forms
        const body = new URLSearchParams({
          'form-name': 'interesse',
          email: capturedEmail,
          name: '',
          message: segment,
          'ref': capturedRef,
          'language': capturedLang,
          'segment': segment,
        });
        await fetch('/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: body.toString(),
        });

        // Also submit to our own leads API for DB storage
        await fetch('/api/leads', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            email: capturedEmail,
            segment,
            language: capturedLang,
            ref_code: capturedRef,
            source: 'homepage_circle',
          }),
        });
      } catch { /* non-critical */ }

      // Move to step 3
      document.getElementById('circle-step-2')?.classList.add('hidden');
      document.getElementById('circle-step-3')?.classList.remove('hidden');

      // If maker or curator — redirect to makers page after 3 seconds
      if (segment === 'maker' || segment === 'curator') {
        setTimeout(() => { window.location.href = '/makers'; }, 3000);
      }
    }

    (window as any).submitSegment = submitSegment;
  </script>
