---
const title = "Scandi Japandi Collection";
---

<!DOCTYPE html>
<html lang="no">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Scandi Japandi Collection</title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;500&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    body { 
      font-family: 'Inter', system-ui, sans-serif; 
    }
    .serif { 
      font-family: 'Cormorant Garamond', serif; 
    }
    .hero {
      background-image: linear-gradient(rgba(18,18,18,0.42), rgba(18,18,18,0.42)), 
                        url('https://picsum.photos/id/1015/2000/1200');
      background-size: cover;
      background-position: center;
    }
  </style>
</head>
<body class="bg-[#FAF9F6] text-[#1F1F1F]">

  <!-- Navigation -->
  <nav class="fixed top-0 w-full bg-white/95 backdrop-blur-md z-50 border-b border-[#1F1F1F]/10">
    <div class="max-w-7xl mx-auto px-8 py-6 flex justify-between items-center">
      <div class="text-2xl tracking-[0.25em] font-light serif">SCANDI JAPANDI</div>
      <div class="flex items-center gap-10 text-sm uppercase tracking-widest">
        <a href="#collection" class="hover:text-[#C5A05B] transition-colors">Kolleksjon</a>
        <a href="#" class="hover:text-[#C5A05B] transition-colors">Japandi</a>
        <a href="#" class="hover:text-[#C5A05B] transition-colors">Produsenter</a>
      </div>
      <div class="flex gap-6 text-sm font-medium">
        <a href="/" class="text-[#C5A05B]">NO</a>
        <a href="/en" class="hover:text-[#C5A05B]">EN</a>
        <a href="/ja" class="hover:text-[#C5A05B]">JA</a>
      </div>
    </div>
  </nav>

  <!-- Hero -->
  <section class="hero h-screen flex items-center justify-center text-white">
    <div class="max-w-5xl mx-auto text-center px-6">
      <p class="uppercase tracking-[0.4em] text-sm mb-6 opacity-90">Quiet Luxury • Timeless Harmony</p>
      <h1 class="serif text-6xl md:text-7xl leading-none font-light tracking-tight mb-10">
        Skandinavisk sjel.<br>
        Japansk ro.
      </h1>
      <p class="text-xl max-w-xl mx-auto mb-12 opacity-90">
        Håndplukkede objekter fra de beste småskala produsentene i Norden.
      </p>
      <a href="#collection" 
         class="inline-block border border-white px-14 py-6 text-sm uppercase tracking-widest hover:bg-white hover:text-[#1F1F1F] transition-all duration-500">
        Utforsk kolleksjonen
      </a>
    </div>
  </section>

  <!-- Collection placeholder -->
  <section id="collection" class="max-w-7xl mx-auto px-8 py-28">
    <h2 class="serif text-5xl font-light text-center mb-20">Kuratert kolleksjon</h2>
    <p class="text-center text-gray-600">Produkter vil dukke opp her når vi har koblet til admin.</p>
  </section>

</body>
</html>
