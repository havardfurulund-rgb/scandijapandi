---
import Base from '../layouts/Base.astro';
---
<Base title="About — ScandiJapandi">
  <main class="min-h-screen bg-paper flex items-center justify-center px-6 py-32 pt-40">
    <div class="max-w-2xl">
      <p class="text-[10px] uppercase tracking-widest text-stone mb-6">About ScandiJapandi</p>
      <h1 class="font-serif text-4xl sm:text-5xl text-ink font-light leading-tight mb-10">
        Where Nordic craft<br/>meets Japanese sensibility.
      </h1>
      <div class="space-y-6 text-base text-stone font-light leading-relaxed">
        <p>
          ScandiJapandi is a curated bridge between two of the world's most refined design traditions —
          Scandinavian craftsmanship and Japanese aesthetic philosophy.
        </p>
        <p>
          We work with a small number of Nordic makers whose objects embody the same quiet principles
          that define wabi-sabi and hygge: honesty of material, purposeful form, and enduring quality.
        </p>
        <p>
          Each piece in our collection is chosen not for trend, but for its ability to bring stillness
          into a room — and into a life.
        </p>
      </div>
      <div class="mt-16 pt-10 border-t border-ink/8">
        <p class="text-[10px] uppercase tracking-widest text-stone mb-4">Based in</p>
        <p class="text-sm text-ink">Scandinavia · Japan · The world</p>
      </div>
      <a href="/" class="inline-block mt-12 text-[10px] uppercase tracking-widest text-stone hover:text-ink transition-colors">
        ← Back to collection
      </a>
    </div>
  </main>
</Base>
