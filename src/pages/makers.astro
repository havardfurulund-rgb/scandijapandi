---
import Base from '../layouts/Base.astro';
---
<Base title="For Makers — ScandiJapandi">
  <main class="min-h-screen bg-paper flex items-center justify-center px-6 py-32">
    <div class="max-w-lg text-center">
      <p class="text-[10px] uppercase tracking-widest text-stone mb-6">ScandiJapandi · Makers</p>
      <h1 class="font-serif text-4xl sm:text-5xl text-ink font-light leading-tight mb-6">
        Bring your craft<br/>to Japan.
      </h1>
      <p class="text-base text-stone font-light leading-relaxed mb-12">
        We partner with a small number of Scandinavian makers whose work embodies quiet, enduring craft.
        If that sounds like you, we'd like to hear from you.
      </p>
      <a href="mailto:makers@scandijapandi.no" class="inline-block bg-ink text-paper px-10 py-5 text-[10px] uppercase tracking-widest hover:bg-clay transition-colors">
        Get in touch
      </a>
      <p class="mt-12 text-xs text-stone/50">
        <a href="/" class="hover:text-stone transition-colors">← Back to collection</a>
      </p>
    </div>
  </main>
</Base>
