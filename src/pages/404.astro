---
import Base from '../layouts/Base.astro';
---
<Base title="Page not found — ScandiJapandi">
  <main class="min-h-screen bg-paper flex items-center justify-center px-6 py-32">
    <div class="max-w-md text-center">
      <p class="font-serif text-8xl text-ink/10 font-light mb-8">404</p>
      <p class="text-[10px] uppercase tracking-widest text-stone mb-6">ScandiJapandi</p>
      <h1 class="font-serif text-3xl text-ink font-light mb-6">This page doesn't exist.</h1>
      <p class="text-sm text-stone font-light leading-relaxed mb-10">
        The object you were looking for may have moved, sold out, or never existed.
      </p>
      <a href="/" class="inline-block bg-ink text-paper px-10 py-4 text-[10px] uppercase tracking-widest hover:bg-clay transition-colors">
        Back to collection
      </a>
    </div>
  </main>
</Base>
