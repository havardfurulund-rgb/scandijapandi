          if (t.name_en) $('pr-title-en').value = t.name_en;
          if (t.name_jp) $('pr-title-jp').value = t.name_jp;
          if (t.description_en) $('pr-body-en').value = t.description_en;
          if (t.description_jp) $('pr-body-jp').value = t.description_jp;
        });
