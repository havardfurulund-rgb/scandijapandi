        price_nok:            Number($('p-price').value),
        price_jpy:            Number.isFinite(priceJpy) && priceJpy > 0 ? Math.round(priceJpy) : null,
        image_url:            $('p-image').value.trim(),
        description:          $('p-description').value.trim() || null,
        description_en:         $('p-description-en').value.trim() || null,
        description_jp:         $('p-description-jp').value.trim() || null,
        origin_story:           $('p-origin-story').value.trim() || null,
        origin_story_en:        $('p-origin-story-en').value.trim() || null,
        origin_story_jp:        $('p-origin-story-jp').value.trim() || null,
        producer_story_en:      $('p-producer-story-en').value.trim() || null,
        producer_story_jp:      $('p-producer-story-jp').value.trim() || null,
        material_en:            $('p-material-en').value.trim() || null,
        material_jp:            $('p-material-jp').value.trim() || null,
        care_instructions_en:   $('p-care-en').value.trim() || null,
        care_instructions_jp:   $('p-care-jp').value.trim() || null,
        producer_location:    $('p-producer-location').value.trim() || null,
        producer_image_url:   $('p-producer-image-url').value.trim() || null,
        producer_story:       $('p-producer-story').value.trim() || null,
        material:             $('p-material').value.trim() || null,
        dimensions:           $('p-dimensions').value.trim() || null,
        care_instructions:    $('p-care').value.trim() || null,
        stripe_link:          $('p-stripe-link').value.trim() || null,
        stock_quantity:       $('p-stock').value !== '' ? Number($('p-stock').value) : null,
        weight_grams:         $('p-weight-grams').value !== '' ? Number($('p-weight-grams').value) : null,
        country_of_origin:    $('p-country-of-origin').value.trim() || null,
        gallery_urls:         [$('p-gallery-1').value.trim(), $('p-gallery-2').value.trim(), $('p-gallery-3').value.trim(), $('p-gallery-4').value.trim()].filter(Boolean),
        active:               $('p-active').checked,
      };
      const res = slug
        ? await api(`/api/admin/products/${encodeURIComponent(slug)}`, { method: 'PUT', body: JSON.stringify(payload) })
        : await api('/api/admin/products', { method: 'POST', body: JSON.stringify(payload) });
      if (res.ok) { resetForm(); await loadProducts(); msg('Lagret.', true); }
      else {
        const err = await res.json().catch(() => ({}));
        msg(err.error === 'a valid producer_email is required' ? 'Oppgi en gyldig produsent e-post.' : 'Kunne ikke lagre.', false);
      }
    });

    $('cancel-edit').addEventListener('click', resetForm);

    // ── AI Translation ────────────────────────────────────────────────
    document.getElementById('btn-translate')?.addEventListener('click', async () => {
      const name = $('p-name').value.trim();
      if (!name) {
        showTranslateStatus('Fyll inn produktnavn (NO) først.', false);
        return;
      }

      const btn = document.getElementById('btn-translate');
      const label = document.getElementById('translate-label');
      const icon = document.getElementById('translate-icon');
      if (btn) btn.setAttribute('disabled', 'true');
      if (label) label.textContent = 'Oversetter…';
      if (icon) icon.textContent = '⟳';

      try {
        const payload = {
          name:                $('p-name').value.trim(),
          description:         $('p-description').value.trim(),
          origin_story:        $('p-origin-story').value.trim(),
          producer_story:      $('p-producer-story').value.trim(),
          material:            $('p-material').value.trim(),
          care_instructions:   $('p-care').value.trim(),
        };

        const res = await fetch('/api/admin/translate', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });

        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        const { translations: t } = await res.json();

        // Fill EN fields
        if (t.name_en)         $('p-name-en').value = t.name_en;
        if (t.description_en)  $('p-description-en').value = t.description_en;
        if (t.origin_story_en) $('p-origin-story-en').value = t.origin_story_en;
        if (t.producer_story_en) $('p-producer-story-en').value = t.producer_story_en;
        if (t.material_en)     $('p-material-en').value = t.material_en;
        if (t.care_en)         $('p-care-en').value = t.care_en;

        // Fill JP fields
        if (t.name_jp)         $('p-name-jp').value = t.name_jp;
        if (t.description_jp)  $('p-description-jp').value = t.description_jp;
        if (t.origin_story_jp) $('p-origin-story-jp').value = t.origin_story_jp;
        if (t.producer_story_jp) $('p-producer-story-jp').value = t.producer_story_jp;
        if (t.material_jp)     $('p-material-jp').value = t.material_jp;
        if (t.care_jp)         $('p-care-jp').value = t.care_jp;

        // Add EN/JP description textareas if they were empty
        if (t.description_en && !$('p-description-en').value)
          $('p-description-en').value = t.description_en;
        if (t.description_jp && !$('p-description-jp').value)
          $('p-description-jp').value = t.description_jp;

        showTranslateStatus('✓ Oversettelse fullført — kontroller og lagre.', true);
      } catch (err) {
        console.error('[translate]', err);
        showTranslateStatus('Oversettelse feilet — prøv igjen.', false);
      } finally {
        if (btn) btn.removeAttribute('disabled');
        if (label) label.textContent = 'Oversett automatisk (NO → EN + JP)';
        if (icon) icon.textContent = '✦';
      }
    });

    function showTranslateStatus(msg: string, ok: boolean) {
      const el = document.getElementById('translate-status');
      if (!el) return;
      el.textContent = msg;
      el.className = `text-[11px] ${ok ? 'text-moss' : 'text-clay'}`;
      el.classList.remove('hidden');
      setTimeout(() => el.classList.add('hidden'), 6000);
    }

    // ---- Bilde-opplasting (Netlify Blobs via /api/admin/upload) ----

    // Synk forhåndsvisningen med det skjulte image_url-feltet.
    function setImage(url) {
      $('p-image').value = url || '';
      if (url) {
        $('p-image-preview').src = url;
        show('p-image-preview-wrap');
        hide('p-image-placeholder');
      } else {
        $('p-image-preview').removeAttribute('src');
        hide('p-image-preview-wrap');
        show('p-image-placeholder');
      }
    }

    function imageStatus(text, ok) {
      const el = $('p-image-status');
      if (!text) { hide('p-image-status'); el.textContent = ''; return; }
      el.textContent = text;
      el.className = `mt-1 text-[11px] ${ok === false ? 'text-clay' : 'text-stone'}`;
      show('p-image-status');
    }

    async function uploadFile(file) {
      if (!file) return;
      if (!file.type.startsWith('image/')) { imageStatus('Velg en bildefil.', false); return; }
      if (file.size > 5 * 1024 * 1024) { imageStatus('Bildet er for stort (maks 5 MB).', false); return; }

      const uploadBtn = $('p-image-upload');
      uploadBtn.disabled = true;
      imageStatus('Laster opp …');
      try {
        const fd = new FormData();
        fd.append('file', file);
        const res = await fetch('/api/admin/upload', { method: 'POST', body: fd });
        const data = await res.json().catch(() => ({}));
        if (!res.ok) throw new Error(data.error || 'Opplasting feilet.');
        setImage(data.url);
        imageStatus('Bilde lastet opp.', true);
      } catch (err) {
        imageStatus(err.message || 'Opplasting feilet.', false);
      } finally {
        uploadBtn.disabled = false;
        $('p-image-file').value = '';
      }
    }

    $('p-image-upload').addEventListener('click', () => $('p-image-file').click());
    $('p-image-file').addEventListener('change', (e) => uploadFile(e.target.files?.[0]));
    $('p-image-remove').addEventListener('click', () => { setImage(''); imageStatus(''); });

    // Dra-og-slipp på opplastingsfeltet.
    const drop = $('p-image-drop');
    ['dragenter', 'dragover'].forEach((evt) =>
      drop.addEventListener(evt, (e) => { e.preventDefault(); drop.classList.add('border-ink', 'bg-oat/60'); }));
    ['dragleave', 'drop'].forEach((evt) =>
      drop.addEventListener(evt, (e) => { e.preventDefault(); drop.classList.remove('border-ink', 'bg-oat/60'); }));
    drop.addEventListener('drop', (e) => uploadFile(e.dataTransfer?.files?.[0]));

    // Influencer link generator
    $('ref-make').addEventListener('click', () => {
      const name = $('ref-name').value.trim().toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
      if (!name) return;
      const link = `${window.location.origin}/?ref=${encodeURIComponent(name)}`;
      $('ref-link').textContent = link;
      show('ref-result');
    });
    $('ref-copy').addEventListener('click', () => navigator.clipboard?.writeText($('ref-link').textContent || ''));

    // Oppdater ordrehistorikken på forespørsel.
    $('orders-refresh').addEventListener('click', () => loadOrders());
    $('leads-refresh').addEventListener('click', () => loadLeads());

    // ---- Auth ----

    // ---- Kodebasert admin-innlogging (hovedløsning: brukernavn + passord) ----
    // En enkel, pålitelig innlogging som snakker med /api/admin/* og setter en
    // httpOnly øktcookie på serveren. Brukernavn/passord ligger i
    // netlify/lib/temp-admin.mts. Fungerer uavhengig av Netlify Identity.

    // Sjekk om en gyldig admin-cookie allerede finnes.
    async function isTempAdmin() {
      try {
        const res = await fetch('/api/admin/session');
        if (!res.ok) return false;
        const data = await res.json();
        return !!data.authenticated;
      } catch (e) {
        return false;
      }
    }

    // Vis dashbordet for en innlogget (midlertidig) admin.
    async function enterDashboard(label) {
      $('admin-email').textContent = label || '';
      show('logout-btn');
      showOnly('admin-view');
      await loadProducts();
      loadOrders();
      loadLeads();
      loadKurator();
    }

    // Logg inn med kodebasert brukernavn + passord.
    $('temp-login-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      hide('temp-login-error');
      try {
        const res = await fetch('/api/admin/login', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ username: $('temp-username').value, password: $('temp-password').value }),
        });
        if (!res.ok) throw new Error('bad credentials');
        $('temp-password').value = '';
        await enterDashboard($('temp-username').value || 'Admin');
      } catch (err) {
        $('temp-login-error').textContent = 'Feil brukernavn eller passord. Prøv igjen.';
        show('temp-login-error');
      }
    });

    // Bytt til/fra den fulle Netlify Identity-innloggingen.
    $('use-identity').addEventListener('click', () => showOnly('login-view'));
    $('back-to-temp').addEventListener('click', () => showOnly('temp-login-view'));

    // Logout from the dashboard and the "no access" screen. Clears BOTH the
    // temporary session cookie and any Netlify Identity session, then reloads.
    async function doLogout() {
      try { await fetch('/api/admin/logout', { method: 'POST' }); } catch (e) {}
      try { await logout(); } catch (e) {}
      location.assign('/admin');
    }
    $('logout-btn').addEventListener('click', doLogout);
    $('noaccess-logout').addEventListener('click', doLogout);

    // Login
    $('login-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      hide('login-error');
      try {
        await login($('login-email').value, $('login-password').value);
        await boot();
      } catch (err) {
        const el = $('login-error');
        el.textContent = authMessage(err);
        show('login-error');
      }
    });

    // Switch between login and "forgot password".
    $('forgot-link').addEventListener('click', () => {
      hide('login-error');
      $('forgot-email').value = $('login-email').value;
      hide('forgot-msg');
      showOnly('forgot-view');
    });
    $('back-to-login').addEventListener('click', () => showOnly('login-view'));

    // Request a recovery email.
    $('forgot-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const el = $('forgot-msg');
      try {
        await requestPasswordRecovery($('forgot-email').value.trim());
        el.textContent = 'Sjekk e-posten din for en lenke til å sette nytt passord.';
        el.className = 'text-sm text-ink';
        show('forgot-msg');
      } catch (err) {
        el.textContent = authMessage(err);
        el.className = 'text-sm text-clay';
        show('forgot-msg');
      }
    });

    // Set a new password — used for both recovery and invite acceptance.
    // resetMode is 'recovery' (user already logged in via the callback) or
    // 'invite' (we hold a token and must redeem it together with the password).
    let resetMode = 'recovery';
    let inviteToken = null;

    function showResetView(mode, { email, title, sub } = {}) {
      resetMode = mode;
      $('reset-title').textContent = title || 'Sett nytt passord';
      $('reset-sub').textContent = sub || (email ? `Velg et nytt passord for ${email}.` : 'Velg et nytt passord for kontoen din.');
      hide('reset-error');
      $('reset-form').reset();
      showOnly('reset-view');
    }

    $('reset-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      hide('reset-error');
      const pw = $('reset-password').value;
      const pw2 = $('reset-password2').value;
      const el = $('reset-error');
      if (pw.length < 8) { el.textContent = 'Passordet må være minst 8 tegn.'; show('reset-error'); return; }
      if (pw !== pw2) { el.textContent = 'Passordene er ikke like.'; show('reset-error'); return; }
      try {
        if (resetMode === 'invite') {
          await acceptInvite(inviteToken, pw);
        } else {
          await updateUser({ password: pw });
        }
        inviteToken = null;
        await boot();
      } catch (err) {
        el.textContent = authMessage(err);
        show('reset-error');
      }
    });

    // Route an authenticated user to the dashboard, the "no access" screen, or
    // the login form — the single source of truth for what the page shows.
    async function boot() {
      // getUser kan kaste hvis Identity ikke er aktivert – da faller vi pent
      // tilbake til den midlertidige passord-innloggingen.
      let user = null;
      try { user = await getUser(); } catch (e) { user = null; }
      if (!user) {
        // Ingen Identity-bruker: vis den midlertidige passord-innloggingen som standard.
        showOnly('temp-login-view');
        hide('logout-btn');
        $('admin-email').textContent = '';
        return;
      }
      $('admin-email').textContent = user.email || '';
      show('logout-btn');
      if (!user.roles?.includes('admin')) { showOnly('noaccess-view'); return; }
      showOnly('admin-view');
      await loadProducts();
      loadOrders();
      loadLeads();
      loadKurator();
    }

    // On page load, redeem any token in the URL hash (recovery, invite,
    // confirmation, email change) BEFORE deciding which view to show. This is
    // what makes the emailed recovery and invite links actually work.
    async function init() {
      // Kodebasert admin: er øktcookien allerede gyldig? Gå rett inn.
      if (await isTempAdmin()) {
        await enterDashboard('Admin');
        return;
      }

      let routed = false;
      try {
        const result = await handleAuthCallback();
        if (result?.type === 'recovery') {
          showResetView('recovery', { email: result.user?.email });
          routed = true;
        } else if (result?.type === 'invite') {
          inviteToken = result.token;
          showResetView('invite', { title: 'Velkommen', sub: 'Velg et passord for å fullføre kontoen din.' });
          routed = true;
        }
        // 'confirmation' / 'email_change' / 'oauth' log the user in; boot() handles them.
      } catch (err) {
        if (window.location.hash) {
          // Kom hit fra en e-postlenke (recovery/invite) med en ugyldig/brukt
          // token: vis Identity-innloggingen med kontekst.
          showOnly('login-view');
          $('login-error').textContent = authMessage(err);
          show('login-error');
          routed = true;
        }
        // Ellers (f.eks. Identity ikke aktivert): la boot() vise den
        // midlertidige passord-innloggingen som standard.
      }

      // Strip the hash so a refresh can't try to reuse a one-time token.
      if (window.location.hash) {
        history.replaceState(null, '', window.location.pathname + window.location.search);
      }

      if (!routed) await boot();
    }

    // ══════════════════════════════════════════════════════════════════
    //  KURATOR HUB
    //  Nyhetsbrev · Pressemeldinger · Produsenter · Influensere.
    //  Bruker samme api()-hjelper, show/hide-mønster og styling som resten
    //  av admin-panelet.
    // ══════════════════════════════════════════════════════════════════
    const nokMinor = (v) => nok.format(Number(v || 0) / 100);
    const fmtDay = (s) => { try { return new Date(s).toLocaleDateString('nb-NO', { dateStyle: 'medium' }); } catch { return s || ''; } };

    // ── Fane-navigasjon ──────────────────────────────────────────────
    const K_TABS = ['nyhetsbrev', 'presse', 'produsenter', 'influensere'];
    function showKuratorTab(tab) {
      K_TABS.forEach((t) => { const el = $(`ktab-${t}`); if (el) el.classList.toggle('hidden', t !== tab); });
      document.querySelectorAll('.k-tab').forEach((b) => {
        const on = b.dataset.ktab === tab;
        b.classList.toggle('border-ink', on);
        b.classList.toggle('text-ink', on);
        b.classList.toggle('border-transparent', !on);
        b.classList.toggle('text-stone', !on);
      });
    }
    document.querySelectorAll('.k-tab').forEach((b) => b.addEventListener('click', () => showKuratorTab(b.dataset.ktab)));

    function kStatus(id, text, ok) {
      const el = $(id);
      if (!el) return;
      el.textContent = text;
      el.className = `text-[11px] ${ok ? 'text-moss' : 'text-clay'}`;
      show(id);
      setTimeout(() => hide(id), 5000);
    }

    // Delt statusmerke for kladd/sendt.
    function sendBadge(status) {
      return status === 'sent'
        ? '<span class="text-[10px] uppercase tracking-widest text-moss">Sendt</span>'
        : '<span class="text-[10px] uppercase tracking-widest text-clay">Kladd</span>';
    }

    async function loadKurator() {
      loadNewsletters();
      loadPress();
      loadProducers();
      loadInfluencers();
    }
    $('kurator-refresh')?.addEventListener('click', loadKurator);

    // ── Delt AI-oversettelse (gjenbruker /api/admin/translate) ───────
    // Endepunktet forventer { name, description } og svarer med *_en/*_jp.
    async function kTranslate(sourceText, sourceBody, btnId, iconId, labelId, apply) {
      if (!sourceText) { return { error: 'Fyll inn tekst (NO) først.' }; }
      const btn = $(btnId), icon = $(iconId), label = $(labelId);
      if (btn) btn.setAttribute('disabled', 'true');
      if (label) label.textContent = 'Oversetter…';
      if (icon) icon.textContent = '⟳';
      try {
        const res = await fetch('/api/admin/translate', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name: sourceText, description: sourceBody }),
        });
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        const { translations: t } = await res.json();
        apply(t);
        return { ok: true };
      } catch (err) {
        console.error('[kurator-translate]', err);
        return { error: 'Oversettelse feilet — prøv igjen.' };
      } finally {
        if (btn) btn.removeAttribute('disabled');
        if (label) label.textContent = 'Oversett automatisk (NO → EN + JP)';
        if (icon) icon.textContent = '✦';
      }
    }

    // ─────────────────────────────────────────────────────────────────
    //  NYHETSBREV
    // ─────────────────────────────────────────────────────────────────
    function renderNewsletters(rows) {
      const list = $('nl-list');
      if (!rows.length) { list.innerHTML = '<p class="text-sm text-stone">Ingen nyhetsbrev ennå.</p>'; return; }
      const segLabel = { all: 'Alle', customer: 'Kunder', maker: 'Makers', curator: 'Kuratorer' };
      list.innerHTML = `
        <table class="w-full text-sm border-collapse">
          <thead><tr class="text-left border-b border-ink/10">
            <th class="py-3 pr-4 text-[10px] uppercase tracking-widest text-stone font-medium">Emne</th>
            <th class="py-3 pr-4 text-[10px] uppercase tracking-widest text-stone font-medium">Segment</th>
            <th class="py-3 pr-4 text-[10px] uppercase tracking-widest text-stone font-medium">Status</th>
            <th class="py-3 pr-4 text-[10px] uppercase tracking-widest text-stone font-medium">Sendt</th>
            <th class="py-3 text-[10px] uppercase tracking-widest text-stone font-medium">Mottakere</th>
          </tr></thead>
          <tbody>
            ${rows.map((n) => `
              <tr class="border-b border-ink/5">
                <td class="py-3 pr-4 text-ink">${escapeHtml(n.subject_no || n.subject_en || '—')}</td>
                <td class="py-3 pr-4 text-stone">${escapeHtml(segLabel[n.segment] || n.segment || '—')}</td>
                <td class="py-3 pr-4">${sendBadge(n.status)}</td>
                <td class="py-3 pr-4 text-stone whitespace-nowrap">${n.sent_at ? escapeHtml(fmtDay(n.sent_at)) : '—'}</td>
                <td class="py-3 text-stone">${n.recipients || 0}</td>
              </tr>`).join('')}
          </tbody>
        </table>`;
    }

    async function loadNewsletters() {
      const list = $('nl-list');
      try {
        const res = await api('/api/admin/kurator/newsletters');
        if (!res.ok) { list.innerHTML = '<p class="text-sm text-clay">Kunne ikke laste nyhetsbrev.</p>'; return; }
        const data = await res.json();
        renderNewsletters(data.newsletters || []);
      } catch { list.innerHTML = '<p class="text-sm text-clay">Kunne ikke laste nyhetsbrev.</p>'; }
    }

    function nlReset() {
      $('nl-id').value = '';
      ['nl-subject-no','nl-subject-en','nl-subject-jp','nl-body-no','nl-body-en','nl-body-jp'].forEach((id) => { $(id).value = ''; });
      $('nl-segment').value = 'all';
    }
    $('nl-new')?.addEventListener('click', () => { nlReset(); show('nl-form'); });
    $('nl-cancel')?.addEventListener('click', () => { hide('nl-form'); nlReset(); });

    $('nl-translate')?.addEventListener('click', async () => {
      const r = await kTranslate($('nl-subject-no').value.trim(), $('nl-body-no').value.trim(),
        'nl-translate', 'nl-translate-icon', 'nl-translate-label', (t) => {
          if (t.name_en) $('nl-subject-en').value = t.name_en;
          if (t.name_jp) $('nl-subject-jp').value = t.name_jp;
          if (t.description_en) $('nl-body-en').value = t.description_en;
          if (t.description_jp) $('nl-body-jp').value = t.description_jp;
        });
      if (r.error) kStatus('nl-status', r.error, false);
      else kStatus('nl-status', '✓ Oversettelse fullført — kontroller og lagre.', true);
    });

    function nlPayload() {
      return {
        subject_no: $('nl-subject-no').value.trim() || null,
        subject_en: $('nl-subject-en').value.trim() || null,
        subject_jp: $('nl-subject-jp').value.trim() || null,
        body_no: $('nl-body-no').value.trim() || null,
        body_en: $('nl-body-en').value.trim() || null,
        body_jp: $('nl-body-jp').value.trim() || null,
        segment: $('nl-segment').value,
      };
    }

    // Lagrer en kladd (INSERT) og returnerer raden, eller null ved feil.
    async function nlSave(silent) {
      const p = nlPayload();
      if (!p.subject_no && !p.subject_en) { kStatus('nl-status', 'Skriv inn et emne først.', false); return null; }
      const res = await api('/api/admin/kurator/newsletters', { method: 'POST', body: JSON.stringify(p) });
      if (!res.ok) { kStatus('nl-status', 'Kunne ikke lagre.', false); return null; }
      const data = await res.json();
      $('nl-id').value = data.newsletter?.id || '';
      await loadNewsletters();
      if (!silent) kStatus('nl-status', '✓ Kladd lagret.', true);
      return data.newsletter;
    }
    $('nl-save')?.addEventListener('click', () => nlSave(false));

    $('nl-send')?.addEventListener('click', async () => {
      if (!confirm('Send nyhetsbrevet nå til valgt segment? Dette kan ikke angres.')) return;
      let id = $('nl-id').value;
      if (!id) { const saved = await nlSave(true); if (!saved) return; id = saved.id; }
      kStatus('nl-status', 'Sender …', true);
      const res = await api('/api/admin/kurator/send-newsletter', { method: 'POST', body: JSON.stringify({ id: Number(id) }) });
      const data = await res.json().catch(() => ({}));
      if (res.ok) {
        kStatus('nl-status', `✓ Sendt til ${data.recipients} mottakere.`, true);
        hide('nl-form'); nlReset(); await loadNewsletters();
      } else {
        kStatus('nl-status', `Sending feilet: ${data.error || `HTTP ${res.status}`}`, false);
      }
    });

    // ─────────────────────────────────────────────────────────────────
    //  PRESSEMELDINGER + PRESSEKONTAKTER
    // ─────────────────────────────────────────────────────────────────
