    function renderReleases(rows) {
      const list = $('pr-list');
      if (!rows.length) { list.innerHTML = '<p class="text-sm text-stone">Ingen pressemeldinger ennå.</p>'; return; }
      list.innerHTML = `
        <table class="w-full text-sm border-collapse">
          <thead><tr class="text-left border-b border-ink/10">
            <th class="py-3 pr-4 text-[10px] uppercase tracking-widest text-stone font-medium">Tittel</th>
            <th class="py-3 pr-4 text-[10px] uppercase tracking-widest text-stone font-medium">Status</th>
            <th class="py-3 pr-4 text-[10px] uppercase tracking-widest text-stone font-medium">Sendt</th>
            <th class="py-3 text-[10px] uppercase tracking-widest text-stone font-medium">Mottakere</th>
          </tr></thead>
          <tbody>
            ${rows.map((r) => `
              <tr class="border-b border-ink/5">
                <td class="py-3 pr-4 text-ink">${escapeHtml(r.title || '—')}</td>
                <td class="py-3 pr-4">${sendBadge(r.status)}</td>
                <td class="py-3 pr-4 text-stone whitespace-nowrap">${r.sent_at ? escapeHtml(fmtDay(r.sent_at)) : '—'}</td>
                <td class="py-3 text-stone">${r.recipients || 0}</td>
              </tr>`).join('')}
          </tbody>
        </table>`;
    }

    function renderContacts(rows) {
      const list = $('pc-list');
      if (!rows.length) { list.innerHTML = '<p class="text-sm text-stone">Ingen pressekontakter ennå.</p>'; return; }
      list.innerHTML = `
        <table class="w-full text-sm border-collapse">
          <thead><tr class="text-left border-b border-ink/10">
            <th class="py-3 pr-4 text-[10px] uppercase tracking-widest text-stone font-medium">Navn</th>
            <th class="py-3 pr-4 text-[10px] uppercase tracking-widest text-stone font-medium">Mediehus</th>
            <th class="py-3 pr-4 text-[10px] uppercase tracking-widest text-stone font-medium">E-post</th>
            <th class="py-3 pr-4 text-[10px] uppercase tracking-widest text-stone font-medium">Land</th>
            <th class="py-3 pr-4 text-[10px] uppercase tracking-widest text-stone font-medium">Språk</th>
            <th class="py-3 text-[10px] uppercase tracking-widest text-stone font-medium"></th>
          </tr></thead>
          <tbody>
            ${rows.map((c) => `
