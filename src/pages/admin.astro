---
import Base from '../layouts/Base.astro';
---

<Base title="Admin — ScandiJapandi">
  <header class="border-b border-ink/10 bg-paper">
    <div class="mx-auto flex h-20 max-w-5xl items-center justify-between px-6">
      <a href="/" class="font-serif text-xl tracking-tight">ScandiJapandi</a>
      <div class="flex items-center gap-6 text-[10px] font-medium uppercase tracking-widest text-stone">
        <span>Admin</span>
        <span id="admin-email" class="text-ink"></span>
        <button id="logout-btn" type="button" class="hidden hover:text-ink transition-colors">Logg ut</button>
      </div>
    </div>
  </header>

  <main class="mx-auto max-w-5xl px-6 py-16">
    <!-- Primær admin-innlogging (kodebasert: brukernavn + passord) -->
    <section id="temp-login-view" class="hidden max-w-md mx-auto">
      <span class="text-[10px] font-medium uppercase tracking-widest text-stone block mb-3">Tilgang</span>
      <h1 class="font-serif text-3xl text-ink">Logg inn på admin</h1>
      <p class="mt-3 text-sm text-stone font-light">Skriv inn brukernavn og passord for å administrere butikken.</p>
      <form id="temp-login-form" class="mt-8 space-y-5 bg-oat/60 p-8 border border-ink/5">
        <label class="block">
          <span class="text-[10px] uppercase tracking-widest text-stone">Brukernavn</span>
          <input type="text" id="temp-username" autocomplete="username" required class="mt-2 w-full bg-paper p-4 border border-ink/10 focus:border-ink outline-none" />
        </label>
        <label class="block">
          <span class="text-[10px] uppercase tracking-widest text-stone">Passord</span>
          <input type="password" id="temp-password" autocomplete="current-password" required class="mt-2 w-full bg-paper p-4 border border-ink/10 focus:border-ink outline-none" />
        </label>
        <button type="submit" class="w-full bg-ink text-paper py-4 uppercase text-[10px] font-medium tracking-widest transition-colors hover:bg-clay">Logg inn</button>
        <p id="temp-login-error" class="hidden text-sm text-clay"></p>
        <button type="button" id="use-identity" class="block w-full text-center text-[10px] uppercase tracking-widest text-stone hover:text-ink transition-colors">
          Bruk Netlify Identity i stedet
        </button>
      </form>
    </section>

    <!-- Login -->
    <section id="login-view" class="hidden max-w-md mx-auto">
      <span class="text-[10px] font-medium uppercase tracking-widest text-stone block mb-3">Tilgang</span>
      <h1 class="font-serif text-3xl text-ink">Logg inn på admin</h1>
      <p class="mt-3 text-sm text-stone font-light">Administrer produkter, priser og influenser-lenker.</p>
      <form id="login-form" class="mt-8 space-y-5 bg-oat/60 p-8 border border-ink/5">
        <label class="block">
          <span class="text-[10px] uppercase tracking-widest text-stone">E-post</span>
          <input type="email" id="login-email" autocomplete="username" required class="mt-2 w-full bg-paper p-4 border border-ink/10 focus:border-ink outline-none" />
        </label>
        <label class="block">
          <span class="text-[10px] uppercase tracking-widest text-stone">Passord</span>
          <input type="password" id="login-password" autocomplete="current-password" required class="mt-2 w-full bg-paper p-4 border border-ink/10 focus:border-ink outline-none" />
        </label>
        <button type="submit" class="w-full bg-ink text-paper py-4 uppercase text-[10px] font-medium tracking-widest transition-colors hover:bg-clay">Logg inn</button>
        <p id="login-error" class="hidden text-sm text-clay"></p>
        <button type="button" id="forgot-link" class="block w-full text-center text-[10px] uppercase tracking-widest text-stone hover:text-ink transition-colors">
          Glemt passordet?
        </button>
        <button type="button" id="back-to-temp" class="block w-full text-center text-[10px] uppercase tracking-widest text-stone hover:text-ink transition-colors">
          ← Tilbake til passord-innlogging
        </button>
      </form>
    </section>

    <!-- Forgot password -->
    <section id="forgot-view" class="hidden max-w-md mx-auto">
      <span class="text-[10px] font-medium uppercase tracking-widest text-stone block mb-3">Tilbakestilling</span>
      <h1 class="font-serif text-3xl text-ink">Glemt passordet?</h1>
      <p class="mt-3 text-sm text-stone font-light">Skriv inn e-posten din, så sender vi deg en lenke for å sette et nytt passord.</p>
      <form id="forgot-form" class="mt-8 space-y-5 bg-oat/60 p-8 border border-ink/5">
        <label class="block">
          <span class="text-[10px] uppercase tracking-widest text-stone">E-post</span>
          <input type="email" id="forgot-email" autocomplete="username" required class="mt-2 w-full bg-paper p-4 border border-ink/10 focus:border-ink outline-none" />
        </label>
        <button type="submit" class="w-full bg-ink text-paper py-4 uppercase text-[10px] font-medium tracking-widest transition-colors hover:bg-clay">Send tilbakestillingslenke</button>
        <p id="forgot-msg" class="hidden text-sm"></p>
        <button type="button" id="back-to-login" class="block w-full text-center text-[10px] uppercase tracking-widest text-stone hover:text-ink transition-colors">
          ← Tilbake til innlogging
        </button>
      </form>
    </section>

    <!-- Set new password (recovery + invite) -->
    <section id="reset-view" class="hidden max-w-md mx-auto">
      <span class="text-[10px] font-medium uppercase tracking-widest text-stone block mb-3">Sikkerhet</span>
      <h1 id="reset-title" class="font-serif text-3xl text-ink">Sett nytt passord</h1>
      <p id="reset-sub" class="mt-3 text-sm text-stone font-light">Velg et nytt passord for kontoen din.</p>
      <form id="reset-form" class="mt-8 space-y-5 bg-oat/60 p-8 border border-ink/5">
        <label class="block">
          <span class="text-[10px] uppercase tracking-widest text-stone">Nytt passord</span>
          <input type="password" id="reset-password" autocomplete="new-password" minlength="8" required class="mt-2 w-full bg-paper p-4 border border-ink/10 focus:border-ink outline-none" />
        </label>
        <label class="block">
          <span class="text-[10px] uppercase tracking-widest text-stone">Bekreft passord</span>
          <input type="password" id="reset-password2" autocomplete="new-password" minlength="8" required class="mt-2 w-full bg-paper p-4 border border-ink/10 focus:border-ink outline-none" />
        </label>
        <button type="submit" class="w-full bg-ink text-paper py-4 uppercase text-[10px] font-medium tracking-widest transition-colors hover:bg-clay">Lagre passord</button>
        <p id="reset-error" class="hidden text-sm text-clay"></p>
      </form>
    </section>

    <!-- No access -->
    <section id="noaccess-view" class="hidden max-w-md mx-auto text-center">
      <h1 class="font-serif text-3xl text-ink">Ingen admin-tilgang</h1>
      <p class="mt-3 text-sm text-stone font-light">
        Kontoen din mangler <code class="bg-oat px-1">admin</code>-rollen. En administrator må tildele rollen
        i Netlify Identity før du får tilgang.
      </p>
      <button type="button" id="noaccess-logout" class="mt-8 text-[10px] uppercase tracking-widest text-stone hover:text-ink transition-colors">Logg ut</button>
    </section>

    <!-- Admin dashboard -->
    <section id="admin-view" class="hidden">
      <div class="flex items-baseline justify-between mb-10">
        <div>
          <span class="text-[10px] font-medium uppercase tracking-widest text-stone block mb-2">Katalog</span>
          <h1 class="font-serif text-3xl text-ink">Produkter</h1>
        </div>
      </div>

      <!-- Add / edit product -->
      <form id="product-form" class="bg-oat/60 p-8 border border-ink/5 mb-12 space-y-5">
        <h2 id="form-title" class="font-serif text-xl text-ink">Nytt produkt</h2>
        <input type="hidden" id="edit-slug" value="" />
        <div class="grid sm:grid-cols-2 gap-5">
          <label class="block">
            <span class="text-[10px] uppercase tracking-widest text-stone">Navn *</span>
            <input type="text" id="p-name" required class="mt-2 w-full bg-paper p-4 border border-ink/10 focus:border-ink outline-none" />
          </label>
          <label class="block">
            <span class="text-[10px] uppercase tracking-widest text-stone">Produsent</span>
            <input type="text" id="p-producer" class="mt-2 w-full bg-paper p-4 border border-ink/10 focus:border-ink outline-none" />
          </label>
          <label class="block">
            <span class="text-[10px] uppercase tracking-widest text-stone">Produsent e-post *</span>
            <input type="email" id="p-producer-email" required autocomplete="off" placeholder="produsent@eksempel.no" class="mt-2 w-full bg-paper p-4 border border-ink/10 focus:border-ink outline-none" />
          </label>
          <label class="block">
            <span class="text-[10px] uppercase tracking-widest text-stone">Pris (NOK) *</span>
            <input type="number" id="p-price" min="0" step="1" required class="mt-2 w-full bg-paper p-4 border border-ink/10 focus:border-ink outline-none" />
          </label>
        </div>

        <!-- Produktbilde: opplasting med forhåndsvisning -->
        <div class="block">
          <span class="text-[10px] uppercase tracking-widest text-stone">Produktbilde</span>
          <!-- Skjult felt som holder den endelige bilde-URL-en (sendes til API-et). -->
          <input type="hidden" id="p-image" value="" />
          <input type="file" id="p-image-file" accept="image/jpeg,image/png,image/webp,image/gif,image/avif,image/svg+xml" class="hidden" />
          <div id="p-image-drop" class="mt-2 flex items-center gap-5 border border-dashed border-ink/15 bg-paper/60 p-4 transition-colors">
            <div id="p-image-preview-wrap" class="hidden relative shrink-0">
              <img id="p-image-preview" src="" alt="Forhåndsvisning" class="h-24 w-24 object-cover bg-oat border border-ink/10" />
              <button type="button" id="p-image-remove" title="Fjern bilde" aria-label="Fjern bilde" class="absolute -top-2 -right-2 flex h-6 w-6 items-center justify-center rounded-full bg-ink text-paper text-sm leading-none transition-colors hover:bg-clay">×</button>
            </div>
            <div id="p-image-placeholder" class="flex h-24 w-24 shrink-0 items-center justify-center bg-oat/60 text-center text-[10px] uppercase tracking-widest text-stone">Ingen<br />bilde</div>
            <div class="flex-1 min-w-0">
              <button type="button" id="p-image-upload" class="border border-ink/20 px-6 py-3 uppercase text-[10px] font-medium tracking-widest transition-colors hover:border-ink">Last opp bilde</button>
              <p class="mt-2 text-[11px] text-stone font-light">Dra og slipp, eller velg en fil. JPG, PNG, WebP, GIF, AVIF eller SVG — maks 5 MB.</p>
              <p id="p-image-status" class="hidden mt-1 text-[11px]"></p>
            </div>
          </div>
        </div>

        <label class="block">
          <span class="text-[10px] uppercase tracking-widest text-stone">Beskrivelse</span>
          <textarea id="p-description" rows="2" class="mt-2 w-full bg-paper p-4 border border-ink/10 focus:border-ink outline-none"></textarea>
        </label>
        <label class="flex items-center gap-3 text-sm">
          <input type="checkbox" id="p-active" checked class="accent-clay" /> Aktiv (vises i butikken)
        </label>
        <div class="flex gap-4">
          <button type="submit" class="bg-ink text-paper px-8 py-3 uppercase text-[10px] font-medium tracking-widest transition-colors hover:bg-clay">Lagre produkt</button>
          <button type="button" id="cancel-edit" class="hidden border border-ink/20 px-8 py-3 uppercase text-[10px] font-medium tracking-widest hover:border-ink">Avbryt</button>
        </div>
        <p id="product-msg" class="hidden text-sm"></p>
      </form>

      <div id="product-list" class="space-y-3"></div>

      <!-- Influencer links -->
      <div class="mt-16 bg-ink text-paper p-8">
        <h2 class="font-serif text-xl">Influenser-lenker</h2>
        <p class="mt-2 text-sm text-paper/70 font-light">
          Lag en delbar lenke til en influenser. Salg via lenken merkes med deres navn (curator) i Stripe.
        </p>
        <div class="mt-6 flex flex-col sm:flex-row gap-3">
          <input type="text" id="ref-name" placeholder="influenser-navn" class="flex-1 bg-paper/10 border border-paper/20 p-4 text-paper placeholder:text-paper/40 outline-none focus:border-paper" />
          <button type="button" id="ref-make" class="bg-paper text-ink px-8 py-4 uppercase text-[10px] font-medium tracking-widest hover:bg-clay hover:text-paper transition-colors">Lag lenke</button>
        </div>
        <div id="ref-result" class="hidden mt-4 flex items-center gap-3 bg-paper/10 p-4">
          <code id="ref-link" class="flex-1 break-all text-sm text-paper/90"></code>
          <button type="button" id="ref-copy" class="text-[10px] uppercase tracking-widest text-paper/70 hover:text-paper">Kopier</button>
        </div>
      </div>

      <!-- === TEST E-POST KNAPP - IKKE FJERN NOE OVER ELLER UNDER === -->
      <div class="admin-test-email mt-10 p-6 border border-stone/30 rounded-2xl bg-oat/30">
        <h3 class="font-serif text-xl mb-4 text-ink">Send Test E-post</h3>
        <p id="email-config-status" class="mb-4 text-xs text-stone">Sjekker konfigurasjon …</p>
        <div class="flex flex-col sm:flex-row gap-3">
          <input
            type="email"
            id="test-email-input"
            placeholder="mottaker@example.com"
            class="flex-1 px-5 py-3 border border-stone/30 rounded-xl focus:outline-none focus:border-clay text-sm"
          />
          <button
            id="send-test-email-btn"
            class="px-8 py-3 bg-ink hover:bg-clay text-paper rounded-xl font-medium transition-colors whitespace-nowrap"
          >
            Send test
          </button>
        </div>
        <p id="test-email-status" class="mt-3 text-sm min-h-[20px]"></p>
      </div>

      <script>
        const btn = document.getElementById('send-test-email-btn');
        const input = document.getElementById('test-email-input');
        const status = document.getElementById('test-email-status');
        const configStatus = document.getElementById('email-config-status');

        // E-post sendes nå via Netlify Forms – innebygd i plattformen. Ingen
        // API-nøkler, SMTP eller eksterne tjenester. Varslingsadressen settes i
        // Netlify UI under Notifications → Emails and webhooks.
        configStatus.textContent = 'E-post sendes via Netlify Forms. Varselet går til adressen som er satt opp i Netlify (Notifications → Emails and webhooks) for skjemaene «test-epost», «ordrebekreftelse» og «kunde-bekreftelse».';
        configStatus.style.color = '#3f6212';

        // Liten hjelper for konsistent status + konsoll-logging, slik at det er
        // enkelt å feilsøke e-post fra nettleserens utviklerverktøy.
        function setStatus(message, color) {
          status.textContent = message;
          status.style.color = color;
          console.log('[test-epost]', message);
        }

        btn.addEventListener('click', async () => {
          const email = input.value.trim();
          if (!email) {
            setStatus('Skriv inn en e-postadresse', 'red');
            return;
          }

          btn.disabled = true;
          setStatus('Sender …', '#666');

          try {
            const body = new URLSearchParams({
              'form-name': 'test-epost',
              subject: 'Test-e-post fra ScandiJapandi-admin',
              email,
              melding: `Dette er en test-e-post sendt fra admin-panelet (oppgitt mottaker: ${email}).`,
            });

            // Send til det statiske skjema-skjelettet (/__forms.html), ikke '/',
            // slik at Netlify Forms fanger opp innsendingen og sender varselet.
            console.log('[test-epost] POST /__forms.html', { email });
            const res = await fetch('/__forms.html', {
              method: 'POST',
              headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
              body: body.toString(),
            });
            console.log('[test-epost] svar', res.status, res.statusText);

            if (res.ok) {
              setStatus('✅ Innsending mottatt av Netlify Forms. Varselet sendes til adressen som er konfigurert i Netlify (sjekk også spam).', 'green');
              input.value = '';
            } else {
              setStatus(`Feil ved sending (HTTP ${res.status} ${res.statusText}). Sjekk at skjemaet «test-epost» er registrert i Netlify.`, 'red');
            }
          } catch (err) {
            console.error('[test-epost] nettverksfeil', err);
            setStatus('Nettverksfeil – prøv igjen', 'red');
          } finally {
            btn.disabled = false;
          }
        });
      </script>
      <!-- === SLUTT PÅ TEST E-POST KNAPP === -->
    </section>
  </main>

  <script>
    import {
      login, logout, getUser,
      requestPasswordRecovery, handleAuthCallback, updateUser, acceptInvite,
      AuthError, MissingIdentityError,
    } from '@netlify/identity';

    const nok = new Intl.NumberFormat('nb-NO', { style: 'currency', currency: 'NOK', maximumFractionDigits: 0 });
    const $ = (id) => document.getElementById(id);
    const show = (id) => $(id).classList.remove('hidden');
    const hide = (id) => $(id).classList.add('hidden');

    // The mutually-exclusive top-level views. Only one is ever visible.
    const VIEWS = ['temp-login-view', 'login-view', 'forgot-view', 'reset-view', 'noaccess-view', 'admin-view'];
    function showOnly(view) { VIEWS.forEach((v) => (v === view ? show(v) : hide(v))); }

    // Turn an identity error into a human message without leaking which field was wrong.
    function authMessage(err) {
      if (err instanceof MissingIdentityError) return 'Identity er ikke aktivert. Kjør «netlify dev» eller aktiver Identity i prosjektet.';
      if (err instanceof AuthError) {
        if (err.status === 401) return 'Feil e-post eller passord.';
        if (err.status === 403) return 'Handlingen er ikke tillatt for denne kontoen.';
        if (err.status === 422) return 'Ugyldig inndata. Sjekk e-post og passord (minst 8 tegn).';
        if (err.status === 404) return 'Fant ingen konto for denne e-posten.';
        return err.message || 'Noe gikk galt. Prøv igjen.';
      }
      return err?.message || 'Noe gikk galt. Prøv igjen.';
    }

    function escapeHtml(s) {
      return String(s ?? '').replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));
    }

    async function api(path, options = {}) {
      const res = await fetch(path, { ...options, headers: { 'Content-Type': 'application/json', ...(options.headers || {}) } });
      return res;
    }

    function renderList(products) {
      const list = $('product-list');
      if (!products.length) { list.innerHTML = '<p class="text-sm text-stone">Ingen produkter ennå.</p>'; return; }
      list.innerHTML = products.map((p) => `
        <div class="flex items-center gap-4 bg-paper border border-ink/10 p-4">
          <img src="${escapeHtml(p.image_url)}" alt="" class="h-16 w-16 object-cover bg-oat" />
          <div class="flex-1 min-w-0">
            <p class="font-serif text-lg text-ink truncate">${escapeHtml(p.name)} ${p.active ? '' : '<span class="text-[10px] uppercase tracking-widest text-clay">(skjult)</span>'}</p>
            <p class="text-[10px] uppercase tracking-wider text-stone">${escapeHtml(p.producer || '')} · ${nok.format(Number(p.price_nok))} · /${escapeHtml(p.slug)}</p>
            ${p.producer_email ? `<p class="text-[10px] uppercase tracking-wider text-stone/70">✉ ${escapeHtml(p.producer_email)}</p>` : '<p class="text-[10px] uppercase tracking-wider text-clay">Mangler produsent e-post</p>'}
          </div>
          <button type="button" data-edit="${escapeHtml(p.slug)}" class="text-[10px] uppercase tracking-widest text-stone hover:text-ink">Rediger</button>
          <button type="button" data-del="${escapeHtml(p.slug)}" class="text-[10px] uppercase tracking-widest text-clay hover:opacity-70">Slett</button>
        </div>`).join('');

      list.querySelectorAll('[data-edit]').forEach((b) => b.addEventListener('click', () => startEdit(products.find((x) => x.slug === b.dataset.edit))));
      list.querySelectorAll('[data-del]').forEach((b) => b.addEventListener('click', () => del(b.dataset.del)));
    }

    let cache = [];
    async function loadProducts() {
      const res = await api('/api/admin/products');
      if (!res.ok) return;
      const data = await res.json();
      cache = data.products || [];
      renderList(cache);
    }

    function startEdit(p) {
      if (!p) return;
      $('form-title').textContent = 'Rediger produkt';
      $('edit-slug').value = p.slug;
      $('p-name').value = p.name || '';
      $('p-producer').value = p.producer || '';
      $('p-producer-email').value = p.producer_email || '';
      $('p-price').value = p.price_nok ?? '';
      setImage(p.image_url || '');
      $('p-description').value = p.description || '';
      $('p-active').checked = !!p.active;
      show('cancel-edit');
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function resetForm() {
      $('form-title').textContent = 'Nytt produkt';
      $('product-form').reset();
      $('edit-slug').value = '';
      $('p-active').checked = true;
      setImage('');
      hide('cancel-edit');
    }

    function msg(text, ok) {
      const el = $('product-msg');
      el.textContent = text;
      el.className = `text-sm ${ok ? 'text-ink' : 'text-clay'}`;
      show('product-msg');
      setTimeout(() => hide('product-msg'), 4000);
    }

    async function del(slug) {
      if (!confirm('Slette dette produktet?')) return;
      const res = await api(`/api/admin/products/${encodeURIComponent(slug)}`, { method: 'DELETE' });
      if (res.ok) { await loadProducts(); msg('Produkt slettet.', true); } else { msg('Kunne ikke slette.', false); }
    }

    $('product-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const slug = $('edit-slug').value;
      const payload = {
        name: $('p-name').value.trim(),
        producer: $('p-producer').value.trim(),
        producer_email: $('p-producer-email').value.trim(),
        price_nok: Number($('p-price').value),
        image_url: $('p-image').value.trim(),
        description: $('p-description').value.trim(),
        active: $('p-active').checked,
      };
      const res = slug
        ? await api(`/api/admin/products/${encodeURIComponent(slug)}`, { method: 'PUT', body: JSON.stringify(payload) })
        : await api('/api/admin/products', { method: 'POST', body: JSON.stringify(payload) });
      if (res.ok) { resetForm(); await loadProducts(); msg('Lagret.', true); }
      else {
        const err = await res.json().catch(() => ({}));
        msg(err.error === 'a valid producer_email is required' ? 'Oppgi en gyldig produsent e-post.' : 'Kunne ikke lagre.', false);
      }
    });

    $('cancel-edit').addEventListener('click', resetForm);

    // ---- Bilde-opplasting (Netlify Blobs via /api/admin/upload) ----

    // Synk forhåndsvisningen med det skjulte image_url-feltet.
    function setImage(url) {
      $('p-image').value = url || '';
      if (url) {
        $('p-image-preview').src = url;
        show('p-image-preview-wrap');
        hide('p-image-placeholder');
      } else {
        $('p-image-preview').removeAttribute('src');
        hide('p-image-preview-wrap');
        show('p-image-placeholder');
      }
    }

    function imageStatus(text, ok) {
      const el = $('p-image-status');
      if (!text) { hide('p-image-status'); el.textContent = ''; return; }
      el.textContent = text;
      el.className = `mt-1 text-[11px] ${ok === false ? 'text-clay' : 'text-stone'}`;
      show('p-image-status');
    }

    async function uploadFile(file) {
      if (!file) return;
      if (!file.type.startsWith('image/')) { imageStatus('Velg en bildefil.', false); return; }
      if (file.size > 5 * 1024 * 1024) { imageStatus('Bildet er for stort (maks 5 MB).', false); return; }

      const uploadBtn = $('p-image-upload');
      uploadBtn.disabled = true;
      imageStatus('Laster opp …');
      try {
        const fd = new FormData();
        fd.append('file', file);
        const res = await fetch('/api/admin/upload', { method: 'POST', body: fd });
        const data = await res.json().catch(() => ({}));
        if (!res.ok) throw new Error(data.error || 'Opplasting feilet.');
        setImage(data.url);
        imageStatus('Bilde lastet opp.', true);
      } catch (err) {
        imageStatus(err.message || 'Opplasting feilet.', false);
      } finally {
        uploadBtn.disabled = false;
        $('p-image-file').value = '';
      }
    }

    $('p-image-upload').addEventListener('click', () => $('p-image-file').click());
    $('p-image-file').addEventListener('change', (e) => uploadFile(e.target.files?.[0]));
    $('p-image-remove').addEventListener('click', () => { setImage(''); imageStatus(''); });

    // Dra-og-slipp på opplastingsfeltet.
    const drop = $('p-image-drop');
    ['dragenter', 'dragover'].forEach((evt) =>
      drop.addEventListener(evt, (e) => { e.preventDefault(); drop.classList.add('border-ink', 'bg-oat/60'); }));
    ['dragleave', 'drop'].forEach((evt) =>
      drop.addEventListener(evt, (e) => { e.preventDefault(); drop.classList.remove('border-ink', 'bg-oat/60'); }));
    drop.addEventListener('drop', (e) => uploadFile(e.dataTransfer?.files?.[0]));

    // Influencer link generator
    $('ref-make').addEventListener('click', () => {
      const name = $('ref-name').value.trim().toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
      if (!name) return;
      const link = `${window.location.origin}/?ref=${encodeURIComponent(name)}`;
      $('ref-link').textContent = link;
      show('ref-result');
    });
    $('ref-copy').addEventListener('click', () => navigator.clipboard?.writeText($('ref-link').textContent || ''));

    // ---- Auth ----

    // ---- Kodebasert admin-innlogging (hovedløsning: brukernavn + passord) ----
    // En enkel, pålitelig innlogging som snakker med /api/admin/* og setter en
    // httpOnly øktcookie på serveren. Brukernavn/passord ligger i
    // netlify/lib/temp-admin.mts. Fungerer uavhengig av Netlify Identity.

    // Sjekk om en gyldig admin-cookie allerede finnes.
    async function isTempAdmin() {
      try {
        const res = await fetch('/api/admin/session');
        if (!res.ok) return false;
        const data = await res.json();
        return !!data.authenticated;
      } catch (e) {
        return false;
      }
    }

    // Vis dashbordet for en innlogget (midlertidig) admin.
    async function enterDashboard(label) {
      $('admin-email').textContent = label || '';
      show('logout-btn');
      showOnly('admin-view');
      await loadProducts();
    }

    // Logg inn med kodebasert brukernavn + passord.
    $('temp-login-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      hide('temp-login-error');
      try {
        const res = await fetch('/api/admin/login', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ username: $('temp-username').value, password: $('temp-password').value }),
        });
        if (!res.ok) throw new Error('bad credentials');
        $('temp-password').value = '';
        await enterDashboard($('temp-username').value || 'Admin');
      } catch (err) {
        $('temp-login-error').textContent = 'Feil brukernavn eller passord. Prøv igjen.';
        show('temp-login-error');
      }
    });

    // Bytt til/fra den fulle Netlify Identity-innloggingen.
    $('use-identity').addEventListener('click', () => showOnly('login-view'));
    $('back-to-temp').addEventListener('click', () => showOnly('temp-login-view'));

    // Logout from the dashboard and the "no access" screen. Clears BOTH the
    // temporary session cookie and any Netlify Identity session, then reloads.
    async function doLogout() {
      try { await fetch('/api/admin/logout', { method: 'POST' }); } catch (e) {}
      try { await logout(); } catch (e) {}
      location.assign('/admin');
    }
    $('logout-btn').addEventListener('click', doLogout);
    $('noaccess-logout').addEventListener('click', doLogout);

    // Login
    $('login-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      hide('login-error');
      try {
        await login($('login-email').value, $('login-password').value);
        await boot();
      } catch (err) {
        const el = $('login-error');
        el.textContent = authMessage(err);
        show('login-error');
      }
    });

    // Switch between login and "forgot password".
    $('forgot-link').addEventListener('click', () => {
      hide('login-error');
      $('forgot-email').value = $('login-email').value;
      hide('forgot-msg');
      showOnly('forgot-view');
    });
    $('back-to-login').addEventListener('click', () => showOnly('login-view'));

    // Request a recovery email.
    $('forgot-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const el = $('forgot-msg');
      try {
        await requestPasswordRecovery($('forgot-email').value.trim());
        el.textContent = 'Sjekk e-posten din for en lenke til å sette nytt passord.';
        el.className = 'text-sm text-ink';
        show('forgot-msg');
      } catch (err) {
        el.textContent = authMessage(err);
        el.className = 'text-sm text-clay';
        show('forgot-msg');
      }
    });

    // Set a new password — used for both recovery and invite acceptance.
    // resetMode is 'recovery' (user already logged in via the callback) or
    // 'invite' (we hold a token and must redeem it together with the password).
    let resetMode = 'recovery';
    let inviteToken = null;

    function showResetView(mode, { email, title, sub } = {}) {
      resetMode = mode;
      $('reset-title').textContent = title || 'Sett nytt passord';
      $('reset-sub').textContent = sub || (email ? `Velg et nytt passord for ${email}.` : 'Velg et nytt passord for kontoen din.');
      hide('reset-error');
      $('reset-form').reset();
      showOnly('reset-view');
    }

    $('reset-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      hide('reset-error');
      const pw = $('reset-password').value;
      const pw2 = $('reset-password2').value;
      const el = $('reset-error');
      if (pw.length < 8) { el.textContent = 'Passordet må være minst 8 tegn.'; show('reset-error'); return; }
      if (pw !== pw2) { el.textContent = 'Passordene er ikke like.'; show('reset-error'); return; }
      try {
        if (resetMode === 'invite') {
          await acceptInvite(inviteToken, pw);
        } else {
          await updateUser({ password: pw });
        }
        inviteToken = null;
        await boot();
      } catch (err) {
        el.textContent = authMessage(err);
        show('reset-error');
      }
    });

    // Route an authenticated user to the dashboard, the "no access" screen, or
    // the login form — the single source of truth for what the page shows.
    async function boot() {
      // getUser kan kaste hvis Identity ikke er aktivert – da faller vi pent
      // tilbake til den midlertidige passord-innloggingen.
      let user = null;
      try { user = await getUser(); } catch (e) { user = null; }
      if (!user) {
        // Ingen Identity-bruker: vis den midlertidige passord-innloggingen som standard.
        showOnly('temp-login-view');
        hide('logout-btn');
        $('admin-email').textContent = '';
        return;
      }
      $('admin-email').textContent = user.email || '';
      show('logout-btn');
      if (!user.roles?.includes('admin')) { showOnly('noaccess-view'); return; }
      showOnly('admin-view');
      await loadProducts();
    }

    // On page load, redeem any token in the URL hash (recovery, invite,
    // confirmation, email change) BEFORE deciding which view to show. This is
    // what makes the emailed recovery and invite links actually work.
    async function init() {
      // Kodebasert admin: er øktcookien allerede gyldig? Gå rett inn.
      if (await isTempAdmin()) {
        await enterDashboard('Admin');
        return;
      }

      let routed = false;
      try {
        const result = await handleAuthCallback();
        if (result?.type === 'recovery') {
          showResetView('recovery', { email: result.user?.email });
          routed = true;
        } else if (result?.type === 'invite') {
          inviteToken = result.token;
          showResetView('invite', { title: 'Velkommen', sub: 'Velg et passord for å fullføre kontoen din.' });
          routed = true;
        }
        // 'confirmation' / 'email_change' / 'oauth' log the user in; boot() handles them.
      } catch (err) {
        if (window.location.hash) {
          // Kom hit fra en e-postlenke (recovery/invite) med en ugyldig/brukt
          // token: vis Identity-innloggingen med kontekst.
          showOnly('login-view');
          $('login-error').textContent = authMessage(err);
          show('login-error');
          routed = true;
        }
        // Ellers (f.eks. Identity ikke aktivert): la boot() vise den
        // midlertidige passord-innloggingen som standard.
      }

      // Strip the hash so a refresh can't try to reuse a one-time token.
      if (window.location.hash) {
        history.replaceState(null, '', window.location.pathname + window.location.search);
      }

      if (!routed) await boot();
    }

    init();
  </script>
</Base>
