  <script>
    import {
      login, logout, getUser,
      requestPasswordRecovery, handleAuthCallback, updateUser, acceptInvite,
      AuthError, MissingIdentityError,
    } from '@netlify/identity';

    const nok = new Intl.NumberFormat('nb-NO', { style: 'currency', currency: 'NOK', maximumFractionDigits: 0 });
    const $ = (id) => document.getElementById(id);
    const show = (id) => $(id).classList.remove('hidden');
    const hide = (id) => $(id).classList.add('hidden');

    // The mutually-exclusive top-level views. Only one is ever visible.
    const VIEWS = ['temp-login-view', 'login-view', 'forgot-view', 'reset-view', 'noaccess-view', 'admin-view'];
    function showOnly(view) { VIEWS.forEach((v) => (v === view ? show(v) : hide(v))); }

    // Turn an identity error into a human message without leaking which field was wrong.
    function authMessage(err) {
      if (err instanceof MissingIdentityError) return 'Identity er ikke aktivert. Kjør «netlify dev» eller aktiver Identity i prosjektet.';
      if (err instanceof AuthError) {
        if (err.status === 401) return 'Feil e-post eller passord.';
        if (err.status === 403) return 'Handlingen er ikke tillatt for denne kontoen.';
        if (err.status === 422) return 'Ugyldig inndata. Sjekk e-post og passord (minst 8 tegn).';
        if (err.status === 404) return 'Fant ingen konto for denne e-posten.';
        return err.message || 'Noe gikk galt. Prøv igjen.';
      }
      return err?.message || 'Noe gikk galt. Prøv igjen.';
    }

    function escapeHtml(s) {
      return String(s ?? '').replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));
    }

    async function api(path, options = {}) {
      const res = await fetch(path, { ...options, headers: { 'Content-Type': 'application/json', ...(options.headers || {}) } });
      return res;
    }

    function renderList(products) {
      const list = $('product-list');
      if (!products.length) { list.innerHTML = '<p class="text-sm text-stone">Ingen produkter ennå.</p>'; return; }
      list.innerHTML = products.map((p) => `
        <div class="flex items-center gap-4 bg-paper border border-ink/10 p-4">
          <img src="${escapeHtml(p.image_url)}" alt="" class="h-16 w-16 object-cover bg-oat" />
          <div class="flex-1 min-w-0">
            <p class="font-serif text-lg text-ink truncate">${escapeHtml(p.name)} ${p.active ? '' : '<span class="text-[10px] uppercase tracking-widest text-clay">(skjult)</span>'}</p>
            <p class="text-[10px] uppercase tracking-wider text-stone">${escapeHtml(p.producer || '')} · ${nok.format(Number(p.price_nok))} · /${escapeHtml(p.slug)}</p>
            ${p.producer_email ? `<p class="text-[10px] uppercase tracking-wider text-stone/70">✉ ${escapeHtml(p.producer_email)}</p>` : '<p class="text-[10px] uppercase tracking-wider text-clay">Mangler produsent e-post</p>'}
          </div>
          <button type="button" data-edit="${escapeHtml(p.slug)}" class="text-[10px] uppercase tracking-widest text-stone hover:text-ink">Rediger</button>
          <button type="button" data-del="${escapeHtml(p.slug)}" class="text-[10px] uppercase tracking-widest text-clay hover:opacity-70">Slett</button>
        </div>`).join('');

      list.querySelectorAll('[data-edit]').forEach((b) => b.addEventListener('click', () => startEdit(products.find((x) => x.slug === b.dataset.edit))));
      list.querySelectorAll('[data-del]').forEach((b) => b.addEventListener('click', () => del(b.dataset.del)));
    }

    let cache = [];
    async function loadProducts() {
      const res = await api('/api/admin/products');
      if (!res.ok) return;
      const data = await res.json();
      cache = data.products || [];
      renderList(cache);
    }

    // ---- Ordrehistorikk ----

    // Menneskelig etikett + farge for ordrens e-poststatus.
    function orderStatus(status) {
      if (status === 'emailed') return { label: 'E-post sendt', cls: 'text-ink' };
      if (status === 'email-failed') return { label: 'E-post feilet', cls: 'text-clay' };
      return { label: status || 'Mottatt', cls: 'text-stone' };
    }

    function renderOrders(orders) {
      const list = $('orders-list');
      if (!orders.length) { list.innerHTML = '<p class="text-sm text-stone">Ingen ordrer ennå.</p>'; return; }
      const fmtDate = (s) => { try { return new Date(s).toLocaleString('nb-NO', { dateStyle: 'medium', timeStyle: 'short' }); } catch { return s || ''; } };
      list.innerHTML = orders.map((o) => {
        const st = orderStatus(o.status);
        const amount = Number.isFinite(o.amount) ? nok.format(o.amount) : '';
        return `
        <details class="bg-paper border border-ink/10">
          <summary class="flex items-center gap-4 p-4 cursor-pointer list-none">
            <div class="flex-1 min-w-0">
              <p class="font-serif text-lg text-ink truncate">${escapeHtml(o.product)} · ${escapeHtml(amount)}</p>
              <p class="text-[10px] uppercase tracking-wider text-stone">${escapeHtml(fmtDate(o.created_at))} · ${escapeHtml(o.customer_name || o.customer_email || 'Ukjent kunde')}${o.curator ? ` · henvist av ${escapeHtml(o.curator)}` : ''}</p>
            </div>
            <span class="text-[10px] uppercase tracking-widest ${st.cls} whitespace-nowrap">${escapeHtml(st.label)}</span>
          </summary>
          <div class="border-t border-ink/10 px-4 py-4 text-sm text-stone space-y-1">
            <p><span class="text-[10px] uppercase tracking-wider text-stone/70">Ordrenr</span> <span class="text-ink break-all">${escapeHtml(o.order_id)}</span></p>
            ${o.customer_email ? `<p><span class="text-[10px] uppercase tracking-wider text-stone/70">Kunde</span> <span class="text-ink">${escapeHtml(o.customer_name || '')} · ${escapeHtml(o.customer_email)}</span></p>` : ''}
            ${o.customer_phone ? `<p><span class="text-[10px] uppercase tracking-wider text-stone/70">Telefon</span> <span class="text-ink">${escapeHtml(o.customer_phone)}</span></p>` : ''}
            ${o.producer_email ? `<p><span class="text-[10px] uppercase tracking-wider text-stone/70">Produsent</span> <span class="text-ink">${escapeHtml(o.producer_email)}</span></p>` : ''}
            ${o.shipping_address ? `<p><span class="text-[10px] uppercase tracking-wider text-stone/70">Leveres til</span><br /><span class="text-ink whitespace-pre-line">${escapeHtml(o.shipping_address)}</span></p>` : ''}
          </div>
        </details>`;
      }).join('');
    }

    async function loadOrders() {
      const list = $('orders-list');
      try {
        const res = await api('/api/admin/orders');
        if (!res.ok) { list.innerHTML = '<p class="text-sm text-clay">Kunne ikke laste ordrer.</p>'; return; }
        const data = await res.json();
        renderOrders(data.orders || []);
      } catch (e) {
        list.innerHTML = '<p class="text-sm text-clay">Kunne ikke laste ordrer.</p>';
      }
    }

    // ---- Leads (Private Circle) ----

