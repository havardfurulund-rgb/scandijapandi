          <thead><tr class="text-left border-b border-ink/10">
            <th class="py-3 pr-4 text-[10px] uppercase tracking-widest text-stone font-medium">Navn</th>
            <th class="py-3 pr-4 text-[10px] uppercase tracking-widest text-stone font-medium">Mediehus</th>
            <th class="py-3 pr-4 text-[10px] uppercase tracking-widest text-stone font-medium">E-post</th>
