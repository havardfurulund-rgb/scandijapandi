    function showOutreachCategory(cat) {
      document.querySelectorAll('.outreach-category').forEach(el => el.classList.add('hidden'));
      document.querySelectorAll('.outreach-tab').forEach(el => {
        el.classList.remove('bg-ink', 'text-paper');
      });
      document.getElementById(`ot-${cat}`)?.classList.remove('hidden');
      document.getElementById(`ot-tab-${cat}`)?.classList.add('bg-ink', 'text-paper');
    }

    function toggleOutreachTemplate(id) {
      const el = document.getElementById(id);
      if (el) el.classList.toggle('hidden');
    }

    async function copyOutreach(id) {
      const el = document.getElementById(id);
      if (!el) return;
      const text = (el as HTMLElement).innerText || el.textContent || '';
      try {
        await navigator.clipboard.writeText(text);
        // Brief visual feedback
        const btn = el.previousElementSibling?.querySelector('button');
        if (btn) {
          const orig = btn.textContent;
          btn.textContent = '✓ Kopiert';
          setTimeout(() => { btn.textContent = orig; }, 2000);
        }
      } catch {
        // Fallback
        const range = document.createRange();
        range.selectNode(el);
        window.getSelection()?.removeAllRanges();
        window.getSelection()?.addRange(range);
      }
    }

    // Expose globally for inline onclick handlers
    (window as any).showOutreachCategory = showOutreachCategory;
    (window as any).toggleOutreachTemplate = toggleOutreachTemplate;
    (window as any).copyOutreach = copyOutreach;

