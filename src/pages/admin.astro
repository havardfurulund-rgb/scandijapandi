---
import Base from '../layouts/Base.astro';
---

<Base title="Admin — ScandiJapandi">
  <header class="border-b border-ink/10 bg-paper">
    <div class="mx-auto flex h-20 max-w-5xl items-center justify-between px-6">
      <a href="/" class="font-serif text-xl tracking-tight">ScandiJapandi</a>
      <div class="flex items-center gap-6 text-[10px] font-medium uppercase tracking-widest text-stone">
        <span>Admin</span>
        <span id="admin-email" class="text-ink"></span>
        <button id="logout-btn" type="button" class="hidden hover:text-ink transition-colors">Logg ut</button>
      </div>
    </div>
  </header>

  <main class="mx-auto max-w-5xl px-6 py-16">
    <!-- Primær admin-innlogging (kodebasert: brukernavn + passord) -->
    <section id="temp-login-view" class="hidden max-w-md mx-auto">
      <span class="text-[10px] font-medium uppercase tracking-widest text-stone block mb-3">Tilgang</span>
      <h1 class="font-serif text-3xl text-ink">Logg inn på admin</h1>
      <p class="mt-3 text-sm text-stone font-light">Skriv inn brukernavn og passord for å administrere butikken.</p>
      <form id="temp-login-form" class="mt-8 space-y-5 bg-oat/60 p-8 border border-ink/5">
        <label class="block">
          <span class="text-[10px] uppercase tracking-widest text-stone">Brukernavn</span>
          <input type="text" id="temp-username" autocomplete="username" required class="mt-2 w-full bg-paper p-4 border border-ink/10 focus:border-ink outline-none" />
        </label>
        <label class="block">
          <span class="text-[10px] uppercase tracking-widest text-stone">Passord</span>
          <input type="password" id="temp-password" autocomplete="current-password" required class="mt-2 w-full bg-paper p-4 border border-ink/10 focus:border-ink outline-none" />
        </label>
        <button type="submit" class="w-full bg-ink text-paper py-4 uppercase text-[10px] font-medium tracking-widest transition-colors hover:bg-clay">Logg inn</button>
        <p id="temp-login-error" class="hidden text-sm text-clay"></p>
        <button type="button" id="use-identity" class="block w-full text-center text-[10px] uppercase tracking-widest text-stone hover:text-ink transition-colors">
          Bruk Netlify Identity i stedet
        </button>
      </form>
    </section>

    <!-- Login -->
    <section id="login-view" class="hidden max-w-md mx-auto">
      <span class="text-[10px] font-medium uppercase tracking-widest text-stone block mb-3">Tilgang</span>
      <h1 class="font-serif text-3xl text-ink">Logg inn på admin</h1>
      <p class="mt-3 text-sm text-stone font-light">Administrer produkter, priser og influenser-lenker.</p>
      <form id="login-form" class="mt-8 space-y-5 bg-oat/60 p-8 border border-ink/5">
        <label class="block">
          <span class="text-[10px] uppercase tracking-widest text-stone">E-post</span>
          <input type="email" id="login-email" autocomplete="username" required class="mt-2 w-full bg-paper p-4 border border-ink/10 focus:border-ink outline-none" />
        </label>
        <label class="block">
          <span class="text-[10px] uppercase tracking-widest text-stone">Passord</span>
          <input type="password" id="login-password" autocomplete="current-password" required class="mt-2 w-full bg-paper p-4 border border-ink/10 focus:border-ink outline-none" />
        </label>
        <button type="submit" class="w-full bg-ink text-paper py-4 uppercase text-[10px] font-medium tracking-widest transition-colors hover:bg-clay">Logg inn</button>
        <p id="login-error" class="hidden text-sm text-clay"></p>
        <button type="button" id="forgot-link" class="block w-full text-center text-[10px] uppercase tracking-widest text-stone hover:text-ink transition-colors">
          Glemt passordet?
        </button>
        <button type="button" id="back-to-temp" class="block w-full text-center text-[10px] uppercase tracking-widest text-stone hover:text-ink transition-colors">
          ← Tilbake til passord-innlogging
        </button>
      </form>
    </section>

    <!-- Forgot password -->
    <section id="forgot-view" class="hidden max-w-md mx-auto">
      <span class="text-[10px] font-medium uppercase tracking-widest text-stone block mb-3">Tilbakestilling</span>
      <h1 class="font-serif text-3xl text-ink">Glemt passordet?</h1>
      <p class="mt-3 text-sm text-stone font-light">Skriv inn e-posten din, så sender vi deg en lenke for å sette et nytt passord.</p>
      <form id="forgot-form" class="mt-8 space-y-5 bg-oat/60 p-8 border border-ink/5">
        <label class="block">
          <span class="text-[10px] uppercase tracking-widest text-stone">E-post</span>
          <input type="email" id="forgot-email" autocomplete="username" required class="mt-2 w-full bg-paper p-4 border border-ink/10 focus:border-ink outline-none" />
        </label>
        <button type="submit" class="w-full bg-ink text-paper py-4 uppercase text-[10px] font-medium tracking-widest transition-colors hover:bg-clay">Send tilbakestillingslenke</button>
        <p id="forgot-msg" class="hidden text-sm"></p>
        <button type="button" id="back-to-login" class="block w-full text-center text-[10px] uppercase tracking-widest text-stone hover:text-ink transition-colors">
          ← Tilbake til innlogging
        </button>
      </form>
    </section>

    <!-- Set new password (recovery + invite) -->
    <section id="reset-view" class="hidden max-w-md mx-auto">
      <span class="text-[10px] font-medium uppercase tracking-widest text-stone block mb-3">Sikkerhet</span>
      <h1 id="reset-title" class="font-serif text-3xl text-ink">Sett nytt passord</h1>
      <p id="reset-sub" class="mt-3 text-sm text-stone font-light">Velg et nytt passord for kontoen din.</p>
      <form id="reset-form" class="mt-8 space-y-5 bg-oat/60 p-8 border border-ink/5">
        <label class="block">
          <span class="text-[10px] uppercase tracking-widest text-stone">Nytt passord</span>
          <input type="password" id="reset-password" autocomplete="new-password" minlength="8" required class="mt-2 w-full bg-paper p-4 border border-ink/10 focus:border-ink outline-none" />
        </label>
        <label class="block">
          <span class="text-[10px] uppercase tracking-widest text-stone">Bekreft passord</span>
          <input type="password" id="reset-password2" autocomplete="new-password" minlength="8" required class="mt-2 w-full bg-paper p-4 border border-ink/10 focus:border-ink outline-none" />
        </label>
        <button type="submit" class="w-full bg-ink text-paper py-4 uppercase text-[10px] font-medium tracking-widest transition-colors hover:bg-clay">Lagre passord</button>
        <p id="reset-error" class="hidden text-sm text-clay"></p>
      </form>
    </section>

    <!-- No access -->
    <section id="noaccess-view" class="hidden max-w-md mx-auto text-center">
      <h1 class="font-serif text-3xl text-ink">Ingen admin-tilgang</h1>
      <p class="mt-3 text-sm text-stone font-light">
        Kontoen din mangler <code class="bg-oat px-1">admin</code>-rollen. En administrator må tildele rollen
        i Netlify Identity før du får tilgang.
      </p>
      <button type="button" id="noaccess-logout" class="mt-8 text-[10px] uppercase tracking-widest text-stone hover:text-ink transition-colors">Logg ut</button>
    </section>

    <!-- Admin dashboard -->
    <section id="admin-view" class="hidden">
      <div class="flex items-baseline justify-between mb-10">
        <div>
          <span class="text-[10px] font-medium uppercase tracking-widest text-stone block mb-2">Katalog</span>
          <h1 class="font-serif text-3xl text-ink">Produkter</h1>
        </div>
      </div>

      <!-- Add / edit product -->
      <form id="product-form" class="bg-oat/60 p-8 border border-ink/5 mb-12 space-y-8">
        <h2 id="form-title" class="font-serif text-xl text-ink">Nytt produkt</h2>
        <input type="hidden" id="edit-slug" value="" />

        <!-- ── Grunnleggende info ── -->
        <fieldset class="space-y-5">
          <legend class="text-[10px] uppercase tracking-widest text-stone mb-4 block">Grunnleggende</legend>
          <div class="grid sm:grid-cols-2 gap-5">
            <label class="block">
              <span class="text-[10px] uppercase tracking-widest text-stone">Navn (NO) *</span>
              <input type="text" id="p-name" required class="mt-2 w-full bg-paper p-4 border border-ink/10 focus:border-ink outline-none" />
            </label>
            <label class="block">
              <span class="text-[10px] uppercase tracking-widest text-stone">Navn (EN)</span>
              <input type="text" id="p-name-en" class="mt-2 w-full bg-paper p-4 border border-ink/10 focus:border-ink outline-none" />
            </label>
            <label class="block sm:col-span-2">
              <span class="text-[10px] uppercase tracking-widest text-stone">Navn (JP 日本語)</span>
              <input type="text" id="p-name-jp" class="mt-2 w-full bg-paper p-4 border border-ink/10 focus:border-ink outline-none" placeholder="例：ハーダンゲルのウールセーター" />
            </label>
            <label class="block sm:col-span-2">
              <span class="text-[10px] uppercase tracking-widest text-stone">Slug (URL) — auto-genereres fra navn om tomt</span>
              <input type="text" id="p-slug-edit" class="mt-2 w-full bg-paper p-4 border border-ink/10 focus:border-ink outline-none font-mono text-sm" placeholder="produkt-navn-her" />
            </label>
          </div>
          <div class="grid sm:grid-cols-2 gap-5">
            <label class="block">
              <span class="text-[10px] uppercase tracking-widest text-stone">Produsent</span>
              <input type="text" id="p-producer" class="mt-2 w-full bg-paper p-4 border border-ink/10 focus:border-ink outline-none" />
            </label>
            <label class="block">
              <span class="text-[10px] uppercase tracking-widest text-stone">Produsent e-post *</span>
              <input type="email" id="p-producer-email" required autocomplete="off" placeholder="produsent@eksempel.no" class="mt-2 w-full bg-paper p-4 border border-ink/10 focus:border-ink outline-none" />
            </label>
            <label class="block">
              <span class="text-[10px] uppercase tracking-widest text-stone">Pris (NOK) *</span>
              <input type="number" id="p-price" min="0" step="1" required class="mt-2 w-full bg-paper p-4 border border-ink/10 focus:border-ink outline-none" />
            </label>
            <label class="block">
              <span class="text-[10px] uppercase tracking-widest text-stone">Pris (JPY ¥)</span>
              <input type="number" id="p-price-jpy" min="0" step="1" class="mt-2 w-full bg-paper p-4 border border-ink/10 focus:border-ink outline-none" placeholder="0" />
            </label>
            <label class="block">
              <span class="text-[10px] uppercase tracking-widest text-stone">Stripe Payment Link (valgfritt)</span>
              <input type="url" id="p-stripe-link" class="mt-2 w-full bg-paper p-4 border border-ink/10 focus:border-ink outline-none" placeholder="https://buy.stripe.com/..." />
            </label>
            <label class="block">
              <span class="text-[10px] uppercase tracking-widest text-stone">Antall på lager (blank = ubegrenset)</span>
              <input type="number" id="p-stock" min="0" step="1" class="mt-2 w-full bg-paper p-4 border border-ink/10 focus:border-ink outline-none" placeholder="f.eks. 3" />
            </label>
            <label class="block">
              <span class="text-[10px] uppercase tracking-widest text-stone">Vekt (gram) — for frakt</span>
              <input type="number" id="p-weight-grams" min="0" step="1" class="mt-2 w-full bg-paper p-4 border border-ink/10 focus:border-ink outline-none" placeholder="f.eks. 450" />
            </label>
            <label class="block">
              <span class="text-[10px] uppercase tracking-widest text-stone">Produksjonsland (for toll)</span>
              <input type="text" id="p-country-of-origin" class="mt-2 w-full bg-paper p-4 border border-ink/10 focus:border-ink outline-none" placeholder="Norge" />
            </label>
          </div>
        </fieldset>

        <!-- ── Produktbilde ── -->
        <fieldset class="space-y-3">
          <legend class="text-[10px] uppercase tracking-widest text-stone mb-2 block">Produktbilde</legend>
          <input type="hidden" id="p-image" value="" />
          <input type="file" id="p-image-file" accept="image/jpeg,image/png,image/webp,image/gif,image/avif,image/svg+xml" class="hidden" />
          <div id="p-image-drop" class="flex items-center gap-5 border border-dashed border-ink/15 bg-paper/60 p-4 transition-colors">
            <div id="p-image-preview-wrap" class="hidden relative shrink-0">
              <img id="p-image-preview" src="" alt="Forhåndsvisning" class="h-24 w-24 object-cover bg-oat border border-ink/10" />
              <button type="button" id="p-image-remove" title="Fjern bilde" aria-label="Fjern bilde" class="absolute -top-2 -right-2 flex h-6 w-6 items-center justify-center rounded-full bg-ink text-paper text-sm leading-none transition-colors hover:bg-clay">×</button>
            </div>
            <div id="p-image-placeholder" class="flex h-24 w-24 shrink-0 items-center justify-center bg-oat/60 text-center text-[10px] uppercase tracking-widest text-stone">Ingen<br />bilde</div>
            <div class="flex-1 min-w-0">
              <button type="button" id="p-image-upload" class="border border-ink/20 px-6 py-3 uppercase text-[10px] font-medium tracking-widest transition-colors hover:border-ink">Last opp bilde</button>
              <p class="mt-2 text-[11px] text-stone font-light">Dra og slipp, eller velg en fil. JPG, PNG, WebP — maks 5 MB.</p>
              <p id="p-image-status" class="hidden mt-1 text-[11px]"></p>
            </div>
          </div>
          <div class="mt-4 space-y-2">
            <span class="text-[10px] uppercase tracking-widest text-stone block">Galleribilder — URL-er (opptil 4 ekstra bilder)</span>
            <input type="url" id="p-gallery-1" class="w-full bg-paper p-3 border border-ink/10 focus:border-ink outline-none text-sm" placeholder="https://... (bilde 2)" />
            <input type="url" id="p-gallery-2" class="w-full bg-paper p-3 border border-ink/10 focus:border-ink outline-none text-sm" placeholder="https://... (bilde 3)" />
            <input type="url" id="p-gallery-3" class="w-full bg-paper p-3 border border-ink/10 focus:border-ink outline-none text-sm" placeholder="https://... (bilde 4)" />
            <input type="url" id="p-gallery-4" class="w-full bg-paper p-3 border border-ink/10 focus:border-ink outline-none text-sm" placeholder="https://... (bilde 5)" />
          </div>
        </fieldset>

        <!-- ── Beskrivelser ── -->
        <fieldset class="space-y-5">
          <legend class="text-[10px] uppercase tracking-widest text-stone mb-2 block">Beskrivelse</legend>
          <label class="block">
            <span class="text-[10px] uppercase tracking-widest text-stone">Beskrivelse (NO)</span>
            <textarea id="p-description" rows="2" class="mt-2 w-full bg-paper p-4 border border-ink/10 focus:border-ink outline-none"></textarea>
          </label>
          <label class="block">
            <span class="text-[10px] uppercase tracking-widest text-stone">Beskrivelse (EN)</span>
            <textarea id="p-description-en" rows="2" class="mt-2 w-full bg-paper p-4 border border-ink/10 focus:border-ink outline-none"></textarea>
          </label>
          <label class="block">
            <span class="text-[10px] uppercase tracking-widest text-stone">Beskrivelse (JP 日本語)</span>
            <textarea id="p-description-jp" rows="2" class="mt-2 w-full bg-paper p-4 border border-ink/10 focus:border-ink outline-none"></textarea>
          </label>
        </fieldset>

        <!-- ── Historiefortelling ── -->
        <fieldset class="space-y-5">
          <legend class="text-[10px] uppercase tracking-widest text-stone mb-2 flex items-center justify-between">
            <span>Historiefortelling</span>
            <button type="button" id="btn-translate" class="flex items-center gap-2 border border-ink/20 px-4 py-2 text-[10px] uppercase tracking-widest hover:border-ink transition-colors">
              <span id="translate-icon">✦</span>
              <span id="translate-label">Oversett automatisk (NO → EN + JP)</span>
            </button>
          </legend>
          <p id="translate-status" class="hidden text-[11px] text-stone"></p>
          <div class="space-y-3">
            <label class="block">
              <span class="text-[10px] uppercase tracking-widest text-stone">Objektets historie (NO) — vises som sitat</span>
              <textarea id="p-origin-story" rows="3" class="mt-2 w-full bg-paper p-4 border border-ink/10 focus:border-ink outline-none" placeholder="Hva gjør dette objektet unikt?"></textarea>
            </label>
            <label class="block">
              <span class="text-[10px] uppercase tracking-widest text-stone">Objektets historie (EN)</span>
              <textarea id="p-origin-story-en" rows="3" class="mt-2 w-full bg-paper p-4 border border-ink/10 focus:border-ink outline-none bg-oat/40"></textarea>
            </label>
            <label class="block">
              <span class="text-[10px] uppercase tracking-widest text-stone">Objektets historie (JP 日本語)</span>
              <textarea id="p-origin-story-jp" rows="3" class="mt-2 w-full bg-paper p-4 border border-ink/10 focus:border-ink outline-none bg-oat/40"></textarea>
            </label>
          </div>
        </fieldset>

        <!-- ── Produsenthistorie ── -->
        <fieldset class="space-y-5">
          <legend class="text-[10px] uppercase tracking-widest text-stone mb-2 block">Produsenten</legend>
          <div class="grid sm:grid-cols-2 gap-5">
            <label class="block">
              <span class="text-[10px] uppercase tracking-widest text-stone">Sted (f.eks. Hardanger, Norge)</span>
              <input type="text" id="p-producer-location" class="mt-2 w-full bg-paper p-4 border border-ink/10 focus:border-ink outline-none" placeholder="Hardanger, Norge" />
            </label>
            <label class="block">
              <span class="text-[10px] uppercase tracking-widest text-stone">Produsent portrettbilde URL</span>
              <input type="url" id="p-producer-image-url" class="mt-2 w-full bg-paper p-4 border border-ink/10 focus:border-ink outline-none" placeholder="https://..." />
            </label>
          </div>
          <label class="block">
            <span class="text-[10px] uppercase tracking-widest text-stone">Produsenthistorie — vises under produktet</span>
            <textarea id="p-producer-story" rows="4" class="mt-2 w-full bg-paper p-4 border border-ink/10 focus:border-ink outline-none" placeholder="Hvem er produsenten? Hva driver dem? Hva gjør håndverket deres spesielt?"></textarea>
          </label>
          <label class="block">
            <span class="text-[10px] uppercase tracking-widest text-stone">Produsenthistorie (EN)</span>
            <textarea id="p-producer-story-en" rows="3" class="mt-2 w-full bg-paper p-4 border border-ink/10 focus:border-ink outline-none bg-oat/40"></textarea>
          </label>
          <label class="block">
            <span class="text-[10px] uppercase tracking-widest text-stone">Produsenthistorie (JP 日本語)</span>
            <textarea id="p-producer-story-jp" rows="3" class="mt-2 w-full bg-paper p-4 border border-ink/10 focus:border-ink outline-none bg-oat/40"></textarea>
          </label>
        </fieldset>

        <!-- ── Produktdetaljer ── -->
        <fieldset class="space-y-5">
          <legend class="text-[10px] uppercase tracking-widest text-stone mb-2 block">Produktdetaljer</legend>
          <div class="grid sm:grid-cols-2 gap-5">
            <label class="block">
              <span class="text-[10px] uppercase tracking-widest text-stone">Materiale</span>
              <input type="text" id="p-material" class="mt-2 w-full bg-paper p-4 border border-ink/10 focus:border-ink outline-none" placeholder="100% norsk ull" />
            </label>
            <label class="block">
              <span class="text-[10px] uppercase tracking-widest text-stone">Materiale (EN)</span>
              <input type="text" id="p-material-en" class="mt-2 w-full bg-paper p-4 border border-ink/10 focus:border-ink outline-none bg-oat/40" />
            </label>
            <label class="block">
              <span class="text-[10px] uppercase tracking-widest text-stone">Materiale (JP)</span>
              <input type="text" id="p-material-jp" class="mt-2 w-full bg-paper p-4 border border-ink/10 focus:border-ink outline-none bg-oat/40" />
            </label>
            <label class="block">
              <span class="text-[10px] uppercase tracking-widest text-stone">Dimensjoner</span>
              <input type="text" id="p-dimensions" class="mt-2 w-full bg-paper p-4 border border-ink/10 focus:border-ink outline-none" placeholder="H 22 cm × Ø 14 cm" />
            </label>
          </div>
          <label class="block">
            <span class="text-[10px] uppercase tracking-widest text-stone">Vedlikehold</span>
            <input type="text" id="p-care" class="mt-2 w-full bg-paper p-4 border border-ink/10 focus:border-ink outline-none" placeholder="Håndvask, 30°C" />
          </label>
          <label class="block">
            <span class="text-[10px] uppercase tracking-widest text-stone">Vedlikehold (EN)</span>
            <input type="text" id="p-care-en" class="mt-2 w-full bg-paper p-4 border border-ink/10 focus:border-ink outline-none bg-oat/40" />
          </label>
          <label class="block">
            <span class="text-[10px] uppercase tracking-widest text-stone">Vedlikehold (JP)</span>
            <input type="text" id="p-care-jp" class="mt-2 w-full bg-paper p-4 border border-ink/10 focus:border-ink outline-none bg-oat/40" />
          </label>
        </fieldset>

        <!-- ── Status + lagre ── -->
        <div class="flex items-center justify-between pt-4 border-t border-ink/8">
          <label class="flex items-center gap-3 text-sm">
            <input type="checkbox" id="p-active" checked class="accent-clay" /> Aktiv (vises i butikken)
          </label>
          <div class="flex gap-4">
            <button type="button" id="cancel-edit" class="hidden border border-ink/20 px-8 py-3 uppercase text-[10px] font-medium tracking-widest hover:border-ink">Avbryt</button>
            <button type="submit" class="bg-ink text-paper px-8 py-3 uppercase text-[10px] font-medium tracking-widest transition-colors hover:bg-clay">Lagre produkt</button>
          </div>
        </div>
        <p id="product-msg" class="hidden text-sm"></p>
      </form>

      <div id="product-list" class="space-y-3"></div>

      <!-- Ordrehistorikk: ordrene fra Stripe, lagret av stripe-webhook -->
      <div class="mt-16">
        <div class="flex items-baseline justify-between mb-6">
          <div>
            <span class="text-[10px] font-medium uppercase tracking-widest text-stone block mb-2">Salg</span>
            <h2 class="font-serif text-2xl text-ink">Ordrehistorikk</h2>
          </div>
          <button type="button" id="orders-refresh" class="text-[10px] uppercase tracking-widest text-stone hover:text-ink transition-colors">Oppdater</button>
        </div>
        <div id="orders-list" class="space-y-3">
          <p class="text-sm text-stone">Laster ordrer …</p>
        </div>
      </div>

      <!-- Leads: Private Circle-påmeldinger fra forsiden (circle_leads) -->
      <div class="mt-16">
        <div class="flex items-baseline justify-between mb-6">
          <div>
            <span class="text-[10px] font-medium uppercase tracking-widest text-stone block mb-2">Private Circle</span>
            <h2 class="font-serif text-2xl text-ink">Leads</h2>
          </div>
          <button type="button" id="leads-refresh" class="text-[10px] uppercase tracking-widest text-stone hover:text-ink transition-colors">Oppdater</button>
        </div>

        <!-- Sammendragskort -->
        <div id="leads-summary" class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-6">
          <div class="bg-oat/60 border border-ink/5 p-5">
            <p class="text-[10px] uppercase tracking-widest text-stone mb-2">Total</p>
            <p id="leads-total" class="font-serif text-3xl text-ink">—</p>
          </div>
          <div class="bg-oat/60 border border-ink/5 p-5">
