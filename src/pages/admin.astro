          </tbody>
        </table>`;
      list.querySelectorAll('[data-pdr-send]').forEach((b) => b.addEventListener('click', () => pdrSend(b, b.dataset.pdrSend)));
    }

    async function loadProducers() {
      const list = $('pdr-list');
      try {
        const res = await api('/api/admin/kurator/producers');
        if (!res.ok) { list.innerHTML = '<p class="text-sm text-clay">Kunne ikke laste produsenter.</p>'; return; }
        const data = await res.json();
        renderProducers(data.producers || []);
      } catch { list.innerHTML = '<p class="text-sm text-clay">Kunne ikke laste produsenter.</p>'; }
    }

    async function pdrSend(btn, email) {
      if (!confirm(`Sende ukesrapport nå til ${email}?`)) return;
      const original = btn.textContent;
      btn.setAttribute('disabled', 'true'); btn.textContent = 'Sender …';
      try {
        const res = await api('/api/admin/kurator/send-producer-report', { method: 'POST', body: JSON.stringify({ producer_email: email }) });
        const data = await res.json().catch(() => ({}));
        btn.textContent = res.ok ? '✓ Sendt' : 'Feilet';
        if (!res.ok) console.error('[producer-report]', data.error);
      } catch (err) {
        console.error('[producer-report]', err); btn.textContent = 'Feilet';
      } finally {
        setTimeout(() => { btn.removeAttribute('disabled'); btn.textContent = original; }, 3000);
      }
    }

    // ─────────────────────────────────────────────────────────────────
    //  INFLUENSERE
    // ─────────────────────────────────────────────────────────────────
    function infBadge(status) {
      if (status === 'active') return '<span class="text-[10px] uppercase tracking-widest text-moss">Aktiv</span>';
      if (status === 'paused') return '<span class="text-[10px] uppercase tracking-widest text-clay">Pauset</span>';
      return '<span class="text-[10px] uppercase tracking-widest text-stone">Prospect</span>';
    }

    function renderInfluencers(rows) {
      const list = $('inf-list');
      if (!rows.length) { list.innerHTML = '<p class="text-sm text-stone">Ingen influensere ennå.</p>'; return; }
      list.innerHTML = `
        <table class="w-full text-sm border-collapse">
          <thead><tr class="text-left border-b border-ink/10">
            <th class="py-3 pr-4 text-[10px] uppercase tracking-widest text-stone font-medium">Navn / Handle</th>
            <th class="py-3 pr-4 text-[10px] uppercase tracking-widest text-stone font-medium">Platform</th>
            <th class="py-3 pr-4 text-[10px] uppercase tracking-widest text-stone font-medium">Ref-kode</th>
            <th class="py-3 pr-4 text-[10px] uppercase tracking-widest text-stone font-medium">Land</th>
            <th class="py-3 pr-4 text-[10px] uppercase tracking-widest text-stone font-medium">Status</th>
            <th class="py-3 pr-4 text-[10px] uppercase tracking-widest text-stone font-medium">Ordre</th>
            <th class="py-3 text-[10px] uppercase tracking-widest text-stone font-medium">Omsetning</th>
          </tr></thead>
          <tbody>
            ${rows.map((i) => `
              <tr class="border-b border-ink/5">
                <td class="py-3 pr-4 text-ink">${escapeHtml(i.name)}${i.handle ? ` <span class="text-stone">${escapeHtml(i.handle)}</span>` : ''}</td>
                <td class="py-3 pr-4 text-stone capitalize">${escapeHtml(i.platform || '—')}</td>
                <td class="py-3 pr-4 text-stone font-mono">${escapeHtml(i.ref_code || '—')}</td>
                <td class="py-3 pr-4 text-stone">${escapeHtml(i.country || '—')}</td>
                <td class="py-3 pr-4">${infBadge(i.status)}</td>
                <td class="py-3 pr-4 text-stone">${i.order_count || 0}</td>
                <td class="py-3 text-stone whitespace-nowrap">${nokMinor(i.total_revenue)}</td>
              </tr>`).join('')}
          </tbody>
        </table>`;
    }

    async function loadInfluencers() {
      const list = $('inf-list');
      try {
        const res = await api('/api/admin/kurator/influencers');
        if (!res.ok) { list.innerHTML = '<p class="text-sm text-clay">Kunne ikke laste influensere.</p>'; return; }
        const data = await res.json();
        renderInfluencers(data.influencers || []);
      } catch { list.innerHTML = '<p class="text-sm text-clay">Kunne ikke laste influensere.</p>'; }
    }

    function infReset() {
      ['inf-name','inf-handle','inf-email','inf-ref-code','inf-country','inf-commission','inf-notes'].forEach((id) => { $(id).value = ''; });
      $('inf-platform').value = 'instagram';
      $('inf-status').value = 'prospect';
    }
    $('inf-new')?.addEventListener('click', () => { infReset(); show('inf-form'); });
    $('inf-cancel')?.addEventListener('click', () => { hide('inf-form'); infReset(); });

    $('inf-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const commission = Number($('inf-commission').value);
      const payload = {
        name: $('inf-name').value.trim(),
        handle: $('inf-handle').value.trim() || null,
        platform: $('inf-platform').value,
        email: $('inf-email').value.trim() || null,
        ref_code: $('inf-ref-code').value.trim() || null,
        country: $('inf-country').value.trim() || 'JP',
        commission_pct: Number.isFinite(commission) && commission > 0 ? Math.round(commission) : 10,
        status: $('inf-status').value,
        notes: $('inf-notes').value.trim() || null,
      };
      const res = await api('/api/admin/kurator/influencers', { method: 'POST', body: JSON.stringify(payload) });
      if (res.ok) { hide('inf-form'); infReset(); await loadInfluencers(); }
      else kStatus('inf-status-msg', 'Kunne ikke lagre influenser.', false);
    });

    init();
  </script>
</Base>
