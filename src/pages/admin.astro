    async function loadPress() {
      try {
        const res = await api('/api/admin/kurator/press');
        if (!res.ok) { $('pr-list').innerHTML = '<p class="text-sm text-clay">Kunne ikke laste presse.</p>'; return; }
        const data = await res.json();
        renderReleases(data.releases || []);
        renderContacts(data.contacts || []);
      } catch { $('pr-list').innerHTML = '<p class="text-sm text-clay">Kunne ikke laste presse.</p>'; }
    }

