    async function loadPress() {
      try {
        const res = await api('/api/admin/kurator/press');
        if (!res.ok) { $('pr-list').innerHTML = '<p class="text-sm text-clay">Kunne ikke laste presse.</p>'; return; }
        const data = await res.json();
        renderReleases(data.releases || []);
        renderContacts(data.contacts || []);
      } catch { $('pr-list').innerHTML = '<p class="text-sm text-clay">Kunne ikke laste presse.</p>'; }
    }

    function prReset() {
      $('pr-id').value = '';
      ['pr-title','pr-title-en','pr-title-jp','pr-body-no','pr-body-en','pr-body-jp'].forEach((id) => { $(id).value = ''; });
    }
    $('pr-new')?.addEventListener('click', () => { prReset(); show('pr-form'); });
    $('pr-cancel')?.addEventListener('click', () => { hide('pr-form'); prReset(); });

    $('pr-translate')?.addEventListener('click', async () => {
      const r = await kTranslate($('pr-title').value.trim(), $('pr-body-no').value.trim(),
        'pr-translate', 'pr-translate-icon', 'pr-translate-label', (t) => {
          if (t.name_en) $('pr-title-en').value = t.name_en;
          if (t.name_jp) $('pr-title-jp').value = t.name_jp;
          if (t.description_en) $('pr-body-en').value = t.description_en;
          if (t.description_jp) $('pr-body-jp').value = t.description_jp;
        });
      if (r.error) kStatus('pr-status', r.error, false);
      else kStatus('pr-status', '✓ Oversettelse fullført — kontroller og lagre.', true);
    });

    function prPayload() {
      return {
        title: $('pr-title').value.trim(),
        title_en: $('pr-title-en').value.trim() || null,
        title_jp: $('pr-title-jp').value.trim() || null,
        body_no: $('pr-body-no').value.trim() || null,
        body_en: $('pr-body-en').value.trim() || null,
        body_jp: $('pr-body-jp').value.trim() || null,
      };
    }

    async function prSave(silent) {
      const p = prPayload();
      if (!p.title) { kStatus('pr-status', 'Skriv inn en tittel først.', false); return null; }
      const res = await api('/api/admin/kurator/press-releases', { method: 'POST', body: JSON.stringify(p) });
      if (!res.ok) { kStatus('pr-status', 'Kunne ikke lagre.', false); return null; }
      const data = await res.json();
      $('pr-id').value = data.release?.id || '';
      await loadPress();
      if (!silent) kStatus('pr-status', '✓ Pressemelding lagret.', true);
      return data.release;
    }
    $('pr-save')?.addEventListener('click', () => prSave(false));

    $('pr-send')?.addEventListener('click', async () => {
      if (!confirm('Send pressemeldingen til hele presselisten? Dette kan ikke angres.')) return;
      let id = $('pr-id').value;
      if (!id) { const saved = await prSave(true); if (!saved) return; id = saved.id; }
      kStatus('pr-status', 'Sender …', true);
      const res = await api('/api/admin/kurator/send-press', { method: 'POST', body: JSON.stringify({ id: Number(id) }) });
      const data = await res.json().catch(() => ({}));
      if (res.ok) {
        kStatus('pr-status', `✓ Sendt til ${data.recipients} pressekontakter.`, true);
        hide('pr-form'); prReset(); await loadPress();
      } else {
        kStatus('pr-status', `Sending feilet: ${data.error || `HTTP ${res.status}`}`, false);
      }
    });

    $('pc-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const payload = {
        name: $('pc-name').value.trim(),
        outlet: $('pc-outlet').value.trim() || null,
        email: $('pc-email').value.trim(),
        country: $('pc-country').value.trim() || null,
        language: $('pc-language').value,
      };
      const res = await api('/api/admin/kurator/press-contacts', { method: 'POST', body: JSON.stringify(payload) });
      if (res.ok) { $('pc-form').reset(); await loadPress(); }
      else alert('Kunne ikke legge til kontakt.');
    });

    async function pcDelete(id) {
      if (!confirm('Slette denne pressekontakten?')) return;
      const res = await api(`/api/admin/kurator/press-contacts/${encodeURIComponent(id)}`, { method: 'DELETE' });
      if (res.ok) await loadPress();
      else alert('Kunne ikke slette.');
    }

