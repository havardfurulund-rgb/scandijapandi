                const configStatus = document.getElementById('email-config-status');

                // Test-e-post sendes via /api/admin/test-email, som bruker den samme
                // utgående e-postveien (Resend) som kundekvittering og produsentvarsel.
                // Slik tester knappen den faktiske produksjonsveien – ikke bare et
                // internt Netlify Forms-varsel.
                (async () => {
                  try {
                    const res = await fetch('/api/admin/test-email');
                    const data = await res.json().catch(() => ({}));
                    if (data.configured) {
                      configStatus.textContent = `Utgående e-post er konfigurert. Avsender: ${data.from}. Skriv inn en adresse og send en ekte test.`;
                      configStatus.style.color = '#3f6212';
                    } else {
                      configStatus.textContent = 'Utgående e-post er ikke konfigurert ennå (RESEND_API_KEY mangler). Butikkvarsel sendes via Netlify Forms, men kunde- og produsent-e-post krever Resend.';
                      configStatus.style.color = '#A6694C';
                    }
                  } catch (e) {
                    configStatus.textContent = 'Kunne ikke sjekke e-postkonfigurasjon.';
                    configStatus.style.color = '#A6694C';
                  }
                })();

                // Liten hjelper for konsistent status + konsoll-logging, slik at det er
                // enkelt å feilsøke e-post fra nettleserens utviklerverktøy.
                function setStatus(message, color) {
                  status.textContent = message;
                  status.style.color = color;
                  console.log('[test-epost]', message);
                }

                btn.addEventListener('click', async () => {
                  const email = input.value.trim();
                  if (!email) {
                    setStatus('Skriv inn en e-postadresse', 'red');
                    return;
                  }

                  btn.disabled = true;
                  setStatus('Sender …', '#666');

                  try {
                    console.log('[test-epost] POST /api/admin/test-email', { email });
                    const res = await fetch('/api/admin/test-email', {
                      method: 'POST',
                      headers: { 'Content-Type': 'application/json' },
                      body: JSON.stringify({ email }),
                    });
                    const data = await res.json().catch(() => ({}));
                    console.log('[test-epost] svar', res.status, data);

                    if (res.ok) {
                      setStatus('✅ Test-e-post sendt. Sjekk innboksen (og spam).', 'green');
                      input.value = '';
                    } else {
                      setStatus(`Feil ved sending: ${data.error || `HTTP ${res.status}`}`, 'red');
                    }
                  } catch (err) {
                    console.error('[test-epost] nettverksfeil', err);
                    setStatus('Nettverksfeil – prøv igjen', 'red');
                  } finally {
                    btn.disabled = false;
                  }
                });
              </script>
              <!-- === SLUTT PÅ TEST E-POST KNAPP === -->
            </div>
          </details>
        </div>
      </section>
    </section>
  </main>

  <script>
    import {
      login, logout, getUser,
      requestPasswordRecovery, handleAuthCallback, updateUser, acceptInvite,
      AuthError, MissingIdentityError,
    } from '@netlify/identity';

    const nok = new Intl.NumberFormat('nb-NO', { style: 'currency', currency: 'NOK', maximumFractionDigits: 0 });
    const $ = (id) => document.getElementById(id);
    const show = (id) => $(id).classList.remove('hidden');
    const hide = (id) => $(id).classList.add('hidden');

    // The mutually-exclusive top-level views. Only one is ever visible.
    const VIEWS = ['temp-login-view', 'login-view', 'forgot-view', 'reset-view', 'noaccess-view', 'admin-view'];
    function showOnly(view) { VIEWS.forEach((v) => (v === view ? show(v) : hide(v))); }

    // Turn an identity error into a human message without leaking which field was wrong.
    function authMessage(err) {
      if (err instanceof MissingIdentityError) return 'Identity er ikke aktivert. Kjør «netlify dev» eller aktiver Identity i prosjektet.';
      if (err instanceof AuthError) {
        if (err.status === 401) return 'Feil e-post eller passord.';
        if (err.status === 403) return 'Handlingen er ikke tillatt for denne kontoen.';
        if (err.status === 422) return 'Ugyldig inndata. Sjekk e-post og passord (minst 8 tegn).';
        if (err.status === 404) return 'Fant ingen konto for denne e-posten.';
        return err.message || 'Noe gikk galt. Prøv igjen.';
      }
      return err?.message || 'Noe gikk galt. Prøv igjen.';
    }

    function escapeHtml(s) {
      return String(s ?? '').replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));
    }

    async function api(path, options = {}) {
      const res = await fetch(path, { ...options, headers: { 'Content-Type': 'application/json', ...(options.headers || {}) } });
      return res;
    }

    function renderList(products) {
      const list = $('product-list');
      if (!products.length) { list.innerHTML = '<p class="text-sm text-stone">Ingen produkter ennå.</p>'; return; }
      list.innerHTML = products.map((p) => `
        <div class="flex items-center gap-4 bg-paper border border-ink/10 p-4">
          <img src="${escapeHtml(p.image_url)}" alt="" class="h-16 w-16 object-cover bg-oat" />
          <div class="flex-1 min-w-0">
            <p class="font-serif text-lg text-ink truncate">${escapeHtml(p.name)} ${p.active ? '' : '<span class="text-[10px] uppercase tracking-widest text-clay">(skjult)</span>'}</p>
            <p class="text-[10px] uppercase tracking-wider text-stone">${escapeHtml(p.producer || '')} · ${nok.format(Number(p.price_nok))} · /${escapeHtml(p.slug)}</p>
            ${p.producer_email ? `<p class="text-[10px] uppercase tracking-wider text-stone/70">✉ ${escapeHtml(p.producer_email)}</p>` : '<p class="text-[10px] uppercase tracking-wider text-clay">Mangler produsent e-post</p>'}
          </div>
          <button type="button" data-edit="${escapeHtml(p.slug)}" class="text-[10px] uppercase tracking-widest text-stone hover:text-ink">Rediger</button>
          <button type="button" data-del="${escapeHtml(p.slug)}" class="text-[10px] uppercase tracking-widest text-clay hover:opacity-70">Slett</button>
        </div>`).join('');

      list.querySelectorAll('[data-edit]').forEach((b) => b.addEventListener('click', () => startEdit(products.find((x) => x.slug === b.dataset.edit))));
      list.querySelectorAll('[data-del]').forEach((b) => b.addEventListener('click', () => del(b.dataset.del)));
    }

    let cache = [];
    async function loadProducts() {
      const res = await api('/api/admin/products');
      if (!res.ok) return;
      const data = await res.json();
      cache = data.products || [];
      renderList(cache);
    }

    // ---- Ordrehistorikk ----

    // Menneskelig etikett + farge for ordrens e-poststatus.
    function orderStatus(status) {
      if (status === 'emailed') return { label: 'E-post sendt', cls: 'text-ink' };
      if (status === 'email-failed') return { label: 'E-post feilet', cls: 'text-clay' };
      return { label: status || 'Mottatt', cls: 'text-stone' };
    }

    function renderOrders(orders) {
      const list = $('orders-list');
      if (!orders.length) { list.innerHTML = '<p class="text-sm text-stone">Ingen ordrer ennå.</p>'; return; }
      const fmtDate = (s) => { try { return new Date(s).toLocaleString('nb-NO', { dateStyle: 'medium', timeStyle: 'short' }); } catch { return s || ''; } };
      list.innerHTML = orders.map((o) => {
        const st = orderStatus(o.status);
        const amount = Number.isFinite(o.amount) ? nok.format(o.amount) : '';
        return `
        <details class="bg-paper border border-ink/10">
          <summary class="flex items-center gap-4 p-4 cursor-pointer list-none">
            <div class="flex-1 min-w-0">
              <p class="font-serif text-lg text-ink truncate">${escapeHtml(o.product)} · ${escapeHtml(amount)}</p>
              <p class="text-[10px] uppercase tracking-wider text-stone">${escapeHtml(fmtDate(o.created_at))} · ${escapeHtml(o.customer_name || o.customer_email || 'Ukjent kunde')}${o.curator ? ` · henvist av ${escapeHtml(o.curator)}` : ''}</p>
            </div>
            <span class="text-[10px] uppercase tracking-widest ${st.cls} whitespace-nowrap">${escapeHtml(st.label)}</span>
          </summary>
          <div class="border-t border-ink/10 px-4 py-4 text-sm text-stone space-y-1">
            <p><span class="text-[10px] uppercase tracking-wider text-stone/70">Ordrenr</span> <span class="text-ink break-all">${escapeHtml(o.order_id)}</span></p>
            ${o.customer_email ? `<p><span class="text-[10px] uppercase tracking-wider text-stone/70">Kunde</span> <span class="text-ink">${escapeHtml(o.customer_name || '')} · ${escapeHtml(o.customer_email)}</span></p>` : ''}
            ${o.customer_phone ? `<p><span class="text-[10px] uppercase tracking-wider text-stone/70">Telefon</span> <span class="text-ink">${escapeHtml(o.customer_phone)}</span></p>` : ''}
            ${o.producer_email ? `<p><span class="text-[10px] uppercase tracking-wider text-stone/70">Produsent</span> <span class="text-ink">${escapeHtml(o.producer_email)}</span></p>` : ''}
            ${o.shipping_address ? `<p><span class="text-[10px] uppercase tracking-wider text-stone/70">Leveres til</span><br /><span class="text-ink whitespace-pre-line">${escapeHtml(o.shipping_address)}</span></p>` : ''}
          </div>
        </details>`;
      }).join('');
    }

    async function loadOrders() {
      const list = $('orders-list');
      try {
        const res = await api('/api/admin/orders');
        if (!res.ok) { list.innerHTML = '<p class="text-sm text-clay">Kunne ikke laste ordrer.</p>'; return; }
        const data = await res.json();
        renderOrders(data.orders || []);
      } catch (e) {
        list.innerHTML = '<p class="text-sm text-clay">Kunne ikke laste ordrer.</p>';
      }
    }

    // ---- Leads (Private Circle) ----

    function renderLeads(leads, summary) {
      $('leads-total').textContent = summary?.total ?? leads.length;
      $('leads-customers').textContent = summary?.customers ?? 0;
      $('leads-makers').textContent = summary?.makers ?? 0;
      $('leads-curators').textContent = summary?.curators ?? 0;

      const list = $('leads-list');
      if (!leads.length) { list.innerHTML = '<p class="text-sm text-stone">Ingen leads ennå.</p>'; return; }
      const fmtDate = (s) => { try { return new Date(s).toLocaleDateString('nb-NO', { dateStyle: 'medium' }); } catch { return s || ''; } };
      list.innerHTML = `
        <table class="w-full text-sm border-collapse">
          <thead>
            <tr class="text-left border-b border-ink/10">
              <th class="py-3 pr-4 text-[10px] uppercase tracking-widest text-stone font-medium">Email</th>
              <th class="py-3 pr-4 text-[10px] uppercase tracking-widest text-stone font-medium">Segment</th>
              <th class="py-3 pr-4 text-[10px] uppercase tracking-widest text-stone font-medium">Language</th>
              <th class="py-3 pr-4 text-[10px] uppercase tracking-widest text-stone font-medium">Ref code</th>
              <th class="py-3 text-[10px] uppercase tracking-widest text-stone font-medium">Date</th>
            </tr>
          </thead>
          <tbody>
            ${leads.map((l) => `
              <tr class="border-b border-ink/5">
                <td class="py-3 pr-4 text-ink break-all">${escapeHtml(l.email)}</td>
                <td class="py-3 pr-4 text-stone">${escapeHtml(l.segment || '—')}</td>
                <td class="py-3 pr-4 text-stone uppercase">${escapeHtml(l.language || '—')}</td>
                <td class="py-3 pr-4 text-stone">${escapeHtml(l.ref_code || '—')}</td>
                <td class="py-3 text-stone whitespace-nowrap">${escapeHtml(fmtDate(l.created_at))}</td>
              </tr>`).join('')}
          </tbody>
        </table>`;
    }

    async function loadLeads() {
      const list = $('leads-list');
      try {
        const res = await api('/api/admin/leads');
        if (!res.ok) { list.innerHTML = '<p class="text-sm text-clay">Kunne ikke laste leads.</p>'; return; }
        const data = await res.json();
        renderLeads(data.leads || [], data.summary);
      } catch (e) {
        list.innerHTML = '<p class="text-sm text-clay">Kunne ikke laste leads.</p>';
      }
    }

    function startEdit(p) {
      if (!p) return;
      $('form-title').textContent = 'Rediger produkt';
      $('edit-slug').value = p.slug;
      $('p-name').value = p.name || '';
      $('p-name-en').value = p.name_en || '';
      $('p-name-jp').value = p.name_jp || '';
      $('p-producer').value = p.producer || '';
      $('p-producer-email').value = p.producer_email || '';
      $('p-price').value = p.price_nok ?? '';
      $('p-price-jpy').value = p.price_jpy ?? '';
      setImage(p.image_url || '');
      $('p-description').value = p.description || '';
      $('p-description-en').value = p.description_en || '';
      $('p-description-jp').value = p.description_jp || '';
      $('p-origin-story').value = p.origin_story || '';
      $('p-producer-location').value = p.producer_location || '';
      $('p-producer-image-url').value = p.producer_image_url || '';
      $('p-producer-story').value = p.producer_story || '';
      $('p-material').value = p.material || '';
      $('p-dimensions').value = p.dimensions || '';
      $('p-care').value = p.care_instructions || '';
      $('p-active').checked = !!p.active;
      $('p-slug-edit').value = p.slug || '';
      $('p-stripe-link').value = p.stripe_link || '';
      $('p-stock').value = p.stock_quantity ?? '';
      $('p-weight-grams').value = p.weight_grams ?? '';
      $('p-country-of-origin').value = p.country_of_origin || '';
      const gallery = Array.isArray(p.gallery_urls) ? p.gallery_urls : [];
      $('p-gallery-1').value = gallery[0] || '';
      $('p-gallery-2').value = gallery[1] || '';
      $('p-gallery-3').value = gallery[2] || '';
      $('p-gallery-4').value = gallery[3] || '';
      $('p-origin-story-en').value = p.origin_story_en || '';
      $('p-origin-story-jp').value = p.origin_story_jp || '';
      $('p-producer-story-en').value = p.producer_story_en || '';
      $('p-producer-story-jp').value = p.producer_story_jp || '';
      $('p-material-en').value = p.material_en || '';
      $('p-material-jp').value = p.material_jp || '';
      $('p-care-en').value = p.care_instructions_en || '';
      $('p-care-jp').value = p.care_instructions_jp || '';
      show('cancel-edit');
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function resetForm() {
      $('form-title').textContent = 'Nytt produkt';
      $('product-form').reset();
      $('edit-slug').value = '';
      $('p-active').checked = true;
      setImage('');
      hide('cancel-edit');
      // Clear fields not covered by form.reset() (hidden inputs etc)
      ['p-name-en','p-name-jp','p-price-jpy','p-description-en','p-description-jp',
       'p-origin-story','p-producer-location','p-producer-image-url',
       'p-producer-story','p-material','p-dimensions','p-care',
       'p-slug-edit', 'p-stripe-link', 'p-stock', 'p-weight-grams', 'p-country-of-origin', 'p-gallery-1', 'p-gallery-2', 'p-gallery-3', 'p-gallery-4',
       'p-origin-story-en', 'p-origin-story-jp', 'p-producer-story-en', 'p-producer-story-jp', 'p-material-en', 'p-material-jp', 'p-care-en', 'p-care-jp'].forEach(id => {
        const el = document.getElementById(id);
        if (el) (el as HTMLInputElement | HTMLTextAreaElement).value = '';
      });
    }

    function msg(text, ok) {
      const el = $('product-msg');
      el.textContent = text;
      el.className = `text-sm ${ok ? 'text-ink' : 'text-clay'}`;
      show('product-msg');
      setTimeout(() => hide('product-msg'), 4000);
    }

    async function del(slug) {
      if (!confirm('Slette dette produktet?')) return;
      const res = await api(`/api/admin/products/${encodeURIComponent(slug)}`, { method: 'DELETE' });
      if (res.ok) { await loadProducts(); msg('Produkt slettet.', true); } else { msg('Kunne ikke slette.', false); }
    }

    $('product-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const slug = $('edit-slug').value;
      const priceJpy = Number($('p-price-jpy').value);
      const payload = {
        name:                 $('p-name').value.trim(),
        name_en:              $('p-name-en').value.trim() || null,
        name_jp:              $('p-name-jp').value.trim() || null,
        producer:             $('p-producer').value.trim(),
        producer_email:       $('p-producer-email').value.trim(),
        price_nok:            Number($('p-price').value),
        price_jpy:            Number.isFinite(priceJpy) && priceJpy > 0 ? Math.round(priceJpy) : null,
        image_url:            $('p-image').value.trim(),
        description:          $('p-description').value.trim() || null,
        description_en:         $('p-description-en').value.trim() || null,
        description_jp:         $('p-description-jp').value.trim() || null,
        origin_story:           $('p-origin-story').value.trim() || null,
        origin_story_en:        $('p-origin-story-en').value.trim() || null,
        origin_story_jp:        $('p-origin-story-jp').value.trim() || null,
        producer_story_en:      $('p-producer-story-en').value.trim() || null,
        producer_story_jp:      $('p-producer-story-jp').value.trim() || null,
        material_en:            $('p-material-en').value.trim() || null,
        material_jp:            $('p-material-jp').value.trim() || null,
        care_instructions_en:   $('p-care-en').value.trim() || null,
        care_instructions_jp:   $('p-care-jp').value.trim() || null,
        producer_location:    $('p-producer-location').value.trim() || null,
        producer_image_url:   $('p-producer-image-url').value.trim() || null,
        producer_story:       $('p-producer-story').value.trim() || null,
        material:             $('p-material').value.trim() || null,
        dimensions:           $('p-dimensions').value.trim() || null,
        care_instructions:    $('p-care').value.trim() || null,
        stripe_link:          $('p-stripe-link').value.trim() || null,
        stock_quantity:       $('p-stock').value !== '' ? Number($('p-stock').value) : null,
        weight_grams:         $('p-weight-grams').value !== '' ? Number($('p-weight-grams').value) : null,
        country_of_origin:    $('p-country-of-origin').value.trim() || null,
        gallery_urls:         [$('p-gallery-1').value.trim(), $('p-gallery-2').value.trim(), $('p-gallery-3').value.trim(), $('p-gallery-4').value.trim()].filter(Boolean),
        active:               $('p-active').checked,
      };
      const res = slug
        ? await api(`/api/admin/products/${encodeURIComponent(slug)}`, { method: 'PUT', body: JSON.stringify(payload) })
        : await api('/api/admin/products', { method: 'POST', body: JSON.stringify(payload) });
      if (res.ok) { resetForm(); await loadProducts(); msg('Lagret.', true); }
      else {
        const err = await res.json().catch(() => ({}));
        msg(err.error === 'a valid producer_email is required' ? 'Oppgi en gyldig produsent e-post.' : 'Kunne ikke lagre.', false);
      }
    });

    $('cancel-edit').addEventListener('click', resetForm);

    // ── AI Translation ────────────────────────────────────────────────
    document.getElementById('btn-translate')?.addEventListener('click', async () => {
      const name = $('p-name').value.trim();
      if (!name) {
        showTranslateStatus('Fyll inn produktnavn (NO) først.', false);
        return;
      }

      const btn = document.getElementById('btn-translate');
      const label = document.getElementById('translate-label');
      const icon = document.getElementById('translate-icon');
      if (btn) btn.setAttribute('disabled', 'true');
      if (label) label.textContent = 'Oversetter…';
      if (icon) icon.textContent = '⟳';

      try {
        const payload = {
          name:                $('p-name').value.trim(),
          description:         $('p-description').value.trim(),
          origin_story:        $('p-origin-story').value.trim(),
          producer_story:      $('p-producer-story').value.trim(),
          material:            $('p-material').value.trim(),
          care_instructions:   $('p-care').value.trim(),
        };

        const res = await fetch('/api/admin/translate', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });

        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        const { translations: t } = await res.json();

        // Fill EN fields
        if (t.name_en)         $('p-name-en').value = t.name_en;
        if (t.description_en)  $('p-description-en').value = t.description_en;
        if (t.origin_story_en) $('p-origin-story-en').value = t.origin_story_en;
        if (t.producer_story_en) $('p-producer-story-en').value = t.producer_story_en;
        if (t.material_en)     $('p-material-en').value = t.material_en;
        if (t.care_en)         $('p-care-en').value = t.care_en;

        // Fill JP fields
        if (t.name_jp)         $('p-name-jp').value = t.name_jp;
        if (t.description_jp)  $('p-description-jp').value = t.description_jp;
        if (t.origin_story_jp) $('p-origin-story-jp').value = t.origin_story_jp;
        if (t.producer_story_jp) $('p-producer-story-jp').value = t.producer_story_jp;
        if (t.material_jp)     $('p-material-jp').value = t.material_jp;
        if (t.care_jp)         $('p-care-jp').value = t.care_jp;

        // Add EN/JP description textareas if they were empty
        if (t.description_en && !$('p-description-en').value)
          $('p-description-en').value = t.description_en;
        if (t.description_jp && !$('p-description-jp').value)
          $('p-description-jp').value = t.description_jp;

        showTranslateStatus('✓ Oversettelse fullført — kontroller og lagre.', true);
      } catch (err) {
        console.error('[translate]', err);
        showTranslateStatus('Oversettelse feilet — prøv igjen.', false);
      } finally {
        if (btn) btn.removeAttribute('disabled');
        if (label) label.textContent = 'Oversett automatisk (NO → EN + JP)';
        if (icon) icon.textContent = '✦';
      }
    });

    function showTranslateStatus(msg: string, ok: boolean) {
      const el = document.getElementById('translate-status');
      if (!el) return;
      el.textContent = msg;
      el.className = `text-[11px] ${ok ? 'text-moss' : 'text-clay'}`;
      el.classList.remove('hidden');
      setTimeout(() => el.classList.add('hidden'), 6000);
    }

    // ---- Bilde-opplasting (Netlify Blobs via /api/admin/upload) ----

    // Synk forhåndsvisningen med det skjulte image_url-feltet.
    function setImage(url) {
      $('p-image').value = url || '';
      if (url) {
        $('p-image-preview').src = url;
        show('p-image-preview-wrap');
        hide('p-image-placeholder');
      } else {
        $('p-image-preview').removeAttribute('src');
        hide('p-image-preview-wrap');
        show('p-image-placeholder');
      }
    }

    function imageStatus(text, ok) {
      const el = $('p-image-status');
      if (!text) { hide('p-image-status'); el.textContent = ''; return; }
      el.textContent = text;
      el.className = `mt-1 text-[11px] ${ok === false ? 'text-clay' : 'text-stone'}`;
      show('p-image-status');
    }

    async function uploadFile(file) {
      if (!file) return;
      if (!file.type.startsWith('image/')) { imageStatus('Velg en bildefil.', false); return; }
      if (file.size > 5 * 1024 * 1024) { imageStatus('Bildet er for stort (maks 5 MB).', false); return; }

      const uploadBtn = $('p-image-upload');
      uploadBtn.disabled = true;
      imageStatus('Laster opp …');
      try {
        const fd = new FormData();
        fd.append('file', file);
        const res = await fetch('/api/admin/upload', { method: 'POST', body: fd });
        const data = await res.json().catch(() => ({}));
        if (!res.ok) throw new Error(data.error || 'Opplasting feilet.');
        setImage(data.url);
        imageStatus('Bilde lastet opp.', true);
      } catch (err) {
        imageStatus(err.message || 'Opplasting feilet.', false);
      } finally {
        uploadBtn.disabled = false;
        $('p-image-file').value = '';
      }
    }

    $('p-image-upload').addEventListener('click', () => $('p-image-file').click());
    $('p-image-file').addEventListener('change', (e) => uploadFile(e.target.files?.[0]));
    $('p-image-remove').addEventListener('click', () => { setImage(''); imageStatus(''); });

    // Dra-og-slipp på opplastingsfeltet.
    const drop = $('p-image-drop');
    ['dragenter', 'dragover'].forEach((evt) =>
      drop.addEventListener(evt, (e) => { e.preventDefault(); drop.classList.add('border-ink', 'bg-oat/60'); }));
    ['dragleave', 'drop'].forEach((evt) =>
      drop.addEventListener(evt, (e) => { e.preventDefault(); drop.classList.remove('border-ink', 'bg-oat/60'); }));
    drop.addEventListener('drop', (e) => uploadFile(e.dataTransfer?.files?.[0]));

    // Influencer link generator
    $('ref-make').addEventListener('click', () => {
      const name = $('ref-name').value.trim().toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
      if (!name) return;
      const link = `${window.location.origin}/?ref=${encodeURIComponent(name)}`;
      $('ref-link').textContent = link;
      show('ref-result');
    });
    $('ref-copy').addEventListener('click', () => navigator.clipboard?.writeText($('ref-link').textContent || ''));

    // Oppdater ordrehistorikken på forespørsel.
    $('orders-refresh').addEventListener('click', () => loadOrders());
    $('leads-refresh').addEventListener('click', () => loadLeads());

    // ---- Auth ----

    // ---- Kodebasert admin-innlogging (hovedløsning: brukernavn + passord) ----
    // En enkel, pålitelig innlogging som snakker med /api/admin/* og setter en
    // httpOnly øktcookie på serveren. Brukernavn/passord ligger i
    // netlify/lib/temp-admin.mts. Fungerer uavhengig av Netlify Identity.

    // Sjekk om en gyldig admin-cookie allerede finnes.
    async function isTempAdmin() {
      try {
        const res = await fetch('/api/admin/session');
        if (!res.ok) return false;
        const data = await res.json();
        return !!data.authenticated;
      } catch (e) {
        return false;
      }
    }

    // Vis dashbordet for en innlogget (midlertidig) admin.
    async function enterDashboard(label) {
      $('admin-email').textContent = label || '';
      show('logout-btn');
      showOnly('admin-view');
      await loadProducts();
      loadOrders();
      loadLeads();
      loadKurator();
    }

    // Logg inn med kodebasert brukernavn + passord.
    $('temp-login-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      hide('temp-login-error');
      try {
        const res = await fetch('/api/admin/login', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ username: $('temp-username').value, password: $('temp-password').value }),
        });
        if (!res.ok) throw new Error('bad credentials');
        $('temp-password').value = '';
        await enterDashboard($('temp-username').value || 'Admin');
      } catch (err) {
        $('temp-login-error').textContent = 'Feil brukernavn eller passord. Prøv igjen.';
        show('temp-login-error');
      }
    });

    // Bytt til/fra den fulle Netlify Identity-innloggingen.
    $('use-identity').addEventListener('click', () => showOnly('login-view'));
    $('back-to-temp').addEventListener('click', () => showOnly('temp-login-view'));

    // Logout from the dashboard and the "no access" screen. Clears BOTH the
    // temporary session cookie and any Netlify Identity session, then reloads.
    async function doLogout() {
      try { await fetch('/api/admin/logout', { method: 'POST' }); } catch (e) {}
      try { await logout(); } catch (e) {}
      location.assign('/admin');
    }
    $('logout-btn').addEventListener('click', doLogout);
    $('noaccess-logout').addEventListener('click', doLogout);

    // Login
    $('login-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      hide('login-error');
      try {
        await login($('login-email').value, $('login-password').value);
        await boot();
      } catch (err) {
        const el = $('login-error');
        el.textContent = authMessage(err);
        show('login-error');
      }
    });

    // Switch between login and "forgot password".
    $('forgot-link').addEventListener('click', () => {
      hide('login-error');
      $('forgot-email').value = $('login-email').value;
      hide('forgot-msg');
      showOnly('forgot-view');
    });
    $('back-to-login').addEventListener('click', () => showOnly('login-view'));

    // Request a recovery email.
    $('forgot-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const el = $('forgot-msg');
      try {
        await requestPasswordRecovery($('forgot-email').value.trim());
        el.textContent = 'Sjekk e-posten din for en lenke til å sette nytt passord.';
        el.className = 'text-sm text-ink';
        show('forgot-msg');
      } catch (err) {
        el.textContent = authMessage(err);
        el.className = 'text-sm text-clay';
        show('forgot-msg');
      }
    });

    // Set a new password — used for both recovery and invite acceptance.
    // resetMode is 'recovery' (user already logged in via the callback) or
    // 'invite' (we hold a token and must redeem it together with the password).
    let resetMode = 'recovery';
    let inviteToken = null;

    function showResetView(mode, { email, title, sub } = {}) {
      resetMode = mode;
      $('reset-title').textContent = title || 'Sett nytt passord';
      $('reset-sub').textContent = sub || (email ? `Velg et nytt passord for ${email}.` : 'Velg et nytt passord for kontoen din.');
      hide('reset-error');
      $('reset-form').reset();
      showOnly('reset-view');
    }

    $('reset-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      hide('reset-error');
      const pw = $('reset-password').value;
      const pw2 = $('reset-password2').value;
      const el = $('reset-error');
      if (pw.length < 8) { el.textContent = 'Passordet må være minst 8 tegn.'; show('reset-error'); return; }
      if (pw !== pw2) { el.textContent = 'Passordene er ikke like.'; show('reset-error'); return; }
      try {
        if (resetMode === 'invite') {
          await acceptInvite(inviteToken, pw);
        } else {
          await updateUser({ password: pw });
        }
        inviteToken = null;
        await boot();
      } catch (err) {
        el.textContent = authMessage(err);
        show('reset-error');
      }
    });

    // Route an authenticated user to the dashboard, the "no access" screen, or
    // the login form — the single source of truth for what the page shows.
    async function boot() {
      // getUser kan kaste hvis Identity ikke er aktivert – da faller vi pent
      // tilbake til den midlertidige passord-innloggingen.
      let user = null;
      try { user = await getUser(); } catch (e) { user = null; }
      if (!user) {
        // Ingen Identity-bruker: vis den midlertidige passord-innloggingen som standard.
        showOnly('temp-login-view');
        hide('logout-btn');
        $('admin-email').textContent = '';
        return;
      }
      $('admin-email').textContent = user.email || '';
      show('logout-btn');
      if (!user.roles?.includes('admin')) { showOnly('noaccess-view'); return; }
      showOnly('admin-view');
      await loadProducts();
      loadOrders();
      loadLeads();
      loadKurator();
    }

    // On page load, redeem any token in the URL hash (recovery, invite,
    // confirmation, email change) BEFORE deciding which view to show. This is
    // what makes the emailed recovery and invite links actually work.
    async function init() {
      // Kodebasert admin: er øktcookien allerede gyldig? Gå rett inn.
      if (await isTempAdmin()) {
        await enterDashboard('Admin');
        return;
      }

      let routed = false;
      try {
        const result = await handleAuthCallback();
        if (result?.type === 'recovery') {
          showResetView('recovery', { email: result.user?.email });
          routed = true;
        } else if (result?.type === 'invite') {
          inviteToken = result.token;
          showResetView('invite', { title: 'Velkommen', sub: 'Velg et passord for å fullføre kontoen din.' });
          routed = true;
        }
        // 'confirmation' / 'email_change' / 'oauth' log the user in; boot() handles them.
      } catch (err) {
        if (window.location.hash) {
          // Kom hit fra en e-postlenke (recovery/invite) med en ugyldig/brukt
          // token: vis Identity-innloggingen med kontekst.
          showOnly('login-view');
          $('login-error').textContent = authMessage(err);
          show('login-error');
          routed = true;
        }
        // Ellers (f.eks. Identity ikke aktivert): la boot() vise den
        // midlertidige passord-innloggingen som standard.
      }

      // Strip the hash so a refresh can't try to reuse a one-time token.
      if (window.location.hash) {
        history.replaceState(null, '', window.location.pathname + window.location.search);
      }

      if (!routed) await boot();
    }

    // ══════════════════════════════════════════════════════════════════
    //  KURATOR HUB
    //  Nyhetsbrev · Pressemeldinger · Produsenter · Influensere.
    //  Bruker samme api()-hjelper, show/hide-mønster og styling som resten
    //  av admin-panelet.
    // ══════════════════════════════════════════════════════════════════
    const nokMinor = (v) => nok.format(Number(v || 0) / 100);
    const fmtDay = (s) => { try { return new Date(s).toLocaleDateString('nb-NO', { dateStyle: 'medium' }); } catch { return s || ''; } };

    // ── Fane-navigasjon ──────────────────────────────────────────────
    const K_TABS = ['nyhetsbrev', 'presse', 'produsenter', 'influensere'];
    function showKuratorTab(tab) {
      K_TABS.forEach((t) => { const el = $(`ktab-${t}`); if (el) el.classList.toggle('hidden', t !== tab); });
      document.querySelectorAll('.k-tab').forEach((b) => {
        const on = b.dataset.ktab === tab;
        b.classList.toggle('border-ink', on);
        b.classList.toggle('text-ink', on);
        b.classList.toggle('border-transparent', !on);
        b.classList.toggle('text-stone', !on);
      });
    }
    document.querySelectorAll('.k-tab').forEach((b) => b.addEventListener('click', () => showKuratorTab(b.dataset.ktab)));

    function kStatus(id, text, ok) {
      const el = $(id);
      if (!el) return;
      el.textContent = text;
      el.className = `text-[11px] ${ok ? 'text-moss' : 'text-clay'}`;
      show(id);
      setTimeout(() => hide(id), 5000);
    }

    // Delt statusmerke for kladd/sendt.
    function sendBadge(status) {
      return status === 'sent'
        ? '<span class="text-[10px] uppercase tracking-widest text-moss">Sendt</span>'
        : '<span class="text-[10px] uppercase tracking-widest text-clay">Kladd</span>';
    }

    async function loadKurator() {
      loadNewsletters();
      loadPress();
      loadProducers();
      loadInfluencers();
    }
    $('kurator-refresh')?.addEventListener('click', loadKurator);

    // ── Delt AI-oversettelse (gjenbruker /api/admin/translate) ───────
    // Endepunktet forventer { name, description } og svarer med *_en/*_jp.
    async function kTranslate(sourceText, sourceBody, btnId, iconId, labelId, apply) {
      if (!sourceText) { return { error: 'Fyll inn tekst (NO) først.' }; }
      const btn = $(btnId), icon = $(iconId), label = $(labelId);
      if (btn) btn.setAttribute('disabled', 'true');
      if (label) label.textContent = 'Oversetter…';
      if (icon) icon.textContent = '⟳';
      try {
        const res = await fetch('/api/admin/translate', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name: sourceText, description: sourceBody }),
        });
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        const { translations: t } = await res.json();
        apply(t);
        return { ok: true };
      } catch (err) {
        console.error('[kurator-translate]', err);
        return { error: 'Oversettelse feilet — prøv igjen.' };
      } finally {
        if (btn) btn.removeAttribute('disabled');
        if (label) label.textContent = 'Oversett automatisk (NO → EN + JP)';
        if (icon) icon.textContent = '✦';
      }
    }

    // ─────────────────────────────────────────────────────────────────
    //  NYHETSBREV
    // ─────────────────────────────────────────────────────────────────
    function renderNewsletters(rows) {
      const list = $('nl-list');
      if (!rows.length) { list.innerHTML = '<p class="text-sm text-stone">Ingen nyhetsbrev ennå.</p>'; return; }
      const segLabel = { all: 'Alle', customer: 'Kunder', maker: 'Makers', curator: 'Kuratorer' };
      list.innerHTML = `
        <table class="w-full text-sm border-collapse">
          <thead><tr class="text-left border-b border-ink/10">
            <th class="py-3 pr-4 text-[10px] uppercase tracking-widest text-stone font-medium">Emne</th>
            <th class="py-3 pr-4 text-[10px] uppercase tracking-widest text-stone font-medium">Segment</th>
            <th class="py-3 pr-4 text-[10px] uppercase tracking-widest text-stone font-medium">Status</th>
            <th class="py-3 pr-4 text-[10px] uppercase tracking-widest text-stone font-medium">Sendt</th>
            <th class="py-3 text-[10px] uppercase tracking-widest text-stone font-medium">Mottakere</th>
          </tr></thead>
          <tbody>
            ${rows.map((n) => `
              <tr class="border-b border-ink/5">
                <td class="py-3 pr-4 text-ink">${escapeHtml(n.subject_no || n.subject_en || '—')}</td>
                <td class="py-3 pr-4 text-stone">${escapeHtml(segLabel[n.segment] || n.segment || '—')}</td>
                <td class="py-3 pr-4">${sendBadge(n.status)}</td>
                <td class="py-3 pr-4 text-stone whitespace-nowrap">${n.sent_at ? escapeHtml(fmtDay(n.sent_at)) : '—'}</td>
                <td class="py-3 text-stone">${n.recipients || 0}</td>
              </tr>`).join('')}
          </tbody>
        </table>`;
    }

    async function loadNewsletters() {
      const list = $('nl-list');
      try {
        const res = await api('/api/admin/kurator/newsletters');
        if (!res.ok) { list.innerHTML = '<p class="text-sm text-clay">Kunne ikke laste nyhetsbrev.</p>'; return; }
        const data = await res.json();
        renderNewsletters(data.newsletters || []);
      } catch { list.innerHTML = '<p class="text-sm text-clay">Kunne ikke laste nyhetsbrev.</p>'; }
    }

    function nlReset() {
      $('nl-id').value = '';
      ['nl-subject-no','nl-subject-en','nl-subject-jp','nl-body-no','nl-body-en','nl-body-jp'].forEach((id) => { $(id).value = ''; });
